<UserControl
    x:Class="精密切割系统.View.Controls.KeyboardBtn"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behav="clr-namespace:精密切割系统.Behaviors"
    xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:精密切割系统.View.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="62"
    d:DesignWidth="72"
    Loaded="keyboardBtn_Loaded"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style TargetType="Button">
            <Setter Property="BorderBrush" Value="{x:Null}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Border
        x:Name="keyboardBorderBtn"
        Background="#87B6D3"
        Focusable="False">
        <Button
            x:Name="keyboardBtn"
            Focusable="False"
            FontWeight="Bold"
            Foreground="#FFFFFF">
            <behaviors:Interaction.Behaviors>
                <behav:DualInputBehavior StartCommand="{Binding KeyDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" StopCommand="{Binding KeyUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            </behaviors:Interaction.Behaviors>
            <Button.Content>
                <TextBlock
                    x:Name="keyboardText"
                    Padding="3,3,0,0"
                    Text="SDF"
                    TextAlignment="Left"
                    TextWrapping="Wrap" />
            </Button.Content>
        </Button>
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="20"
                Direction="315"
                ShadowDepth="5"
                Color="#4DC9EBF7" />
        </Border.Effect>
        <!--  设置按钮内容的偏移效果  -->
        <Border.RenderTransform>
            <TranslateTransform x:Name="ContentTransform" X="0" Y="0" />
        </Border.RenderTransform>
    </Border>

</UserControl>
