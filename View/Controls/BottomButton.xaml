<UserControl
    x:Class="精密切割系统.View.Controls.BottomButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:behavs="clr-namespace:精密切割系统.Behaviors"
    xmlns:cvert="clr-namespace:精密切割系统.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:精密切割系统.View.Controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="100"
    d:DesignWidth="268"
    mc:Ignorable="d">
    <UserControl.Resources>
        <cvert:StartsWithSlashConverter x:Key="StartsWithSlashConverter" />
    </UserControl.Resources>
    <Grid Width="268" Height="100">
        <Border
            x:Name="btnBorder"
            d:Background="#5087cb"
            Background="{Binding BackgroundDefColor, RelativeSource={RelativeSource AncestorType=UserControl}}"
            CornerRadius="10">
            <behaviors:Interaction.Behaviors>
                <behavs:InteractiveBorderBehavior DefaultColor="{Binding BackgroundDefColor, RelativeSource={RelativeSource AncestorType=UserControl}}" DownColor="{Binding BackgroundDownColor, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            </behaviors:Interaction.Behaviors>
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <ContentControl
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    d:Content=""
                    Content="{Binding ImagePath, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <ContentControl.Resources>
                        <DataTemplate x:Key="IconTemplate">
                            <materialDesign:PackIcon
                                Width="35"
                                Height="35"
                                Margin="0,0,5,0"
                                Foreground="White"
                                Kind="{Binding}"
                                RenderTransformOrigin="0.964,1.2" />
                        </DataTemplate>
                        <DataTemplate x:Key="ImageTemplate">
                            <Image
                                Width="30"
                                Height="30"
                                Margin="0,0,5,0"
                                d:Source="/Assets/icon/tab_1/03/tab_02.png"
                                RenderTransformOrigin="0.964,1.2"
                                Source="{Binding}" />
                        </DataTemplate>
                    </ContentControl.Resources>
                    <ContentControl.ContentTemplateSelector>
                        <cvert:ImageOrIconTemplateSelector IconTemplate="{StaticResource IconTemplate}" ImageTemplate="{StaticResource ImageTemplate}" />
                    </ContentControl.ContentTemplateSelector>
                </ContentControl>
                <Label
                    MaxWidth="228"
                    d:Content="基准线调窄"
                    d:FontSize="22"
                    Content="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=ContentText}"
                    FontSize="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=ContentTextFontSize}"
                    FontWeight="Bold"
                    Foreground="White" />
            </StackPanel>
        </Border>
        <Image
            Width="29"
            Height="16"
            Margin="0,12,20,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Visibility="{Binding OpenOrCloseVisibility, RelativeSource={RelativeSource AncestorType=UserControl}}">
            <Image.Style>
                <Style TargetType="Image">
                    <Setter Property="Source" Value="pack://application:,,,/精密切割系统;component/Assets/icon/right/close.png" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsOpen, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                            <Setter Property="Source" Value="pack://application:,,,/精密切割系统;component/Assets/icon/right/open.png" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Image.Style>
        </Image>
        <Grid.Effect>
            <DropShadowEffect
                BlurRadius="20"
                Direction="315"
                ShadowDepth="5"
                Color="#5087CBF7" />
        </Grid.Effect>
        <!--  设置按钮内容的偏移效果  -->
        <Grid.RenderTransform>
            <TranslateTransform x:Name="ContentTransform" X="0" Y="0" />
        </Grid.RenderTransform>
        <!--  响应事件  -->
        <Grid.Triggers>
            <!--  按下时内容向阴影方向偏移并改变背景色  -->
            <EventTrigger RoutedEvent="Border.TouchDown">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation
                            Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                            To="2"
                            Duration="0:0:0.1" />
                        <DoubleAnimation
                            Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                            To="2"
                            Duration="0:0:0.1" />
                        <DoubleAnimation
                            Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                            To="0.16"
                            Duration="0:0:0.1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <!--  松开时恢复原位和背景色  -->
            <EventTrigger RoutedEvent="Border.TouchUp">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation
                            Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                            To="0"
                            Duration="0:0:0.1" />
                        <DoubleAnimation
                            Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                            To="0"
                            Duration="0:0:0.1" />
                        <DoubleAnimation
                            Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                            To="0.8"
                            Duration="0:0:0.1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="Border.TouchLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation
                            Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                            To="0"
                            Duration="0:0:0.1" />
                        <DoubleAnimation
                            Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                            To="0"
                            Duration="0:0:0.1" />
                        <DoubleAnimation
                            Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                            To="0.8"
                            Duration="0:0:0.1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="Border.MouseDown">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation
                            Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                            To="2"
                            Duration="0:0:0.1" />
                        <DoubleAnimation
                            Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                            To="2"
                            Duration="0:0:0.1" />
                        <DoubleAnimation
                            Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                            To="0.16"
                            Duration="0:0:0.1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="Border.PreviewMouseDown">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation
                            Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                            To="2"
                            Duration="0:0:0.1" />
                        <DoubleAnimation
                            Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                            To="2"
                            Duration="0:0:0.1" />
                        <DoubleAnimation
                            Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                            To="0.16"
                            Duration="0:0:0.1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="Border.MouseUp">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation
                            Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                            To="0"
                            Duration="0:0:0.1" />
                        <DoubleAnimation
                            Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                            To="0"
                            Duration="0:0:0.1" />
                        <DoubleAnimation
                            Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                            To="0.8"
                            Duration="0:0:0.1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="Border.MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation
                            Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                            To="0"
                            Duration="0:0:0.1" />
                        <DoubleAnimation
                            Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                            To="0"
                            Duration="0:0:0.1" />
                        <DoubleAnimation
                            Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                            To="0.8"
                            Duration="0:0:0.1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>
    </Grid>
</UserControl>
