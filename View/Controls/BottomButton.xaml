<UserControl x:Class="精密切割系统.View.Controls.BottomButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:cvert="clr-namespace:精密切割系统.Converters"
             xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:behavs="clr-namespace:精密切割系统.Behaviors"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:精密切割系统.View.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="268">
    <UserControl.Resources>
        <cvert:StartsWithSlashConverter x:Key="StartsWithSlashConverter" />
    </UserControl.Resources>
    <Grid Width="268" Height="100">
        <Border x:Name="btnBorder" CornerRadius="10" Background="{Binding BackgroundDefColor, RelativeSource={RelativeSource AncestorType=UserControl}}" d:Background="#5087cb">
            <behaviors:Interaction.Behaviors>
                <behavs:InteractiveBorderBehavior 
                    DownColor="{Binding BackgroundDownColor, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                    DefaultColor="{Binding BackgroundDefColor, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            </behaviors:Interaction.Behaviors>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
                <ContentControl Content="{Binding ImagePath, RelativeSource={RelativeSource AncestorType=UserControl}}" d:Content="" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ContentControl.Resources>
                        <DataTemplate x:Key="IconTemplate">
                            <materialDesign:PackIcon Kind="{Binding}" Foreground="White" Width="35" Height="35" Margin="0,0,5,0" RenderTransformOrigin="0.964,1.2" />
                        </DataTemplate>
                        <DataTemplate x:Key="ImageTemplate">
                            <Image Width="30" Height="30" Margin="0,0,5,0" RenderTransformOrigin="0.964,1.2" d:Source="/Assets/icon/tab_1/03/tab_02.png" Source="{Binding}"/>
                        </DataTemplate>
                    </ContentControl.Resources>
                    <ContentControl.ContentTemplateSelector>
                        <cvert:ImageOrIconTemplateSelector ImageTemplate="{StaticResource ImageTemplate}" IconTemplate="{StaticResource IconTemplate}"/>
                    </ContentControl.ContentTemplateSelector>
                </ContentControl>
                <Label d:Content="基准线调窄"
                       Content="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=ContentText}"
                       d:FontSize="22" FontSize="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=ContentTextFontSize}" Foreground="White" FontWeight="Bold"  MaxWidth="228"/>
            </StackPanel>
        </Border>
        <Image Visibility="{Binding OpenOrCloseVisibility, RelativeSource={RelativeSource AncestorType=UserControl}}" 
               Width="29" Height="16" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,12,20,0">
            <Image.Style>
                <Style TargetType="Image">
                    <Setter Property="Source" Value="pack://application:,,,/精密切割系统;component/Assets/icon/right/close.png"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsOpen, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                            <Setter Property="Source" Value="pack://application:,,,/精密切割系统;component/Assets/icon/right/open.png"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Image.Style>
        </Image>
        <Grid.Effect>
            <DropShadowEffect ShadowDepth="5" BlurRadius="20" Color="#5087CBF7" Direction="315" />
        </Grid.Effect>
        <!-- 设置按钮内容的偏移效果 -->
        <Grid.RenderTransform>
            <TranslateTransform x:Name="ContentTransform" X="0" Y="0" />
        </Grid.RenderTransform>
        <!-- 响应事件 -->
        <Grid.Triggers>
            <!-- 按下时内容向阴影方向偏移并改变背景色 -->
            <EventTrigger RoutedEvent="Border.TouchDown">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                          To="2" Duration="0:0:0.1" />
                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                          To="2" Duration="0:0:0.1" />
                        <DoubleAnimation Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                          To="0.16" Duration="0:0:0.1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <!-- 松开时恢复原位和背景色 -->
            <EventTrigger RoutedEvent="Border.TouchUp">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                          To="0" Duration="0:0:0.1" />
                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                          To="0" Duration="0:0:0.1" />
                        <DoubleAnimation Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                          To="0.8" Duration="0:0:0.1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="Border.TouchLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                          To="0" Duration="0:0:0.1" />
                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                          To="0" Duration="0:0:0.1" />
                        <DoubleAnimation Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                          To="0.8" Duration="0:0:0.1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="Border.MouseDown">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                          To="2" Duration="0:0:0.1" />
                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                          To="2" Duration="0:0:0.1" />
                        <DoubleAnimation Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                          To="0.16" Duration="0:0:0.1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="Border.PreviewMouseDown">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                          To="2" Duration="0:0:0.1" />
                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                          To="2" Duration="0:0:0.1" />
                        <DoubleAnimation Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                          To="0.16" Duration="0:0:0.1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="Border.MouseUp">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                          To="0" Duration="0:0:0.1" />
                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                          To="0" Duration="0:0:0.1" />
                        <DoubleAnimation Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                          To="0.8" Duration="0:0:0.1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="Border.MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                          To="0" Duration="0:0:0.1" />
                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                          To="0" Duration="0:0:0.1" />
                        <DoubleAnimation Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                          To="0.8" Duration="0:0:0.1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>
    </Grid>
</UserControl>
