<UserControl
    x:Class="精密切割系统.View.Controls.RealTimeAxisInfo"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
    xmlns:cvert="clr-namespace:精密切割系统.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:精密切割系统.Helpers"
    xmlns:local="clr-namespace:精密切割系统.View.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="UserControl_Loaded"
    Unloaded="UserControl_Unloaded"
    mc:Ignorable="d">
    <UserControl.Resources>
        <!--  布尔到可见性转换器  -->
        <cvert:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <Style BasedOn="{StaticResource InputTextStyle}" TargetType="Controls:InputTextBox">
            <Setter Property="Width" Value="100" />
            <Setter Property="Margin" Value="5,0,0,0" />
            <Setter Property="IsEnabled" Value="False" />
        </Style>
        <Style TargetType="Label">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <StackPanel HorizontalAlignment="Left">
            <Label
                Width="200"
                Margin="0,0,0,5"
                HorizontalAlignment="Left"
                Content="轴绝对位置"
                FontSize="18"
                FontWeight="Bold" />
            <StackPanel Orientation="Horizontal">
                <Label Content="X" />
                <Controls:InputTextBox x:Name="xAbsolutePosition" />
                <Label Margin="15,0,0,0" Content="Y" />
                <Controls:InputTextBox x:Name="yAbsolutePosition" />
                <Label Margin="15,0,0,0" Content="Z" />
                <Controls:InputTextBox x:Name="zAbsolutePosition" />
                <Label Margin="15,0,0,0" Content="Z2" />
                <Controls:InputTextBox x:Name="z2AbsolutePosition" />
                <Label
                    Margin="15,0,0,0"
                    Content="θ"
                    Visibility="{Binding Source={x:Static helpers:GlobalParams.HasTheta}, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Controls:InputTextBox x:Name="thetaAbsolutePosition" Visibility="{Binding Source={x:Static helpers:GlobalParams.HasTheta}, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>