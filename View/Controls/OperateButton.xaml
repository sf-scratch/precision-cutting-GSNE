<UserControl
    x:Class="精密切割系统.View.Controls.OperateButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:behavs="clr-namespace:精密切割系统.Behaviors"
    xmlns:cvert="clr-namespace:精密切割系统.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:精密切割系统.View.Controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="100"
    d:DesignWidth="268"
    mc:Ignorable="d">
    <Grid Width="268" Height="100">
        <Border
            x:Name="operateBorder"
            Background="#5087cb"
            CornerRadius="10">
            <StackPanel
                x:Name="operateBtn"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <ContentControl
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    d:Content=""
                    Content="{Binding IconSource, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <ContentControl.Resources>
                        <DataTemplate x:Key="IconTemplate">
                            <materialDesign:PackIcon
                                Width="35"
                                Height="35"
                                Margin="0,0,5,0"
                                Foreground="White"
                                Kind="{Binding}"
                                RenderTransformOrigin="0.964,1.2" />
                        </DataTemplate>
                        <DataTemplate x:Key="ImageTemplate">
                            <Image
                                Width="30"
                                Height="30"
                                Margin="0,0,5,0"
                                d:Source="/Assets/icon/tab_1/03/tab_02.png"
                                RenderTransformOrigin="0.964,1.2"
                                Source="{Binding}" />
                        </DataTemplate>
                    </ContentControl.Resources>
                    <ContentControl.ContentTemplateSelector>
                        <cvert:ImageOrIconTemplateSelector IconTemplate="{StaticResource IconTemplate}" ImageTemplate="{StaticResource ImageTemplate}" />
                    </ContentControl.ContentTemplateSelector>
                </ContentControl>
                <Label
                    MaxWidth="228"
                    FontSize="22"
                    FontWeight="Bold"
                    Foreground="White">
                    <TextBlock
                        x:Name="operateText"
                        Text="按钮"
                        TextWrapping="Wrap" />
                </Label>
            </StackPanel>
        </Border>
        <Image
            x:Name="operate01"
            Width="29"
            Height="16"
            Margin="0,12,20,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Source="{Binding ImageSource01}"
            Visibility="Collapsed" />
        <Image
            x:Name="operate02"
            Width="29"
            Height="16"
            Margin="0,12,20,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Source="{Binding ImageSource02}"
            Visibility="Collapsed" />
        <Image
            x:Name="operate03"
            Width="29"
            Height="16"
            Margin="0,12,20,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Source="{Binding ImageSource03}"
            Visibility="Collapsed" />
        <Image
            x:Name="operate04"
            Width="29"
            Height="16"
            Margin="0,12,20,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Source="{Binding ImageSource04}"
            Visibility="Collapsed" />
        <Image
            x:Name="operate05"
            Width="29"
            Height="16"
            Margin="0,12,20,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Source="{Binding ImageSource05}"
            Visibility="Collapsed" />
        <Image
            x:Name="operate06"
            Width="29"
            Height="16"
            Margin="0,12,20,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Source="{Binding ImageSource06}"
            Visibility="Collapsed" />
        <Image
            x:Name="operate07"
            Width="29"
            Height="16"
            Margin="0,12,20,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Source="{Binding ImageSource07}"
            Visibility="Collapsed" />
        <Image
            x:Name="operate08"
            Width="29"
            Height="16"
            Margin="0,12,20,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Source="{Binding ImageSource08}"
            Visibility="Collapsed" />
        <Image
            x:Name="operate09"
            Width="29"
            Height="16"
            Margin="0,12,20,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Source="{Binding ImageSource09}"
            Visibility="Collapsed" />
        <Image
            x:Name="operate010"
            Width="29"
            Height="16"
            Margin="0,12,20,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Source="{Binding ImageSource010}"
            Visibility="Collapsed" />
        <Image
            x:Name="operate8004"
            Width="29"
            Height="16"
            Margin="0,12,20,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Source="{Binding ImageSource8004}"
            Visibility="Collapsed" />
        <Grid.Effect>
            <DropShadowEffect
                BlurRadius="20"
                Direction="315"
                ShadowDepth="5"
                Color="#5087CBF7" />
        </Grid.Effect>
        <!--  设置按钮内容的偏移效果  -->
        <Grid.RenderTransform>
            <TranslateTransform x:Name="ContentTransform" X="0" Y="0" />
        </Grid.RenderTransform>
        <!--  响应事件  -->
        <Grid.Triggers>
            <!--  按下时内容向阴影方向偏移  -->
            <EventTrigger RoutedEvent="Border.TouchDown">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation
                            Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                            To="2"
                            Duration="0:0:0.1" />
                        <DoubleAnimation
                            Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                            To="2"
                            Duration="0:0:0.1" />
                        <!--  发光减弱  -->
                        <DoubleAnimation
                            Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                            To="0.16"
                            Duration="0:0:0.1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <!--  松开时恢复原位  -->
            <EventTrigger RoutedEvent="Border.TouchUp">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation
                            Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                            To="0"
                            Duration="0:0:0.1" />
                        <DoubleAnimation
                            Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                            To="0"
                            Duration="0:0:0.1" />
                        <!--  发光恢复  -->
                        <DoubleAnimation
                            Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                            To="0.8"
                            Duration="0:0:0.1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <!--  松开时恢复原位  -->
            <EventTrigger RoutedEvent="Border.TouchLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation
                            Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                            To="0"
                            Duration="0:0:0.1" />
                        <DoubleAnimation
                            Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                            To="0"
                            Duration="0:0:0.1" />
                        <!--  发光恢复  -->
                        <DoubleAnimation
                            Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                            To="0.8"
                            Duration="0:0:0.1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="Border.MouseDown">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation
                            Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                            To="2"
                            Duration="0:0:0.1" />
                        <DoubleAnimation
                            Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                            To="2"
                            Duration="0:0:0.1" />
                        <DoubleAnimation
                            Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                            To="0.16"
                            Duration="0:0:0.1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="Border.PreviewMouseDown">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation
                            Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                            To="2"
                            Duration="0:0:0.1" />
                        <DoubleAnimation
                            Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                            To="2"
                            Duration="0:0:0.1" />
                        <DoubleAnimation
                            Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                            To="0.16"
                            Duration="0:0:0.1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="Border.MouseUp">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation
                            Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                            To="0"
                            Duration="0:0:0.1" />
                        <DoubleAnimation
                            Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                            To="0"
                            Duration="0:0:0.1" />
                        <DoubleAnimation
                            Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                            To="0.8"
                            Duration="0:0:0.1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="Border.MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation
                            Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                            To="0"
                            Duration="0:0:0.1" />
                        <DoubleAnimation
                            Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                            To="0"
                            Duration="0:0:0.1" />
                        <DoubleAnimation
                            Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                            To="0.8"
                            Duration="0:0:0.1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>
    </Grid>
</UserControl>
