<UserControl x:Class="精密切割系统.View.Controls.OperateButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:精密切割系统.View.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="268">
    <Grid Width="268" Height="100">
        <Border x:Name="operateBorder" CornerRadius="10"  Background="#5087cb">
                <StackPanel x:Name="operateBtn" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Image x:Name="operateIcon"
Width="25" Height="25" RenderTransformOrigin="0.964,1.2" Source="/Assets/icon/tab_0/tab_01.png" Margin="0,0,5,0"/>
                    <Label FontSize="22"  Foreground="White" FontWeight="Bold"  MaxWidth="228">
                        <TextBlock x:Name="operateText" TextWrapping="Wrap" Text="按钮" />
                    </Label>
                </StackPanel>
            </Border>
        <Image x:Name="operate03" Visibility="Collapsed"  Source="{Binding ImageSource03}"  Width="29" Height="16"   HorizontalAlignment="Right" VerticalAlignment="Top"
       Margin="0,12,20,0" />
        <Image x:Name="operate04" Visibility="Collapsed" Source="{Binding ImageSource04}"  Width="29" Height="16"   HorizontalAlignment="Right" VerticalAlignment="Top"
Margin="0,12,20,0" />
        <Image x:Name="operate05" Visibility="Collapsed" Source="{Binding ImageSource05}"  Width="29" Height="16"   HorizontalAlignment="Right" VerticalAlignment="Top"
Margin="0,12,20,0" />
        <Image x:Name="operate06" Visibility="Collapsed" Source="{Binding ImageSource06}"  Width="29" Height="16"   HorizontalAlignment="Right" VerticalAlignment="Top"
Margin="0,12,20,0" />
        <Image x:Name="operate07" Visibility="Collapsed" Source="{Binding ImageSource07}"  Width="29" Height="16"   HorizontalAlignment="Right" VerticalAlignment="Top"
Margin="0,12,20,0" />
        <Image x:Name="operate08" Visibility="Collapsed" Source="{Binding ImageSource08}"  Width="29" Height="16"   HorizontalAlignment="Right" VerticalAlignment="Top"
Margin="0,12,20,0" />
        <Image x:Name="operate09" Visibility="Collapsed" Source="{Binding ImageSource09}"  Width="29" Height="16"   HorizontalAlignment="Right" VerticalAlignment="Top"
Margin="0,12,20,0" />
        <Image x:Name="operate010" Visibility="Collapsed" Source="{Binding ImageSource010}"  Width="29" Height="16"   HorizontalAlignment="Right" VerticalAlignment="Top"
Margin="0,12,20,0" />
        <Image x:Name="operate8004" Visibility="Collapsed" Source="{Binding ImageSource8004}"  Width="29" Height="16"   HorizontalAlignment="Right" VerticalAlignment="Top"
Margin="0,12,20,0" />
        <Grid.Effect>
            <DropShadowEffect 
        ShadowDepth="5" 
        BlurRadius="20" 
        Color="#5087CBF7" 
        Direction="315" />
        </Grid.Effect>
        <!-- 设置按钮内容的偏移效果 -->
        <Grid.RenderTransform>
            <TranslateTransform x:Name="ContentTransform" X="0" Y="0" />
        </Grid.RenderTransform>
        <!-- 响应事件 -->
        <Grid.Triggers>
            <!-- 按下时内容向阴影方向偏移 -->
            <EventTrigger RoutedEvent="Border.TouchDown">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                     To="2" Duration="0:0:0.1" />
                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                     To="2" Duration="0:0:0.1" />
                        <!-- 发光减弱 -->
                        <DoubleAnimation Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                     To="0.16" Duration="0:0:0.1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <!-- 松开时恢复原位 -->
            <EventTrigger RoutedEvent="Border.TouchUp">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                     To="0" Duration="0:0:0.1" />
                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                     To="0" Duration="0:0:0.1" />
                        <!-- 发光恢复 -->
                        <DoubleAnimation Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                     To="0.8" Duration="0:0:0.1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <!-- 松开时恢复原位 -->
            <EventTrigger RoutedEvent="Border.TouchLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                     To="0" Duration="0:0:0.1" />
                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                     To="0" Duration="0:0:0.1" />
                        <!-- 发光恢复 -->
                        <DoubleAnimation Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                     To="0.8" Duration="0:0:0.1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>
    </Grid>
</UserControl>
