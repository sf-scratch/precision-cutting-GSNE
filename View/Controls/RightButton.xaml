<UserControl
    x:Class="精密切割系统.View.Controls.RightButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:精密切割系统.View.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="72"
    d:DesignWidth="226"
    Loaded="UserControl_Loaded"
    mc:Ignorable="d">
    <Grid Width="226" Height="72">
        <Border x:Name="btnBorder" CornerRadius="10">
            <Button
                Grid.Column="2"
                Padding="0,0,0,3"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="Transparent"
                BorderThickness="0,0,0,0"
                IsHitTestVisible="False"
                IsTabStop="False">
                <Viewbox>
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Image
                            Width="10"
                            Height="10"
                            Margin="0,0,2,0"
                            RenderTransformOrigin="0.964,1.2"
                            Source="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=ImagePath}" />
                        <Label
                            Content="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=ContentText}"
                            FontSize="10"
                            FontWeight="Bold"
                            Foreground="White" />
                    </StackPanel>
                </Viewbox>
            </Button>
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="20"
                    Direction="315"
                    ShadowDepth="5"
                    Color="#4DC9EBF7" />
            </Border.Effect>
            <!--  设置按钮内容的偏移效果  -->
            <Border.RenderTransform>
                <TranslateTransform x:Name="ContentTransform" X="0" Y="0" />
            </Border.RenderTransform>
            <!--  响应事件  -->
            <Border.Triggers>
                <!--  按下时内容向阴影方向偏移  -->
                <EventTrigger RoutedEvent="Border.TouchDown">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                                To="2"
                                Duration="0:0:0.1" />
                            <DoubleAnimation
                                Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                                To="2"
                                Duration="0:0:0.1" />
                            <!--  发光减弱  -->
                            <DoubleAnimation
                                Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                                To="0.16"
                                Duration="0:0:0.1" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <!--  松开时恢复原位  -->
                <EventTrigger RoutedEvent="Border.TouchUp">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                                To="0"
                                Duration="0:0:0.1" />
                            <DoubleAnimation
                                Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                                To="0"
                                Duration="0:0:0.1" />
                            <!--  发光恢复  -->
                            <DoubleAnimation
                                Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                                To="0.5"
                                Duration="0:0:0.1" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <!--  松开时恢复原位  -->
                <EventTrigger RoutedEvent="Border.TouchLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                                To="0"
                                Duration="0:0:0.1" />
                            <DoubleAnimation
                                Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                                To="0"
                                Duration="0:0:0.1" />
                            <!--  发光恢复  -->
                            <DoubleAnimation
                                Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                                To="0.5"
                                Duration="0:0:0.1" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>
        </Border>
    </Grid>
</UserControl>
