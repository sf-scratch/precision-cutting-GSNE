<Page x:Class="精密切割系统.View.Pages.F3_ModelCatalog.MCRenameDeviceDirectoryConf"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:精密切割系统.View.Pages.F3_ModelCatalog" xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="676" d:DesignWidth="1448"
      Title="MCRenameDeviceDirectoryConf" Loaded="Page_Loaded">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Label Grid.Row="0" Content="名称变更" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="30" FontWeight="Bold" Padding="0,0,0,0" Margin="0,0,0,30"/>
        <StackPanel  Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Row="0" Grid.Column="0" Content="被变更型号参数号" FontSize="16" Margin="0,0,10,10"   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                <Controls:InputTextBox Grid.Row="0" Grid.Column="1" x:Name="inputTextShow" Margin="0,0,0,10"  Width="300" Height="35" VerticalAlignment="Center"  IsEnabled="False"/>
                <Label Grid.Row="1" Grid.Column="0" Content="变更型号参数号" Margin="0,0,10,0" FontSize="16"    VerticalAlignment="Center" HorizontalAlignment="Right" />
                <Controls:InputTextBox Grid.Row="1" Grid.Column="1" x:Name="inputText"  Width="300" Height="35" VerticalAlignment="Center" MaxLength="8" />
            </Grid>
        </StackPanel>
       
    </Grid>
</Page>
