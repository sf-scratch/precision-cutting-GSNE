<Page
    x:Class="精密切割系统.View.Pages.F3_ModelCatalog.MCAppointDeviceDirectoryConf"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:精密切割系统.View.Pages.F3_ModelCatalog"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MCAppointDeviceDirectoryConf"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Loaded="Page_Loaded"
    mc:Ignorable="d">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Label
            Grid.Row="0"
            Margin="0,0,0,30"
            Padding="0,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="指定参数"
            FontSize="30"
            FontWeight="Bold" />
        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <!---<Label Content="型号参数号：" FontSize="16" Width="300" Margin="0,0,0,15"/>-->
            <Controls:InputTextBox
                x:Name="inputText"
                Width="300"
                Height="35"
                VerticalAlignment="Center"
                IsEnabled="False" />
        </StackPanel>
    </Grid>
</Page>
