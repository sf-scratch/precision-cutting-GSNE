<Page
    x:Class="精密切割系统.View.F3_ModelCatalog.MCDeviceDataListConf"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:精密切割系统.View.F3_ModelCatalog"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MCDeviceDataListConf"
    d:DesignHeight="676"
    d:DesignWidth="1448"
    Loaded="Page_Loaded"
    mc:Ignorable="d">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Label
            Grid.Row="0"
            Margin="0,0,0,20"
            Padding="0,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="型号参数目录（2.0）"
            FontSize="30"
            FontWeight="Bold" />
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="70" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Controls:InputTextBox
                x:Name="DirectoryName"
                Grid.Row="0"
                Width="250"
                Height="35"
                IsEnabled="False" />


            <TreeView
                x:Name="rootTreeView"
                Grid.Row="1"
                Background="White"
                BorderThickness="0"
                ItemsSource="{Binding FileTableModel}"
                SelectedItemChanged="rootTreeView_SelectedItemChanged">

                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="True" />
                        <Setter Property="Padding" Value="0" />
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <Label
                            Width="200"
                            Height="45"
                            VerticalContentAlignment="Center"
                            Content="{Binding Name}"
                            FontSize="18">
                            <Label.Style>
                                <Style TargetType="Label">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="Foreground" Value="White" />
                                            <Setter Property="Background" Value="#5087CB" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="False">
                                            <Setter Property="Foreground" Value="Black" />
                                            <Setter Property="Background" Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Label.Style>
                        </Label>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
            <ListView
                x:Name="preListView"
                Grid.Row="1"
                Grid.Column="1"
                Margin="15,0,0,0"
                BorderThickness="0"
                ItemsSource="{Binding ColList}"
                SelectionChanged="preListView_SelectionChanged">
                <ListView.ItemContainerStyle>
                    <Style TargetType="{x:Type ListViewItem}">
                        <Setter Property="Height" Value="50" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" Value="Transparent" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="true">
                                <Setter Property="Background" Value="#CBE5ED" />
                            </Trigger>
                        </Style.Triggers>

                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.View>
                    <GridView>
                        <GridView.ColumnHeaderContainerStyle>
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </Style>
                        </GridView.ColumnHeaderContainerStyle>
                        <!--  添加你的 GridViewColumn 定义在这里  -->
                        <GridViewColumn>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Height="50" Orientation="Horizontal">
                                        <Label
                                            Width="120"
                                            VerticalAlignment="Center"
                                            Content="{Binding DeviceDataNo}"
                                            FontSize="18" />
                                        <Label
                                            Width="500"
                                            Margin="15,0,0,0"
                                            VerticalAlignment="Center"
                                            Content="{Binding DeviceDataId}"
                                            FontSize="18" />
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="70" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Controls:InputTextBox
                    x:Name="inputSerialNumber"
                    Grid.Row="0"
                    Grid.Column="0"
                    Width="250"
                    Height="35"
                    Margin="15,0,0,0"
                    HorizontalAlignment="Left" />
                <StackPanel
                    Grid.Row="0"
                    Grid.Column="1"
                    Orientation="Horizontal">
                    <Label
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        Content="参数总数"
                        FontSize="18" />
                    <Controls:InputTextBox
                        x:Name="labSumTotal"
                        Width="250"
                        Height="35"
                        IsEnabled="False" />
                </StackPanel>
                <StackPanel
                    Grid.Row="0"
                    Grid.Column="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <Label
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        Content="参数"
                        FontSize="18" />
                    <Controls:InputTextBox
                        x:Name="labDataSum"
                        Width="250"
                        Height="35"
                        IsEnabled="False" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
