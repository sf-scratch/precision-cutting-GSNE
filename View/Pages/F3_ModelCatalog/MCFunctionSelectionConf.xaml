<Page
    x:Class="精密切割系统.View.Pages.F3_ModelCatalog.MCFunctionSelectionConf"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:精密切割系统.View.Pages.F3_ModelCatalog"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MCFunctionSelectionConf"
    d:DesignHeight="676"
    d:DesignWidth="1448"
    mc:Ignorable="d">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Label
            Grid.Row="0"
            Margin="0,0,0,30"
            Padding="0,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="功能选择"
            FontSize="30"
            FontWeight="Bold"
            Loaded="Label_Loaded" />
        <StackPanel Grid.Row="1" Margin="10,0,10,10">
            <CheckBox
                x:Name="dpsdCheckbox"
                Content="是否显示刀片深度"
                FontSize="16">
                <CheckBox.LayoutTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1.2" ScaleY="1.2" />
                        <SkewTransform />
                        <RotateTransform />
                        <TranslateTransform />
                    </TransformGroup>
                </CheckBox.LayoutTransform>
            </CheckBox>
            <CheckBox
                x:Name="loopCheckbox"
                Margin="0,20,0,0"
                Content="是否显示循环功能"
                FontSize="16">
                <CheckBox.LayoutTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1.2" ScaleY="1.2" />
                        <SkewTransform />
                        <RotateTransform />
                        <TranslateTransform />
                    </TransformGroup>
                </CheckBox.LayoutTransform>
            </CheckBox>
        </StackPanel>
    </Grid>
</Page>
