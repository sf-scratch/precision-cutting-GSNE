<Page x:Class="精密切割系统.View.Pages.F3_ModelCatalog.MCMoveDeviceDirectoryConf"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:精密切割系统.View.Pages.F3_ModelCatalog" xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="676" d:DesignWidth="1448"
      Title="MCMoveDeviceDirectoryConf" Loaded="Page_Loaded">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Label Grid.Row="0" Content="移动配置" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="30" FontWeight="Bold" Padding="0,0,0,0" Margin="0,0,0,30"/>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Row="0" Grid.Column="1" Margin="0,0,0,15" Content="目录名" FontSize="16" Width="150"  Padding="0,0,0,0" VerticalAlignment="Center" HorizontalContentAlignment="Center" />
                <Label Grid.Row="0" Grid.Column="2" Margin="0,0,0,15" Content="型号参数序号" FontSize="16" Width="150"  Padding="0,0,0,0" VerticalAlignment="Center" HorizontalContentAlignment="Center" />
                <Label Grid.Row="1" Content="被移动型号参数号" FontSize="16" Margin="0,0,10,15"   Width="150"  VerticalAlignment="Center" HorizontalContentAlignment="Right" />
                <Controls:InputTextBox x:Name="labRootFile"  Width="300" Grid.Row="1" Grid.Column="1" Margin="0,0,15,15"   IsEnabled="False" />
                <Controls:InputTextBox x:Name="labDeviceDataNo"  Width="300" Height="35" Grid.Row="1" Grid.Column="2" Margin="0,0,0,15" IsEnabled="False"/>
                <Label Grid.Row="2" Content="移动到" FontSize="16" Width="150"  Margin="0,0,10,0"   VerticalAlignment="Center" HorizontalContentAlignment="Right" />

                <ComboBox x:Name="comboDirectory" Grid.Row="2" Grid.Column="1" Width="300" Height="35" VerticalContentAlignment="Center" FontSize="16" Margin="0,0,15,0">
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Height" Value="50"/>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>
            </Grid>
