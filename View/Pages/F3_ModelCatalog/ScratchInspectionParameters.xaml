<UserControl
    x:Class="精密切割系统.View.Pages.F3_ModelCatalog.ScratchInspectionParameters"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
    xmlns:auto="clr-namespace:WpfAutoGrid;assembly=WpfAutoGrid.Core"
    xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:common="clr-namespace:精密切割系统.View.Pages.common"
    xmlns:cvert="clr-namespace:精密切割系统.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:精密切割系统.Helpers"
    xmlns:local="clr-namespace:精密切割系统.View.Pages.F3_ModelCatalog"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:精密切割系统.ViewModel"
    d:DataContext="{d:DesignInstance viewModel:ScratchInspectionParametersViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="655"
    d:DesignWidth="1570"
    mc:Ignorable="d">
    <UserControl.Resources>
        <!--  布尔到可见性转换器  -->
        <cvert:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <cvert:BoolToVisibilityConverter x:Key="BoolToVisibilityInverseConverter" IsInverse="True" />
        <Style TargetType="Label">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style BasedOn="{StaticResource InputTextStyle}" TargetType="Controls:InputTextBox">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="InputType" Value="Decimal" />
            <Setter Property="XPrecision" Value="0" />
            <Setter Property="FontWeight" Value="Normal" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>

            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Label
            Grid.Row="0"
            Grid.Column="0"
            Height="auto"
            Margin="30,30,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="刀痕检查参数"
            FontSize="30"
            FontWeight="Bold" />
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Margin="30">
                <TextBlock Text="切割片检查频率（刀）" />
                <auto:AutoGrid
                    ChildMargin="5"
                    Columns="*,*,*,*,*"
                    RowCount="8">
                    <TextBlock />
                    <TextBlock HorizontalAlignment="Center" Text="Ch1" />
                    <TextBlock HorizontalAlignment="Center" Text="Ch2" />
                    <TextBlock HorizontalAlignment="Center" Text="Ch3" />
                    <TextBlock HorizontalAlignment="Center" Text="Ch4" />
                    <TextBlock HorizontalAlignment="Center" Text="首次检查" />
                    <Controls:InputTextBox Text="{Binding Entity.FirstCheckCh1}" />
                    <Controls:InputTextBox Text="{Binding Entity.FirstCheckCh2}" />
                    <Controls:InputTextBox Text="{Binding Entity.FirstCheckCh3}" />
                    <Controls:InputTextBox Text="{Binding Entity.FirstCheckCh4}" />
                    <TextBlock HorizontalAlignment="Center" Text="下次检查" />
                    <Controls:InputTextBox Text="{Binding Entity.NextCheckCh1}" />
                    <Controls:InputTextBox Text="{Binding Entity.NextCheckCh2}" />
                    <Controls:InputTextBox Text="{Binding Entity.NextCheckCh3}" />
                    <Controls:InputTextBox Text="{Binding Entity.NextCheckCh4}" />
                </auto:AutoGrid>
            </StackPanel>
            <!--<StackPanel Grid.Column="1" Margin="30">
                <TextBlock Text="容许值" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <auto:AutoGrid
                        ChildMargin="5"
                        Columns="*,*,auto"
                        RowCount="8">
                        <TextBlock Text="刀痕宽度（上限）" />
                        <Controls:InputTextBox Text="{Binding Path=ScratchInspectionFirstCh1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="mm" />
                        <TextBlock Text="刀痕宽度（下限）" />
                        <Controls:InputTextBox Text="{Binding Path=ScratchInspectionFirstCh1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="mm" />
                        <TextBlock Text="崩边" />
                        <Controls:InputTextBox Text="{Binding Path=ScratchInspectionFirstCh1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="mm" />
                        <TextBlock Text="崩边尺寸" />
                        <Controls:InputTextBox Text="{Binding Path=ScratchInspectionFirstCh1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="mm" />
                    </auto:AutoGrid>
                </Grid>
            </StackPanel>-->
        </Grid>
    </Grid>
</UserControl>