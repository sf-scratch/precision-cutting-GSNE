<Page xmlns:Controls="clr-namespace:精密切割系统.View.Controls"  x:Class="精密切割系统.View.Pages.F3_ModelCatalog.MCAddDeviceDirectoryConf"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:精密切割系统.View.Pages.F3_ModelCatalog"
      mc:Ignorable="d" 
      d:DesignHeight="676" d:DesignWidth="1448"
      Title="MCAddDeviceDirectoryConf" Loaded="Page_Loaded">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Label Grid.Row="0" Content="创建目录" HorizontalAlignment="Left" VerticalAlignment="Bottom" FontSize="30" FontWeight="Bold" Padding="0,0,0,0" Margin="0,0,0,30"/>
        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <Label Content="目录名称" FontSize="16" Width="300" Margin="0,0,0,15"/>
            <Controls:InputTextBox x:Name="inputText" Width="300" Height="35" VerticalAlignment="Center" XMax="8" XMin="0" MaxLength="8"  />
        </StackPanel>
    </Grid>
</Page>
