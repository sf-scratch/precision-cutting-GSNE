<UserControl
    x:Class="精密切割系统.View.Pages.F3_ModelCatalog.AutomaticCompensationCutHeight"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
    xmlns:auto="clr-namespace:WpfAutoGrid;assembly=WpfAutoGrid.Core"
    xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:common="clr-namespace:精密切割系统.View.Pages.common"
    xmlns:cvert="clr-namespace:精密切割系统.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:精密切割系统.Helpers"
    xmlns:local="clr-namespace:精密切割系统.View.Pages.F3_ModelCatalog"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:精密切割系统.ViewModel"
    Height="655"
    Width="1570">
    <UserControl.Resources>
        <cvert:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <cvert:BoolToVisibilityConverter x:Key="BoolToVisibilityInverseConverter" IsInverse="True" />
        <Style TargetType="Label">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style BasedOn="{StaticResource InputTextStyle}" TargetType="Controls:InputTextBox">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="InputType" Value="Decimal" />
            <Setter Property="XPrecision" Value="3" />
            <Setter Property="FontWeight" Value="Normal" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>

            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Label
            Grid.Row="0"
            Grid.Column="0"
            Height="auto"
            Margin="30,30,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="切割高度自动补偿"
            FontSize="30"
            FontWeight="Bold" />
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Margin="30">
                <auto:AutoGrid
                    ChildMargin="5"
                    Columns="2*,2*,*"
                    RowCount="8">
                    <TextBlock Text="高度补偿频率" />
                    <Controls:InputTextBox XPrecision="0" Text="{Binding Entity.CutHeightCompensationFrequency}" />
                    <TextBlock Grid.ColumnSpan="4" Text="/刀" />
                    <TextBlock Text="刀片高度降低距离" />
                    <Controls:InputTextBox Text="{Binding Entity.CutHeightReductionDistance}" />
                    <TextBlock Grid.ColumnSpan="4" Text="mm" />
                </auto:AutoGrid>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>