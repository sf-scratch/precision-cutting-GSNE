<Page x:Class="精密切割系统.View.Pages.F3_ModelCatalog.MCCalibrationParameters"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:精密切割系统.View.Pages.F3_ModelCatalog"
      xmlns:viewModel="clr-namespace:精密切割系统.ViewModel"
      xmlns:Controls="clr-namespace:精密切割系统.View.Controls" 
      xmlns:auto="clr-namespace:WpfAutoGrid;assembly=WpfAutoGrid.Core"
      mc:Ignorable="d" 
      d:DesignHeight="676"
      d:DesignWidth="1448"
      d:DataContext="{d:DesignInstance viewModel:MCCalibrationParametersViewModel}"
      Loaded="Page_Loaded">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <Label
            Grid.Row="0"
            Margin="0,0,0,30"
            Padding="0,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="校准参数"
            FontSize="30"
            FontWeight="Bold" />
        <Label
            Grid.Row="1"
            Margin="10,0,0,15"
            Padding="0,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="基准线宽度"
            FontSize="20"
            FontWeight="Bold" />
        <auto:AutoGrid Grid.Row="2" Margin="10,0,10,10"  Columns="2*,2*,*,2*,2*,*,2*,2*,*,2*,2*,*" RowCount="7">
            <Label Content="CH1" FontSize="16" FontWeight="Bold" HorizontalAlignment="Right"/>
            <Controls:InputTextBox Text="{Binding Path=BaselineWidthCh1,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" InputType="Decimal" />
            <Label Content="um" FontSize="16" FontWeight="Bold"/>
            <Label Content="CH2" FontSize="16" FontWeight="Bold" HorizontalAlignment="Right"/>
            <Controls:InputTextBox Text="{Binding Path=BaselineWidthCh2,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" InputType="Decimal" />
            <Label Content="um" FontSize="16" FontWeight="Bold"/>
            <Label Content="CH3" FontSize="16" FontWeight="Bold" HorizontalAlignment="Right"/>
            <Controls:InputTextBox Text="{Binding Path=BaselineWidthCh3,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" InputType="Decimal" />
            <Label Content="um" FontSize="16" FontWeight="Bold"/>
            <Label Content="CH4" FontSize="16" FontWeight="Bold" HorizontalAlignment="Right"/>
            <Controls:InputTextBox Text="{Binding Path=BaselineWidthCh4,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" InputType="Decimal" />
            <Label Content="um" FontSize="16" FontWeight="Bold"/>
        </auto:AutoGrid>
        <Label
            Grid.Row="3"
            Margin="10,0,0,15"
            Padding="0,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="光源亮度"
            FontSize="20"
            FontWeight="Bold" />
        <auto:AutoGrid Grid.Row="4" Margin="10,0,10,10"  Columns="2*,2*,*,2*,2*,*,2*,2*,*,2*,2*,*" RowCount="7">
            <Label Content="CH1" FontSize="16" FontWeight="Bold" HorizontalAlignment="Right"/>
            <Controls:InputTextBox Text="{Binding Path=LightSourceBrightnessCh1,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" InputType="Decimal" />
            <Label Content="(1-100)" FontSize="16" FontWeight="Bold"/>
            <Label Content="CH2" FontSize="16" FontWeight="Bold" HorizontalAlignment="Right"/>
            <Controls:InputTextBox Text="{Binding Path=LightSourceBrightnessCh2,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" InputType="Decimal" />
            <Label Content="(1-100)" FontSize="16" FontWeight="Bold"/>
            <Label Content="CH3" FontSize="16" FontWeight="Bold" HorizontalAlignment="Right"/>
            <Controls:InputTextBox Text="{Binding Path=LightSourceBrightnessCh3,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" InputType="Decimal" />
            <Label Content="(1-100)" FontSize="16" FontWeight="Bold"/>
            <Label Content="CH4" FontSize="16" FontWeight="Bold" HorizontalAlignment="Right"/>
            <Controls:InputTextBox Text="{Binding Path=LightSourceBrightnessCh4,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" InputType="Decimal" />
            <Label Content="(1-100)" FontSize="16" FontWeight="Bold"/>
        </auto:AutoGrid>
    </Grid>
</Page>
