<UserControl
    x:Class="精密切割系统.View.Pages.common.SimpleDirectOperate"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behav="clr-namespace:精密切割系统.Behaviors"
    xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:convert="clr-namespace:精密切割系统.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:精密切割系统.Helpers"
    xmlns:local="clr-namespace:精密切割系统.View.Pages.common"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:精密切割系统.ViewModel"
    d:DesignHeight="250"
    d:DesignWidth="750"
    mc:Ignorable="d">
    <UserControl.Resources>
        <convert:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <Style
            x:Key="ArrowButton"
            BasedOn="{StaticResource MaterialDesignFloatingActionLightButton}"
            TargetType="Button">
            <Setter Property="Height" Value="82" />
            <Setter Property="Width" Value="82" />
            <Setter Property="Background" Value="#5087Cb" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#5087Cb" />
        </Style>
        <Style BasedOn="{StaticResource MaterialDesignFlatLightBgButton}" TargetType="Button">
            <Setter Property="Height" Value="50" />
            <Setter Property="Width" Value="100" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Background" Value="#5087Cb" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#5087Cb" />
        </Style>
    </UserControl.Resources>
    <UserControl.DataContext>
        <viewModel:DirectOperateViewModel />
    </UserControl.DataContext>
    <Grid>
        <Border
            Grid.Column="1"
            Margin="0"
            CornerRadius="10"
            Visibility="{Binding IsShowKeyboard, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="6*" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <!--<Grid Grid.Row="0">
                        <Grid Width="100" Height="100">
                            <StackPanel Orientation="Vertical">
                                <Border
                                    Width="70"
                                    Height="70"
                                    CornerRadius="33,33,33,33">
                                    <Image
                                        Width="52"
                                        Height="52"
                                        Source="/Assets/picture/SCAN_icon.png" />
                                </Border>
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="18"
                                    FontWeight="Bold"
                                    Text="Scan" />
                            </StackPanel>
                        </Grid>
                    </Grid>-->
                    <Grid Grid.Row="1">
                        <StackPanel VerticalAlignment="Center" Orientation="Vertical">
                            <ToggleButton
                                Width="65"
                                Height="65"
                                Background="#5087Cb"
                                Content="{materialDesign:PackIcon Kind=Speedometer,
                                                                  Size=50}"
                                Foreground="Black"
                                IsChecked="{Binding IsHighSpeed}"
                                Style="{StaticResource MaterialDesignFlatPrimaryToggleButton}" />
                            <TextBlock
                                Margin="0,10,0,0"
                                HorizontalAlignment="Center"
                                FontSize="20"
                                FontWeight="Bold"
                                Text="高速" />
                        </StackPanel>
                    </Grid>
                </Grid>
                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20*" />
                        <ColumnDefinition Width="60*" />
                        <ColumnDefinition Width="20*" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1.5*" />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Button
                            x:Name="scanLeftBottomBtn"
                            VerticalAlignment="Center"
                            Content="{materialDesign:PackIcon ArrowDownLeftBold,
                                                              Size=50}"
                            Style="{StaticResource ArrowButton}"
                            Visibility="{Binding Source={x:Static helpers:GlobalParams.HasTheta}, Converter={StaticResource BoolToVisibilityConverter}}">
                            <behaviors:Interaction.Behaviors>
                                <behav:DualInputBehavior
                                    PromptCommand="{Binding ThetaRelativeNegativeCommand}"
                                    StartCommand="{Binding StartThetaReversalCommand}"
                                    StopCommand="{Binding StopJogThetaCommand}" />
                            </behaviors:Interaction.Behaviors>
                        </Button>
                        <Button Grid.Row="1" Content="Z1抬起">
                            <behaviors:Interaction.Behaviors>
                                <behav:DualInputBehavior
                                    PromptCommand="{Binding Z1RelativeNegativeCommand}"
                                    StartCommand="{Binding StartRaiseZ1Command}"
                                    StopCommand="{Binding StopJogZ1Command}" />
                            </behaviors:Interaction.Behaviors>
                        </Button>
                        <Button Grid.Row="2" Content="Z1下降">
                            <behaviors:Interaction.Behaviors>
                                <behav:DualInputBehavior
                                    PromptCommand="{Binding Z1RelativePositiveCommand}"
                                    StartCommand="{Binding StartDropZ1Command}"
                                    StopCommand="{Binding StopJogZ1Command}" />
                            </behaviors:Interaction.Behaviors>
                        </Button>
                    </Grid>
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid
                            Grid.Row="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <Button
                                x:Name="scanTopBtn"
                                VerticalAlignment="Top"
                                Content="{materialDesign:PackIcon ArrowTopThick,
                                                                  Size=50}"
                                Style="{StaticResource ArrowButton}">
                                <behaviors:Interaction.Behaviors>
                                    <behav:DualInputBehavior
                                        PromptCommand="{Binding YRelativeNegativeCommand}"
                                        StartCommand="{Binding StartYReversalCommand}"
                                        StopCommand="{Binding StopJogYCommand}" />
                                </behaviors:Interaction.Behaviors>
                            </Button>
                        </Grid>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Grid
                                Grid.Column="0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                                <Button
                                    x:Name="scanLeftBtn"
                                    VerticalAlignment="Top"
                                    Content="{materialDesign:PackIcon ArrowLeftThick,
                                                                      Size=50}"
                                    Style="{StaticResource ArrowButton}">
                                    <behaviors:Interaction.Behaviors>
                                        <behav:DualInputBehavior
                                            PromptCommand="{Binding XRelativePositiveCommand}"
                                            StartCommand="{Binding StartXCorotationCommand}"
                                            StopCommand="{Binding StopJogXCommand}" />
                                    </behaviors:Interaction.Behaviors>
                                </Button>
                            </Grid>
                            <Grid
                                Grid.Column="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                                <Button
                                    x:Name="scanRightBtn"
                                    VerticalAlignment="Center"
                                    Content="{materialDesign:PackIcon ArrowRightThick,
                                                                      Size=50}"
                                    Style="{StaticResource ArrowButton}">
                                    <behaviors:Interaction.Behaviors>
                                        <behav:DualInputBehavior
                                            PromptCommand="{Binding XRelativeNegativeCommand}"
                                            StartCommand="{Binding StartXReversalCommand}"
                                            StopCommand="{Binding StopJogXCommand}" />
                                    </behaviors:Interaction.Behaviors>
                                </Button>
                            </Grid>
                        </Grid>
                        <Grid
                            Grid.Row="2"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <Button
                                x:Name="scanBottomBtn"
                                VerticalAlignment="Top"
                                Content="{materialDesign:PackIcon ArrowBottomThick,
                                                                  Size=50}"
                                Style="{StaticResource ArrowButton}">
                                <behaviors:Interaction.Behaviors>
                                    <behav:DualInputBehavior
                                        PromptCommand="{Binding YRelativePositiveCommand}"
                                        StartCommand="{Binding StartYCorotationCommand}"
                                        StopCommand="{Binding StopJogYCommand}" />
                                </behaviors:Interaction.Behaviors>
                            </Button>
                        </Grid>
                    </Grid>
                    <Grid Grid.Column="2" Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1.5*" />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Button
                            x:Name="scanRightBottomBtn"
                            VerticalAlignment="Center"
                            Content="{materialDesign:PackIcon ArrowDownRightBold,
                                                              Size=50}"
                            Style="{StaticResource ArrowButton}"
                            Visibility="{Binding Source={x:Static helpers:GlobalParams.HasTheta}, Converter={StaticResource BoolToVisibilityConverter}}">
                            <behaviors:Interaction.Behaviors>
                                <behav:DualInputBehavior
                                    PromptCommand="{Binding ThetaRelativePositiveCommand}"
                                    StartCommand="{Binding StartThetaCorotationCommand}"
                                    StopCommand="{Binding StopJogThetaCommand}" />
                            </behaviors:Interaction.Behaviors>
                        </Button>
                        <Button Grid.Row="1" Content="Z2抬起">
                            <behaviors:Interaction.Behaviors>
                                <behav:DualInputBehavior
                                    PromptCommand="{Binding Z2RelativeNegativeCommand}"
                                    StartCommand="{Binding StartRaiseZ2Command}"
                                    StopCommand="{Binding StopJogZ2Command}" />
                            </behaviors:Interaction.Behaviors>
                        </Button>
                        <Button Grid.Row="2" Content="Z2下降">
                            <behaviors:Interaction.Behaviors>
                                <behav:DualInputBehavior
                                    PromptCommand="{Binding Z2RelativePositiveCommand}"
                                    StartCommand="{Binding StartDropZ2Command}"
                                    StopCommand="{Binding StopJogZ2Command}" />
                            </behaviors:Interaction.Behaviors>
                        </Button>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>