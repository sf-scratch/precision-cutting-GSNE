<UserControl
    x:Class="精密切割系统.View.Pages.common.SimpleDirectOperate"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behav="clr-namespace:精密切割系统.Behaviors"
    xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:convert="clr-namespace:精密切割系统.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:精密切割系统.Helpers"
    xmlns:local="clr-namespace:精密切割系统.View.Pages.common"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:精密切割系统.ViewModel"
    d:DesignHeight="250"
    d:DesignWidth="750"
    mc:Ignorable="d">
    <UserControl.Resources>
        <convert:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <convert:BoolToValueConverter
            x:Key="BoolToStringConverter"
            FalseValue="低速"
            TrueValue="高速" />
        <Style
            x:Key="ArrowButton"
            BasedOn="{StaticResource MaterialDesignFloatingActionLightButton}"
            TargetType="Button">
            <Setter Property="Height" Value="70" />
            <Setter Property="Width" Value="70" />
            <Setter Property="Background" Value="#5087Cb" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#5087Cb" />
        </Style>
        <!--<Style BasedOn="{StaticResource MaterialDesignFlatLightBgButton}" TargetType="Button">
            <Setter Property="Height" Value="50" />
            <Setter Property="Width" Value="100" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Background" Value="#5087Cb" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#5087Cb" />
        </Style>-->

        <Style TargetType="Button">
            <Setter Property="BorderBrush" Value="{x:Null}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1.0" ScaleY="1.0" />
                </Setter.Value>
            </Setter>

            <!--  按下效果触发器  -->
            <Style.Triggers>
                <!--  鼠标按下时效果  -->
                <Trigger Property="IsPressed" Value="True">

                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="0.95" ScaleY="0.95" />
                        </Setter.Value>
                    </Setter>
                    <Setter Property="BorderBrush" Value="DarkGray" />
                </Trigger>

                <!--  动态恢复效果：动画从按下状态回到正常状态  -->
                <Trigger Property="IsPressed" Value="False">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                    To="1.0"
                                    Duration="0:0:0.1" />
                                <DoubleAnimation
                                    Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                    To="1.0"
                                    Duration="0:0:0.1" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <!--  松开时移除边框  -->
                    <Setter Property="BorderBrush" Value="Transparent" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <UserControl.DataContext>
        <viewModel:DirectOperateViewModel />
    </UserControl.DataContext>
    <Grid>
        <Border
            Grid.Column="1"
            Margin="0"
            CornerRadius="10"
            Visibility="{Binding IsShowKeyboard, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <!--<Grid Grid.Row="0">
                        <Grid
                            Width="100"
                            Height="100"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <StackPanel Orientation="Vertical">
                                <Border
                                    Width="70"
                                    Height="70"
                                    CornerRadius="33,33,33,33">
                                    <Image
                                        Width="52"
                                        Height="52"
                                        Source="/Assets/picture/SCAN_icon.png" />
                                </Border>
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="18"
                                    FontWeight="Bold"
                                    Text="Scan" />
                            </StackPanel>
                        </Grid>
                    </Grid>-->
                    <Grid Grid.RowSpan="2" VerticalAlignment="Bottom">
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Orientation="Vertical">
                            <Button
                                Width="110"
                                Height="75"
                                materialDesign:ButtonAssist.CornerRadius="10"
                                Command="{Binding UpdateHighSpeedCommand}">
                                <Button.Style>
                                    <Style BasedOn="{StaticResource MaterialDesignRaisedButton}" TargetType="Button">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsHighSpeed}" Value="True">
                                                <Setter Property="Background" Value="#5087cb" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Button.Content>
                                    <materialDesign:PackIcon
                                        Width="50"
                                        Height="50"
                                        Foreground="Gray"
                                        Kind="Speedometer" />
                                </Button.Content>
                            </Button>
                            <TextBlock
                                Margin="0,10,0,0"
                                HorizontalAlignment="Center"
                                FontSize="18"
                                FontWeight="Bold"
                                Text="高速" />
                        </StackPanel>
                    </Grid>
                </Grid>
                <Grid Grid.Column="1">
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid
                            Grid.Row="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <Button x:Name="scanTopBtn" VerticalAlignment="Top">
                                <behaviors:Interaction.Behaviors>
                                    <behav:DualInputBehavior
                                        PromptCommand="{Binding YRelativeNegativeCommand}"
                                        StartCommand="{Binding StartYReversalCommand}"
                                        StopCommand="{Binding StopJogYCommand}" />
                                </behaviors:Interaction.Behaviors>
                                <Button.Content>
                                    <Image
                                        x:Name="scanTopIcon"
                                        Width="100"
                                        Height="60"
                                        Source="/Assets/picture/scan_top.png" />
                                </Button.Content>
                            </Button>
                        </Grid>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Grid
                                Grid.Column="0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                                <Button x:Name="scanLeftBtn" VerticalAlignment="Top">
                                    <behaviors:Interaction.Behaviors>
                                        <behav:DualInputBehavior
                                            PromptCommand="{Binding XRelativePositiveCommand}"
                                            StartCommand="{Binding StartXCorotationCommand}"
                                            StopCommand="{Binding StopJogXCommand}" />
                                    </behaviors:Interaction.Behaviors>
                                    <Button.Content>
                                        <Image
                                            x:Name="scanLeftIcon"
                                            Width="100"
                                            Height="60"
                                            Source="/Assets/picture/scan_left.png" />
                                    </Button.Content>
                                </Button>
                            </Grid>
                            <Grid
                                Grid.Column="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                                <Button x:Name="scanRightBtn" VerticalAlignment="Center">
                                    <behaviors:Interaction.Behaviors>
                                        <behav:DualInputBehavior
                                            PromptCommand="{Binding XRelativeNegativeCommand}"
                                            StartCommand="{Binding StartXReversalCommand}"
                                            StopCommand="{Binding StopJogXCommand}" />
                                    </behaviors:Interaction.Behaviors>
                                    <Button.Content>
                                        <Image
                                            x:Name="scanRightIcon"
                                            Width="100"
                                            Height="60"
                                            Source="/Assets/picture/scan_right.png" />
                                    </Button.Content>
                                </Button>
                            </Grid>
                        </Grid>
                        <Grid
                            Grid.Row="2"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <Button x:Name="scanBottomBtn" VerticalAlignment="Top">
                                <behaviors:Interaction.Behaviors>
                                    <behav:DualInputBehavior
                                        PromptCommand="{Binding YRelativePositiveCommand}"
                                        StartCommand="{Binding StartYCorotationCommand}"
                                        StopCommand="{Binding StopJogYCommand}" />
                                </behaviors:Interaction.Behaviors>
                                <Button.Content>
                                    <Image
                                        x:Name="scanBottomIcon"
                                        Width="100"
                                        Height="60"
                                        Source="/Assets/picture/scan_bottom.png" />
                                </Button.Content>
                            </Button>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>