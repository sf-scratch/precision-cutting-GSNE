<UserControl x:Class="精密切割系统.View.Pages.common.CommonDimming"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:精密切割系统.View.Pages.common" xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="130" d:DesignWidth="700" Loaded="UserControl_Loaded">
    <StackPanel>
        <StackPanel Orientation="Horizontal">
            <Label Content="手动调光" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <Label Content="直射" VerticalAlignment="Center" FontWeight="Bold"/>
            <Controls:InputTextBox x:Name="dirLightRatio" IsEnabled="False" Width="100" Text="100" FontWeight="Bold" Padding="8,0,0,0"></Controls:InputTextBox>
            <Label Content="%" VerticalAlignment="Center"></Label>
            <StackPanel Orientation="Horizontal" Margin="20 0 0 0">
                <Button x:Name="subFive" Content="-5%" Width="100" Height="40" Margin="10 0 0 0" Click="SubFive_OnClick" FontSize="18" FontWeight="Bold"></Button>
                <Button x:Name="subOne" Content="-1%" Width="100" Margin="10 0 0 0" Click="SubOne_OnClick" FontSize="18" FontWeight="Bold"></Button>
                <Button x:Name="addOne" Content="+1%" Width="100" Margin="10 0 0 0" Click="AddOne_OnClick" FontSize="18" FontWeight="Bold"></Button>
                <Button x:Name="addFive" Content="+5%" Width="100" Margin="10 0 0 0" Click="AddFive_OnClick" FontSize="18" FontWeight="Bold"></Button>
            </StackPanel>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0,5,0,0" x:Name="ringPanel">
            <Label Content="环光" VerticalAlignment="Center" FontWeight="Bold"/>
            <Controls:InputTextBox x:Name="ringLightRatio" IsEnabled="False" Width="100" Text="100" FontWeight="Bold" Padding="8,0,0,0"></Controls:InputTextBox>
            <Label Content="%" VerticalAlignment="Center"></Label>
            <StackPanel Orientation="Horizontal" Margin="20 0 0 0">
                <Button x:Name="ringSubFive" Content="-5%" Width="100" Height="40" Margin="10 0 0 0" Click="ringSubFive_Click"  FontSize="18" FontWeight="Bold"></Button>
                <Button x:Name="ringSubOne" Content="-1%" Width="100" Margin="10 0 0 0" Click="ringSubOne_Click"  FontSize="18" FontWeight="Bold"></Button>
                <Button x:Name="ringAddOne" Content="+1%" Width="100" Margin="10 0 0 0" Click="ringAddOne_Click"  FontSize="18" FontWeight="Bold"></Button>
                <Button x:Name="ringAddFive" Content="+5%" Width="100" Margin="10 0 0 0" Click="ringAddFive_Click"  FontSize="18" FontWeight="Bold"></Button>
            </StackPanel>
        </StackPanel>
    </StackPanel>
</UserControl>
