<UserControl
    x:Class="精密切割系统.View.Pages.common.CommonDimming"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:精密切割系统.View.Pages.common"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="160"
    d:DesignWidth="700"
    Loaded="UserControl_Loaded"
    Unloaded="UserControl_Unloaded"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style BasedOn="{StaticResource MaterialDesignFlatLightBgButton}" TargetType="Button">
            <Setter Property="Background" Value="#5087Cb" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="BorderBrush" Value="#5087Cb" />
        </Style>
    </UserControl.Resources>
    <StackPanel>
        <Label
            Margin="0,0,0,5"
            Content="手动调光"
            FontSize="18"
            FontWeight="Bold" />
        <StackPanel Orientation="Horizontal">
            <Label
                VerticalAlignment="Center"
                Content="直射亮度"
                FontSize="16"
                FontWeight="Bold" />
            <Controls:InputTextBox
                x:Name="dirLightRatio"
                Width="100"
                Padding="8,0,0,0"
                FontWeight="Bold"
                IsEnabled="False"
                Text="100" />
            <Label VerticalAlignment="Center" Content="%" />
            <StackPanel Margin="20,0,0,0" Orientation="Horizontal">
                <Button
                    x:Name="subFive"
                    Width="100"
                    Margin="10,0,0,0"
                    Click="SubFive_OnClick"
                    Content="-5%"
                    FontSize="18"
                    FontWeight="Bold" />
                <Button
                    x:Name="subOne"
                    Width="100"
                    Margin="10,0,0,0"
                    Click="SubOne_OnClick"
                    Content="-1%"
                    FontSize="18"
                    FontWeight="Bold" />
                <Button
                    x:Name="addOne"
                    Width="100"
                    Margin="10,0,0,0"
                    Click="AddOne_OnClick"
                    Content="+1%"
                    FontSize="18"
                    FontWeight="Bold" />
                <Button
                    x:Name="addFive"
                    Width="100"
                    Margin="10,0,0,0"
                    Click="AddFive_OnClick"
                    Content="+5%"
                    FontSize="18"
                    FontWeight="Bold" />
            </StackPanel>
        </StackPanel>
        <StackPanel
            x:Name="ringPanel"
            Margin="0,5,0,0"
            Orientation="Horizontal">
            <Label
                VerticalAlignment="Center"
                Content="环光亮度"
                FontSize="16"
                FontWeight="Bold" />
            <Controls:InputTextBox
                x:Name="ringLightRatio"
                Width="100"
                Padding="8,0,0,0"
                FontWeight="Bold"
                IsEnabled="False"
                Text="100" />
            <Label VerticalAlignment="Center" Content="%" />
            <StackPanel Margin="20,0,0,0" Orientation="Horizontal">
                <Button
                    x:Name="ringSubFive"
                    Width="100"
                    Margin="10,0,0,0"
                    Click="ringSubFive_Click"
                    Content="-5%"
                    FontSize="18"
                    FontWeight="Bold" />
                <Button
                    x:Name="ringSubOne"
                    Width="100"
                    Margin="10,0,0,0"
                    Click="ringSubOne_Click"
                    Content="-1%"
                    FontSize="18"
                    FontWeight="Bold" />
                <Button
                    x:Name="ringAddOne"
                    Width="100"
                    Margin="10,0,0,0"
                    Click="ringAddOne_Click"
                    Content="+1%"
                    FontSize="18"
                    FontWeight="Bold" />
                <Button
                    x:Name="ringAddFive"
                    Width="100"
                    Margin="10,0,0,0"
                    Click="ringAddFive_Click"
                    Content="+5%"
                    FontSize="18"
                    FontWeight="Bold" />
            </StackPanel>
        </StackPanel>
        <StackPanel
            x:Name="ExposureTimePanel"
            Margin="0,5,0,0"
            Orientation="Horizontal">
            <Label
                VerticalAlignment="Center"
                Content="曝光时间"
                FontSize="16"
                FontWeight="Bold" />
            <Controls:InputTextBox
                x:Name="ExposureTime"
                Width="100"
                Padding="8,0,0,0"
                d:Text="100"
                FontWeight="Bold"
                IsEnabled="False" />
            <Label
                VerticalAlignment="Center"
                Content="%"
                Visibility="Hidden" />
            <StackPanel Margin="20,0,0,0" Orientation="Horizontal">
                <Button
                    Width="100"
                    Margin="10,0,0,0"
                    Command="{Binding UpdateExposureTimeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CommandParameter="{Binding Content, RelativeSource={RelativeSource Self}}"
                    Content="-1000"
                    FontSize="18"
                    FontWeight="Bold" />
                <Button
                    Width="100"
                    Margin="10,0,0,0"
                    Command="{Binding UpdateExposureTimeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CommandParameter="{Binding Content, RelativeSource={RelativeSource Self}}"
                    Content="-100"
                    FontSize="18"
                    FontWeight="Bold" />
                <Button
                    Width="100"
                    Margin="10,0,0,0"
                    Command="{Binding UpdateExposureTimeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CommandParameter="{Binding Content, RelativeSource={RelativeSource Self}}"
                    Content="+100"
                    FontSize="18"
                    FontWeight="Bold" />
                <Button
                    Width="100"
                    Margin="10,0,0,0"
                    Command="{Binding UpdateExposureTimeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CommandParameter="{Binding Content, RelativeSource={RelativeSource Self}}"
                    Content="+1000"
                    FontSize="18"
                    FontWeight="Bold" />
            </StackPanel>
        </StackPanel>
    </StackPanel>
</UserControl>