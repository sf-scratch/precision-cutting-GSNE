<UserControl x:Class="精密切割系统.View.Controls.DirectOperate"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:精密切割系统.View.Controls"
             xmlns:viewModel="clr-namespace:精密切割系统.ViewModel"
             xmlns:behav="clr-namespace:精密切割系统.Behaviors"
             xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:convert="clr-namespace:精密切割系统.Converters"
             xmlns:auto="clr-namespace:WpfAutoGrid;assembly=WpfAutoGrid.Core"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             d:DataContext="{d:DesignInstance viewModel:DirectOperateViewModel, IsDesignTimeCreatable=True}"
             mc:Ignorable="d" 
             d:DesignHeight="250" d:DesignWidth="1500" IsVisibleChanged="UserControl_IsVisibleChanged">
    <UserControl.Resources>
        <convert:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style TargetType="Button">
            <Setter Property="BorderBrush" Value="{x:Null}"></Setter>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
BorderBrush="{TemplateBinding BorderBrush}" 
BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                </Setter.Value>
            </Setter>

            <!-- 按下效果触发器 -->
            <Style.Triggers>
                <!-- 鼠标按下时效果 -->
                <Trigger Property="IsPressed" Value="True">

                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="BorderBrush" Value="DarkGray"/>
                </Trigger>

                <!-- 动态恢复效果：动画从按下状态回到正常状态 -->
                <Trigger Property="IsPressed" Value="False">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                 To="1.0" Duration="0:0:0.1"/>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                 To="1.0" Duration="0:0:0.1"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <!-- 松开时移除边框 -->
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <UserControl.DataContext>
        <viewModel:DirectOperateViewModel/>
    </UserControl.DataContext>
    <Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Border CornerRadius="10" Background="#E9FDFF"  Margin="20,0,0,0">
                <Border.Effect>
                    <DropShadowEffect 
                    ShadowDepth="4" 
                    BlurRadius="20" 
                    Color="#4DC9EBF7" 
                    Direction="315" />
                </Border.Effect>
                <auto:AutoGrid Margin="10" Columns="auto,*,*,*,*,*,*,auto,auto,auto" RowCount="5" ChildMargin="5">
                    <auto:AutoGrid.Resources>
                        <ResourceDictionary>
                            <ResourceDictionary.MergedDictionaries>
                                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml"/>
                            </ResourceDictionary.MergedDictionaries>
                        </ResourceDictionary>
                    </auto:AutoGrid.Resources>
                    <TextBlock Text="X" Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                    <TextBox materialDesign:HintAssist.Hint="当前Jog速度mm/s" IsEnabled="False" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Text="{Binding CurrentJogSpeedX}" />
                    <TextBox materialDesign:HintAssist.Hint="当前速度mm/s" IsEnabled="False" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Text="{Binding CurrentSpeedX}" />
                    <TextBox materialDesign:HintAssist.Hint="当前位置mm" IsEnabled="False" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Text="{Binding CurrentPositionX}" />
                    <TextBox materialDesign:HintAssist.Hint="运动速度mm/s" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Text="{Binding SpeedX}" />
                    <TextBox materialDesign:HintAssist.Hint="目标位置mm" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Text="{Binding TargetPositionX}" />
                    <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}" IsChecked="{Binding IsAbsMoveX, Mode=TwoWay}">
                        <materialDesign:PackIcon Kind="MapMarkerDistance" />
                        <materialDesign:ToggleButtonAssist.OnContent>
                            <materialDesign:PackIcon Kind="MapMarker" />
                        </materialDesign:ToggleButtonAssist.OnContent>
                    </ToggleButton>
                    <Button Content="开始" Style="{StaticResource MaterialDesignOutlinedLightButton}" Command="{Binding StartXCommand}" IsEnabled="{Binding IsReadyX}"/>
                    <Button Content="原点" Style="{StaticResource MaterialDesignOutlinedLightButton}" Command="{Binding StartHomingXCommand}"/>
                    <Button Content="放松" Style="{StaticResource MaterialDesignOutlinedLightButton}" Command="{Binding RelaxXCommand}"/>
                    <TextBlock Text="Y" Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                    <TextBox materialDesign:HintAssist.Hint="当前Jog速度mm/s" IsEnabled="False" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Text="{Binding CurrentJogSpeedY}" />
                    <TextBox materialDesign:HintAssist.Hint="当前速度mm/s" IsEnabled="False" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Text="{Binding CurrentSpeedY}" />
                    <TextBox materialDesign:HintAssist.Hint="当前位置mm" IsEnabled="False" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Text="{Binding CurrentPositionY}" />
                    <TextBox materialDesign:HintAssist.Hint="运动速度mm/s" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Text="{Binding SpeedY}" />
                    <TextBox materialDesign:HintAssist.Hint="目标位置mm" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Text="{Binding TargetPositionY}" />
                    <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}" IsChecked="{Binding IsAbsMoveY, Mode=TwoWay}">
                        <materialDesign:PackIcon Kind="MapMarkerDistance" />
                        <materialDesign:ToggleButtonAssist.OnContent>
                            <materialDesign:PackIcon Kind="MapMarker" />
                        </materialDesign:ToggleButtonAssist.OnContent>
                    </ToggleButton>
                    <Button Content="开始" Style="{StaticResource MaterialDesignOutlinedLightButton}" Command="{Binding StartYCommand}" IsEnabled="{Binding IsReadyY}"/>
                    <Button Content="原点" Style="{StaticResource MaterialDesignOutlinedLightButton}" Command="{Binding StartHomingYCommand}"/>
                    <Button Content="放松" Style="{StaticResource MaterialDesignOutlinedLightButton}" Command="{Binding RelaxYCommand}"/>
                    <TextBlock Text="Z1" Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                    <TextBox materialDesign:HintAssist.Hint="当前Jog速度mm/s" IsEnabled="False" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Text="{Binding CurrentJogSpeedZ1}" />
                    <TextBox materialDesign:HintAssist.Hint="当前速度mm/s" IsEnabled="False" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Text="{Binding CurrentSpeedZ1}" />
                    <TextBox materialDesign:HintAssist.Hint="当前位置mm" IsEnabled="False" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Text="{Binding CurrentPositionZ1}" />
                    <TextBox materialDesign:HintAssist.Hint="运动速度mm/s" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Text="{Binding SpeedZ1}" />
                    <TextBox materialDesign:HintAssist.Hint="目标位置mm" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Text="{Binding TargetPositionZ1}" />
                    <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}" IsChecked="{Binding IsAbsMoveZ1, Mode=TwoWay}">
                        <materialDesign:PackIcon Kind="MapMarkerDistance" />
                        <materialDesign:ToggleButtonAssist.OnContent>
                            <materialDesign:PackIcon Kind="MapMarker" />
                        </materialDesign:ToggleButtonAssist.OnContent>
                    </ToggleButton>
                    <Button Content="开始" Style="{StaticResource MaterialDesignOutlinedLightButton}" Command="{Binding StartZ1Command}" IsEnabled="{Binding IsReadyZ1}"/>
                    <Button Content="原点" Style="{StaticResource MaterialDesignOutlinedLightButton}" Command="{Binding StartHomingZ1Command}"/>
                    <Button Content="放松" Style="{StaticResource MaterialDesignOutlinedLightButton}" Command="{Binding RelaxZ1Command}"/>
                    <TextBlock Text="Z2" Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                    <TextBox materialDesign:HintAssist.Hint="当前Jog速度mm/s" IsEnabled="False" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Text="{Binding CurrentJogSpeedZ2}" />
                    <TextBox materialDesign:HintAssist.Hint="当前速度mm/s" IsEnabled="False" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Text="{Binding CurrentSpeedZ2}" />
                    <TextBox materialDesign:HintAssist.Hint="当前位置mm" IsEnabled="False" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Text="{Binding CurrentPositionZ2}" />
                    <TextBox materialDesign:HintAssist.Hint="运动速度mm/s" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Text="{Binding SpeedZ2}" />
                    <TextBox materialDesign:HintAssist.Hint="目标位置mm" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Text="{Binding TargetPositionZ2}" />
                    <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}" IsChecked="{Binding IsAbsMoveZ2, Mode=TwoWay}">
                        <materialDesign:PackIcon Kind="MapMarkerDistance" />
                        <materialDesign:ToggleButtonAssist.OnContent>
                            <materialDesign:PackIcon Kind="MapMarker" />
                        </materialDesign:ToggleButtonAssist.OnContent>
                    </ToggleButton>
                    <Button Content="开始" Style="{StaticResource MaterialDesignOutlinedLightButton}" Command="{Binding StartZ2Command}" IsEnabled="{Binding IsReadyZ2}"/>
                    <Button Content="原点" Style="{StaticResource MaterialDesignOutlinedLightButton}" Command="{Binding StartHomingZ2Command}"/>
                    <Button Content="放松" Style="{StaticResource MaterialDesignOutlinedLightButton}" Command="{Binding RelaxZ2Command}"/>
                    <TextBlock Text="θ" Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                    <TextBox materialDesign:HintAssist.Hint="当前Jog速度deg/s" IsEnabled="False" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Text="{Binding CurrentJogSpeedTheta}" />
                    <TextBox materialDesign:HintAssist.Hint="当前速度deg/s" IsEnabled="False" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Text="{Binding CurrentSpeedTheta}" />
                    <TextBox materialDesign:HintAssist.Hint="当前位置deg" IsEnabled="False" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Text="{Binding CurrentPositionTheta}" />
                    <TextBox materialDesign:HintAssist.Hint="运动速度deg/s" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Text="{Binding SpeedTheta}" />
                    <TextBox materialDesign:HintAssist.Hint="目标位置deg" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Text="{Binding TargetPositionTheta}" />
                    <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}" IsChecked="{Binding IsAbsMoveTheta, Mode=TwoWay}">
                        <materialDesign:PackIcon Kind="MapMarkerDistance" />
                        <materialDesign:ToggleButtonAssist.OnContent>
                            <materialDesign:PackIcon Kind="MapMarker" />
                        </materialDesign:ToggleButtonAssist.OnContent>
                    </ToggleButton>
                    <Button Content="开始" Style="{StaticResource MaterialDesignOutlinedLightButton}" Command="{Binding StartThetaCommand}" IsEnabled="{Binding IsReadyTheta}"/>
                    <Button Content="原点" Style="{StaticResource MaterialDesignOutlinedLightButton}" Command="{Binding StartHomingThetaCommand}"/>
                    <Button Content="放松" Style="{StaticResource MaterialDesignOutlinedLightButton}" Command="{Binding RelaxThetaCommand}"/>
                </auto:AutoGrid>
            </Border>
            <Border Grid.Column="1" CornerRadius="10" Background="#E9FDFF"  Margin="10,0,5,0" Visibility="{Binding IsShowKeyboard, Converter={StaticResource BoolToVisibilityConverter}}">
                <Border.Effect>
                    <DropShadowEffect 
                    ShadowDepth="5" 
                    BlurRadius="20" 
                    Color="#4DC9EBF7" 
                    Direction="315" />
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20*"></ColumnDefinition>
                        <ColumnDefinition Width="80*"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" >
                        <Grid.RowDefinitions>
                            <RowDefinition></RowDefinition>
                            <RowDefinition></RowDefinition>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid Width="100" Height="100">
                                <StackPanel Orientation="Vertical">
                                    <Border CornerRadius="33,33,33,33" Width="66" Height="66">
                                        <Image Source="/Assets/picture/SCAN_icon.png" Width="52" Height="52"></Image>
                                    </Border>
                                    <TextBlock  Text="Scan" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"></TextBlock>
                                </StackPanel>
                            </Grid>
                        </Grid>
                        <Grid Grid.Row="1" Loaded="UserControl_Loaded">
                            <Grid.Resources>
                                <ResourceDictionary>
                                    <ResourceDictionary.MergedDictionaries>
                                        <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml"/>
                                    </ResourceDictionary.MergedDictionaries>
                                </ResourceDictionary>
                            </Grid.Resources>
                            <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                <ToggleButton Width="65" Height="65" Content="{materialDesign:PackIcon Kind=Speedometer, Size=50}" Style="{StaticResource MaterialDesignFlatPrimaryToggleButton}" 
                                              IsChecked="{Binding IsHighSpeed}" Background="#5087Cb" Foreground="Black"/>
                                <TextBlock  Text="高速" FontSize="18" Margin="0 10 0 0" FontWeight="Bold" HorizontalAlignment="Center"></TextBlock>
                            </StackPanel>
                        </Grid>

                    </Grid>
                    <Grid Grid.Column="1">
                        <Grid.Resources>
                            <ResourceDictionary>
                                <ResourceDictionary.MergedDictionaries>
                                    <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml"/>
                                </ResourceDictionary.MergedDictionaries>
                            </ResourceDictionary>
                        </Grid.Resources>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20*"></ColumnDefinition>
                            <ColumnDefinition Width="60*"></ColumnDefinition>
                            <ColumnDefinition Width="20*"></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition></RowDefinition>
                                <RowDefinition></RowDefinition>
                                <RowDefinition></RowDefinition>
                            </Grid.RowDefinitions>
                            <Button Style="{StaticResource MaterialDesignFloatingActionLightButton}" VerticalAlignment="Center" x:Name="scanLeftBottomBtn" Background="#5087Cb" Foreground="White" Content="{materialDesign:PackIcon ArrowDownLeftBold,Size=30}">
                                <behaviors:Interaction.Behaviors>
                                    <behav:DualInputBehavior StartCommand="{Binding StartThetaReversalCommand}" StopCommand="{Binding StopJogThetaCommand}"/>
                                </behaviors:Interaction.Behaviors>
                            </Button>
                            <Button Height="40" Width="90" Grid.Row="1" Background="#5087Cb" Foreground="White" Content="Z1抬起">
                                <behaviors:Interaction.Behaviors>
                                    <behav:DualInputBehavior StartCommand="{Binding StartRaiseZ1Command}" StopCommand="{Binding StopJogZ1Command}"/>
                                </behaviors:Interaction.Behaviors>
                            </Button>
                            <Button Height="40" Width="90" Grid.Row="2" Background="#5087Cb" Foreground="White" Content="Z1下降">
                                <behaviors:Interaction.Behaviors>
                                    <behav:DualInputBehavior StartCommand="{Binding StartDropZ1Command}" StopCommand="{Binding StopJogZ1Command}"/>
                                </behaviors:Interaction.Behaviors>
                                <Button.Resources>
                                    <ResourceDictionary>
                                        <ResourceDictionary.MergedDictionaries>
                                            <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml"/>
                                        </ResourceDictionary.MergedDictionaries>
                                    </ResourceDictionary>
                                </Button.Resources>
                            </Button>
                        </Grid>
                        <Grid Grid.Column="1" >
                            <Grid.RowDefinitions>
                                <RowDefinition></RowDefinition>
                                <RowDefinition></RowDefinition>
                                <RowDefinition></RowDefinition>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Button Style="{StaticResource MaterialDesignFloatingActionLightButton}" VerticalAlignment="Top" x:Name="scanTopBtn" Background="#5087Cb" Foreground="White" Content="{materialDesign:PackIcon ArrowTopThick,Size=30}">
                                    <behaviors:Interaction.Behaviors>
                                        <behav:DualInputBehavior StartCommand="{Binding StartYReversalCommand}" StopCommand="{Binding StopJogYCommand}"/>
                                    </behaviors:Interaction.Behaviors>
                                </Button>
                            </Grid>
                            <Grid Grid.Row="1" >
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition></ColumnDefinition>
                                    <ColumnDefinition></ColumnDefinition>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Button Style="{StaticResource MaterialDesignFloatingActionLightButton}" VerticalAlignment="Top" x:Name="scanLeftBtn" Background="#5087Cb" Foreground="White" Content="{materialDesign:PackIcon ArrowLeftThick,Size=30}">
                                        <behaviors:Interaction.Behaviors>
                                            <behav:DualInputBehavior StartCommand="{Binding StartXCorotationCommand}" StopCommand="{Binding StopJogXCommand}"/>
                                        </behaviors:Interaction.Behaviors>
                                    </Button>
                                </Grid>
                                <Grid Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Button Style="{StaticResource MaterialDesignFloatingActionLightButton}" VerticalAlignment="Center" x:Name="scanRightBtn" Background="#5087Cb" Foreground="White" Content="{materialDesign:PackIcon ArrowRightThick,Size=30}">
                                        <behaviors:Interaction.Behaviors>
                                            <behav:DualInputBehavior StartCommand="{Binding StartXReversalCommand}" StopCommand="{Binding StopJogXCommand}"/>
                                        </behaviors:Interaction.Behaviors>
                                    </Button>
                                </Grid>
                            </Grid>
                            <Grid Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Button Style="{StaticResource MaterialDesignFloatingActionLightButton}" VerticalAlignment="Top" x:Name="scanBottomBtn" Background="#5087Cb" Foreground="White" Content="{materialDesign:PackIcon ArrowBottomThick,Size=30}">
                                    <behaviors:Interaction.Behaviors>
                                        <behav:DualInputBehavior StartCommand="{Binding StartYCorotationCommand}" StopCommand="{Binding StopJogYCommand}"/>
                                    </behaviors:Interaction.Behaviors>
                                </Button>
                            </Grid>
                        </Grid>
                        <Grid Grid.Column="2" Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition></RowDefinition>
                                <RowDefinition></RowDefinition>
                                <RowDefinition></RowDefinition>
                            </Grid.RowDefinitions>
                            <Button Style="{StaticResource MaterialDesignFloatingActionLightButton}" VerticalAlignment="Center" x:Name="scanRightBottomBtn" Background="#5087Cb" Foreground="White" Content="{materialDesign:PackIcon ArrowDownRightBold,Size=30}">
                                <behaviors:Interaction.Behaviors>
                                    <behav:DualInputBehavior StartCommand="{Binding StartThetaCorotationCommand}" StopCommand="{Binding StopJogThetaCommand}"/>
                                </behaviors:Interaction.Behaviors>
                            </Button>
                            <Button Height="40" Width="90" Grid.Row="1" Background="#5087Cb" Foreground="White" Content="Z2抬起">
                                <behaviors:Interaction.Behaviors>
                                    <behav:DualInputBehavior StartCommand="{Binding StartRaiseZ2Command}" StopCommand="{Binding StopJogZ2Command}"/>
                                </behaviors:Interaction.Behaviors>
                                <Button.Resources>
                                    <ResourceDictionary>
                                        <ResourceDictionary.MergedDictionaries>
                                            <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml"/>
                                        </ResourceDictionary.MergedDictionaries>
                                    </ResourceDictionary>
                                </Button.Resources>
                            </Button>
                            <Button Height="40" Width="90" Grid.Row="2" Background="#5087Cb" Foreground="White" Content="Z2下降">
                                <behaviors:Interaction.Behaviors>
                                    <behav:DualInputBehavior StartCommand="{Binding StartDropZ2Command}" StopCommand="{Binding StopJogZ2Command}"/>
                                </behaviors:Interaction.Behaviors>
                                <Button.Resources>
                                    <ResourceDictionary>
                                        <ResourceDictionary.MergedDictionaries>
                                            <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml"/>
                                        </ResourceDictionary.MergedDictionaries>
                                    </ResourceDictionary>
                                </Button.Resources>
                            </Button>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
