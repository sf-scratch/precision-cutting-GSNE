<UserControl
    x:Class="精密切割系统.View.Pages.common.CameraCommon"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:精密切割系统.View.Pages.common"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="640"
    d:DesignWidth="765"
    Loaded="UserControl_Loaded"
    Unloaded="UserControl_Unloaded"
    mc:Ignorable="d">
    <Grid
        x:Name="CameraCommonGrid"
        Width="765"
        Height="640"
        ClipToBounds="True">
        <Image
            x:Name="cameraImage"
            Width="765"
            Height="640"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            MouseDown="cameraImage_MouseDown"
            RenderOptions.BitmapScalingMode="HighQuality"
            RenderOptions.EdgeMode="Aliased"
            RenderTransformOrigin="0.5,0.5"
            Stretch="Fill"
            TouchDown="cameraImage_TouchDown">
            <Image.RenderTransform>
                <!--  图像翻转并放大  -->
                <ScaleTransform CenterX="0.5" CenterY="0.5" ScaleX="-1" ScaleY="-1" />
            </Image.RenderTransform>

            <!--  裁剪超出部分  -->
            <Image.Clip>
                <RectangleGeometry Rect="0,0,765,640" />
            </Image.Clip>
        </Image>
        <Canvas
            x:Name="MyCanvas"
            Width="765"
            Height="640"
            Background="Transparent"
            IsHitTestVisible="False" />
    </Grid>
</UserControl>