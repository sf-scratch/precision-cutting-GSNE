<UserControl
    x:Class="精密切割系统.View.Pages.common.CustomKeyboard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:精密切割系统.View.Pages.common"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="250"
    d:DesignWidth="1450"
    Loaded="UserControl_Loaded"
    Unloaded="UserControl_Unloaded"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style TargetType="Controls:KeyboardBtn">
            <Setter Property="Width" Value="72" />
            <Setter Property="Height" Value="62" />
            <Setter Property="Margin" Value="5" />
        </Style>
    </UserControl.Resources>
    <Border
        Margin="20,5,0,10"
        Background="#DFFCFF"
        BorderThickness="1"
        CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="20"
                Direction="315"
                ShadowDepth="5"
                Color="#4DC9EBF7" />
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="830" />
                <ColumnDefinition Width="340" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal">
                        <Controls:KeyboardBtn BtnType="0" BtnValue="Q" />
                        <Controls:KeyboardBtn BtnType="0" BtnValue="W" />
                        <Controls:KeyboardBtn BtnType="0" BtnValue="E" />
                        <Controls:KeyboardBtn BtnType="0" BtnValue="R" />
                        <Controls:KeyboardBtn BtnType="0" BtnValue="T" />
                        <Controls:KeyboardBtn BtnType="0" BtnValue="Y" />
                        <Controls:KeyboardBtn BtnType="0" BtnValue="U" />
                        <Controls:KeyboardBtn BtnType="0" BtnValue="I" />
                        <Controls:KeyboardBtn BtnType="0" BtnValue="O" />
                        <Controls:KeyboardBtn BtnType="0" BtnValue="P" />
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="1">
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                        <Controls:KeyboardBtn BtnType="0" BtnValue="A" />
                        <Controls:KeyboardBtn BtnType="0" BtnValue="S" />
                        <Controls:KeyboardBtn BtnType="0" BtnValue="D" />
                        <Controls:KeyboardBtn BtnType="0" BtnValue="F" />
                        <Controls:KeyboardBtn BtnType="0" BtnValue="G" />
                        <Controls:KeyboardBtn BtnType="0" BtnValue="H" />
                        <Controls:KeyboardBtn BtnType="0" BtnValue="J" />
                        <Controls:KeyboardBtn BtnType="0" BtnValue="K" />
                        <Controls:KeyboardBtn BtnType="0" BtnValue="L" />
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="2" VerticalAlignment="Top">
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                        <Controls:KeyboardBtn BtnType="0" BtnValue="Z" />
                        <Controls:KeyboardBtn BtnType="0" BtnValue="X" />
                        <Controls:KeyboardBtn BtnType="0" BtnValue="C" />
                        <Controls:KeyboardBtn BtnType="0" BtnValue="V" />
                        <Controls:KeyboardBtn BtnType="0" BtnValue="B" />
                        <Controls:KeyboardBtn BtnType="0" BtnValue="N" />
                        <Controls:KeyboardBtn BtnType="0" BtnValue="M" />
                        <Controls:KeyboardBtn BtnType="2" BtnValue="-" />
                    </StackPanel>
                </Grid>
            </Grid>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal">
                        <Controls:KeyboardBtn BtnValue="7" />
                        <Controls:KeyboardBtn BtnValue="8" />
                        <Controls:KeyboardBtn BtnValue="9" />
                        <Controls:KeyboardBtn BtnType="2" BtnValue="." />
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="1">
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                        <Controls:KeyboardBtn BtnValue="4" />
                        <Controls:KeyboardBtn BtnValue="5" />
                        <Controls:KeyboardBtn BtnValue="6" />
                        <Controls:KeyboardBtn BtnValue="0" />
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="2">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Orientation="Horizontal">
                        <Controls:KeyboardBtn BtnValue="1" />
                        <Controls:KeyboardBtn BtnValue="2" />
                        <Controls:KeyboardBtn BtnValue="3" />
                        <Controls:KeyboardBtn BtnType="2" BtnValue="Down" />
                    </StackPanel>
                </Grid>
            </Grid>
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal">
                        <Controls:KeyboardBtn BtnType="2" BtnValue="Caps" />
                        <Controls:KeyboardBtn BtnType="3" BtnValue="↑" />
                        <Controls:KeyboardBtn BtnType="2" BtnValue="Del" />
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="1">
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                        <Controls:KeyboardBtn BtnType="3" BtnValue="←" />
                        <Controls:KeyboardBtn BtnType="2" BtnValue="Home" />
                        <Controls:KeyboardBtn BtnType="3" BtnValue="→" />
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="2">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Orientation="Horizontal">
                        <Controls:KeyboardBtn BtnType="2" BtnValue="Shift" />
                        <Controls:KeyboardBtn BtnType="3" BtnValue="↓" />
                        <Controls:KeyboardBtn BtnType="2" BtnValue="Tab" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>

</UserControl>
