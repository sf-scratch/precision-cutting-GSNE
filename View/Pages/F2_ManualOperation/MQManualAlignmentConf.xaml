<Page x:Class="精密切割系统.View.Pages.F2_ManualOperation.MQManualAlignmentConf"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:精密切割系统.View.Pages.F2_ManualOperation" xmlns:common="clr-namespace:精密切割系统.View.Pages.common" xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="655" d:DesignWidth="1570"
      Title="MQManualAlignmentConf" Loaded="Page_Loaded" Unloaded="Page_Unloaded">
    <Page.Resources>
        <Style TargetType="Button" x:Key="customBottonCss">
            <Setter Property="BorderBrush" Value="{x:Null}"></Setter>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                BorderBrush="{TemplateBinding BorderBrush}" 
                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50*"/>
            <ColumnDefinition Width="50*"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <common:CameraCommon Width="765" Height="640"></common:CameraCommon>
        </Grid>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Label x:Name="titleName" Margin="30,30,0,0" Content="单一切割面校准 (1.1)" FontSize="22" FontWeight="Bold"/>
            <StackPanel Grid.Row="1" Margin="30,30,0,0">
                <StackPanel x:Name="channelPanel" Orientation="Horizontal" Visibility="Visible">
                    <Label Content="切割面" FontSize="18" FontWeight="Bold" Width="200"/>
                    <Controls:InputTextBox x:Name="channelNo" IsEnabled="False" TextWrapping="Wrap" Width="200" FontSize="18" FontWeight="Bold" Padding="8,0,0,0"/>
                </StackPanel>
                <StackPanel Margin="0 12" x:Name="channelTipsPanel" Visibility="Visible">
                    <Label Content="校准后，请调整切割道位置。" FontSize="18"></Label>
                    <Label Content="确定后，请按确认按钮。此位置即刀痕检查位置。" FontSize="18"></Label>
                </StackPanel>
                <StackPanel HorizontalAlignment="Left" x:Name="absolutePositionPanel">
                    <Label Content="轴绝对位置" FontSize="18" FontWeight="Bold" 
                                   Margin="0 0 0 10" Width="200" HorizontalAlignment="Left"/>
                    <StackPanel Orientation="Horizontal" >
                        <Label Content="X" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Controls:InputTextBox x:Name="xAbsolutePosition" Width="100" Margin="5 0 0 0" IsEnabled="False"/>
                        <Label Content="Y" FontSize="16" FontWeight="Bold" Margin="15 0 0 0" VerticalAlignment="Center"/>
                        <Controls:InputTextBox x:Name="yAbsolutePosition" Width="100" Margin="5 0 0 0" IsEnabled="False"/>
                        <Label Content="Z" FontSize="16" FontWeight="Bold" Margin="15 0 0 0" VerticalAlignment="Center"/>
                        <Controls:InputTextBox x:Name="zAbsolutePosition" Width="100" Margin="5 0 0 0" IsEnabled="False"/>
                        <Label Content="Z2" FontSize="16" FontWeight="Bold" Margin="15 0 0 0" VerticalAlignment="Center"/>
                        <Controls:InputTextBox x:Name="z2AbsolutePosition" Width="100" Margin="5 0 0 0" IsEnabled="False"/>
                        <Label Content="θ" FontSize="16" FontWeight="Bold" Margin="15 0 0 0" VerticalAlignment="Center"/>
                        <Controls:InputTextBox x:Name="thetaAbsolutePosition" Width="100" Margin="5 0 0 0" IsEnabled="False"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel HorizontalAlignment="Left" Margin="0 10 0 10" x:Name="cleanPositonPanel" Visibility="Collapsed">
                    <Label Content="自计数清零后位置" FontSize="18" 
                                   Margin="0 0 0 10"  FontWeight="Bold" Width="200" HorizontalAlignment="Left"/>
                    <StackPanel Orientation="Horizontal" >
                        <Label Content="X" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"></Label>
                        <Controls:InputTextBox x:Name="xCleanPosition" Width="160" Margin="5 0 0 0"></Controls:InputTextBox>
                        <Label Content="mm" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"></Label>
                        <Label Content="Y" FontSize="16" FontWeight="Bold" Margin="15 0 0 0" VerticalAlignment="Center"></Label>
                        <Controls:InputTextBox x:Name="yCleanPosition" Width="160" Margin="5 0 0 0"></Controls:InputTextBox>
                        <Label Content="mm" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"></Label>
                    </StackPanel>
                </StackPanel>
                <common:CommonDimming x:Name="commonDimming"></common:CommonDimming>
                <StackPanel Orientation="Horizontal" Margin="0 20 0 0" Visibility="Collapsed">
                    <Label Content="刀痕宽度" FontSize="18" FontWeight="Bold" Margin="0,0,10,0"></Label>
                    <Controls:InputTextBox x:Name="cutWidth" IsEnabled="False" Width="100" FontWeight="Bold" Padding="8,0,0,0"></Controls:InputTextBox>
                    <Label Content="mm" VerticalAlignment="Center" FontSize="16"></Label>
                    <Label Content="崩边宽度" FontSize="18" FontWeight="Bold" Margin="40,0,10,0"/>
                    <Controls:InputTextBox x:Name="edgesWidth" IsEnabled="False" Width="100" FontWeight="Bold" Padding="8,0,0,0"></Controls:InputTextBox>
                    <Label Content="mm" VerticalAlignment="Center" FontSize="16"></Label>
                </StackPanel>
            </StackPanel>
            <common:SimpleDirectOperate Grid.Row="2" Margin="60"/>
        </Grid>
    </Grid>
</Page>
