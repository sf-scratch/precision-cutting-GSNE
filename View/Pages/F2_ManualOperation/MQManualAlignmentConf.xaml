<Page
    x:Class="精密切割系统.View.Pages.F2_ManualOperation.MQManualAlignmentConf"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
    xmlns:common="clr-namespace:精密切割系统.View.Pages.common"
    xmlns:cvert="clr-namespace:精密切割系统.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:精密切割系统.Helpers"
    xmlns:local="clr-namespace:精密切割系统.View.Pages.F2_ManualOperation"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MQManualAlignmentConf"
    d:DesignHeight="655"
    d:DesignWidth="1570"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded"
    mc:Ignorable="d">
    <Page.Resources>
        <!--  布尔到可见性转换器  -->
        <cvert:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50*" />
            <ColumnDefinition Width="50*" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <common:CameraCommon Width="765" Height="640" />
        </Grid>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Label
                x:Name="titleName"
                Margin="30,30,0,0"
                Content="单一切割面校准 (1.1)"
                FontSize="30"
                FontWeight="Bold" />
            <StackPanel Grid.Row="1" Margin="30,30,0,0">
                <StackPanel x:Name="channelPanel" Orientation="Horizontal">
                    <Label
                        Width="200"
                        Content="切割面"
                        FontSize="18"
                        FontWeight="Bold" />
                    <Controls:InputTextBox
                        x:Name="channelNo"
                        Width="200"
                        Padding="8,0,0,0"
                        FontSize="18"
                        FontWeight="Bold"
                        IsEnabled="False"
                        TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel x:Name="channelTipsPanel">
                    <Label Content="校准后，请调整切割道位置。" FontSize="18" />
                    <Label Content="确定后，请按确认按钮。此位置即刀痕检查位置。" FontSize="18" />
                </StackPanel>
                <common:CommonDimming x:Name="commonDimming" />
                <Controls:RealTimeAxisInfo />
            </StackPanel>
            <!--<common:SimpleDirectOperate Grid.Row="2" Margin="60" />-->
            <Controls:RealTimeInfoBox
                x:Name="RealTimeInfo"
                Grid.Row="2"
                Margin="30"
                Visibility="Collapsed" />
            <common:SimpleDirectOperate
                Grid.Row="2"
                Grid.Column="1"
                Width="600"
                Height="220" />
        </Grid>
    </Grid>
</Page>