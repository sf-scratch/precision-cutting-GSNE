<Page
    x:Class="精密切割系统.View.Pages.F2_ManualOperation.MQManualAlignmentConf"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
    xmlns:common="clr-namespace:精密切割系统.View.Pages.common"
    xmlns:cvert="clr-namespace:精密切割系统.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:精密切割系统.Helpers"
    xmlns:local="clr-namespace:精密切割系统.View.Pages.F2_ManualOperation"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MQManualAlignmentConf"
    d:DesignHeight="655"
    d:DesignWidth="1570"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded"
    mc:Ignorable="d">
    <Page.Resources>
        <Style x:Key="customBottonCss" TargetType="Button">
            <Setter Property="BorderBrush" Value="{x:Null}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!--  布尔到可见性转换器  -->
        <cvert:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50*" />
            <ColumnDefinition Width="50*" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <common:CameraCommon Width="765" Height="640" />
        </Grid>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Label
                x:Name="titleName"
                Margin="30,30,0,0"
                Content="单一切割面校准 (1.1)"
                FontSize="30"
                FontWeight="Bold" />
            <StackPanel Grid.Row="1" Margin="30,30,0,0">
                <StackPanel
                    x:Name="channelPanel"
                    Orientation="Horizontal"
                    Visibility="Visible">
                    <Label
                        Width="200"
                        Content="切割面"
                        FontSize="18"
                        FontWeight="Bold" />
                    <Controls:InputTextBox
                        x:Name="channelNo"
                        Width="200"
                        Padding="8,0,0,0"
                        FontSize="18"
                        FontWeight="Bold"
                        IsEnabled="False"
                        TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel
                    x:Name="channelTipsPanel"
                    Margin="0,12"
                    Visibility="Visible">
                    <Label Content="校准后，请调整切割道位置。" FontSize="18" />
                    <Label Content="确定后，请按确认按钮。此位置即刀痕检查位置。" FontSize="18" />
                </StackPanel>
                <StackPanel x:Name="absolutePositionPanel" HorizontalAlignment="Left">
                    <Label
                        Width="200"
                        Margin="0,0,0,10"
                        HorizontalAlignment="Left"
                        Content="轴绝对位置"
                        FontSize="18"
                        FontWeight="Bold" />
                    <StackPanel Orientation="Horizontal">
                        <Label
                            VerticalAlignment="Center"
                            Content="X"
                            FontSize="16"
                            FontWeight="Bold" />
                        <Controls:InputTextBox
                            x:Name="xAbsolutePosition"
                            Width="100"
                            Margin="5,0,0,0"
                            IsEnabled="False" />
                        <Label
                            Margin="15,0,0,0"
                            VerticalAlignment="Center"
                            Content="Y"
                            FontSize="16"
                            FontWeight="Bold" />
                        <Controls:InputTextBox
                            x:Name="yAbsolutePosition"
                            Width="100"
                            Margin="5,0,0,0"
                            IsEnabled="False" />
                        <Label
                            Margin="15,0,0,0"
                            VerticalAlignment="Center"
                            Content="Z"
                            FontSize="16"
                            FontWeight="Bold" />
                        <Controls:InputTextBox
                            x:Name="zAbsolutePosition"
                            Width="100"
                            Margin="5,0,0,0"
                            IsEnabled="False" />
                        <Label
                            Margin="15,0,0,0"
                            VerticalAlignment="Center"
                            Content="Z2"
                            FontSize="16"
                            FontWeight="Bold" />
                        <Controls:InputTextBox
                            x:Name="z2AbsolutePosition"
                            Width="100"
                            Margin="5,0,0,0"
                            IsEnabled="False" />
                        <Label
                            Margin="15,0,0,0"
                            VerticalAlignment="Center"
                            Content="θ"
                            FontSize="16"
                            FontWeight="Bold"
                            Visibility="{Binding Source={x:Static helpers:GlobalParams.HasTheta}, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Controls:InputTextBox
                            x:Name="thetaAbsolutePosition"
                            Width="100"
                            Margin="5,0,0,0"
                            IsEnabled="False"
                            Visibility="{Binding Source={x:Static helpers:GlobalParams.HasTheta}, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>
                </StackPanel>
                <StackPanel
                    x:Name="cleanPositonPanel"
                    Margin="0,10,0,10"
                    HorizontalAlignment="Left"
                    Visibility="Collapsed">
                    <Label
                        Width="200"
                        Margin="0,0,0,10"
                        HorizontalAlignment="Left"
                        Content="自计数清零后位置"
                        FontSize="18"
                        FontWeight="Bold" />
                    <StackPanel Orientation="Horizontal">
                        <Label
                            VerticalAlignment="Center"
                            Content="X"
                            FontSize="16"
                            FontWeight="Bold" />
                        <Controls:InputTextBox
                            x:Name="xCleanPosition"
                            Width="160"
                            Margin="5,0,0,0" />
                        <Label
                            VerticalAlignment="Center"
                            Content="mm"
                            FontSize="16"
                            FontWeight="Bold" />
                        <Label
                            Margin="15,0,0,0"
                            VerticalAlignment="Center"
                            Content="Y"
                            FontSize="16"
                            FontWeight="Bold" />
                        <Controls:InputTextBox
                            x:Name="yCleanPosition"
                            Width="160"
                            Margin="5,0,0,0" />
                        <Label
                            VerticalAlignment="Center"
                            Content="mm"
                            FontSize="16"
                            FontWeight="Bold" />
                    </StackPanel>
                </StackPanel>
                <common:CommonDimming x:Name="commonDimming" />
                <StackPanel
                    Margin="0,20,0,0"
                    Orientation="Horizontal"
                    Visibility="Collapsed">
                    <Label
                        Margin="0,0,10,0"
                        Content="刀痕宽度"
                        FontSize="18"
                        FontWeight="Bold" />
                    <Controls:InputTextBox
                        x:Name="cutWidth"
                        Width="100"
                        Padding="8,0,0,0"
                        FontWeight="Bold"
                        IsEnabled="False" />
                    <Label
                        VerticalAlignment="Center"
                        Content="mm"
                        FontSize="16" />
                    <Label
                        Margin="40,0,10,0"
                        Content="崩边宽度"
                        FontSize="18"
                        FontWeight="Bold" />
                    <Controls:InputTextBox
                        x:Name="edgesWidth"
                        Width="100"
                        Padding="8,0,0,0"
                        FontWeight="Bold"
                        IsEnabled="False" />
                    <Label
                        VerticalAlignment="Center"
                        Content="mm"
                        FontSize="16" />
                </StackPanel>
            </StackPanel>
            <!--<common:SimpleDirectOperate Grid.Row="2" Margin="60" />-->
            <Controls:RealTimeInfoBox
                x:Name="RealTimeInfo"
                Grid.Row="2"
                Margin="30" />
        </Grid>
    </Grid>
</Page>