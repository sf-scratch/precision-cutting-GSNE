<Page
    x:Class="精密切割系统.View.Pages.F2_ManualOperation.MQSemiAutomaticCuttingConf"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
    xmlns:Converters="clr-namespace:精密切割系统.Converters"
    xmlns:common="clr-namespace:精密切割系统.View.Pages.common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:精密切割系统.View.Pages.F2_ManualOperation"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:精密切割系统.ViewModel"
    Title="MQSemiAutomaticCuttingConf"
    d:DesignHeight="645"
    d:DesignWidth="1560"
    Loaded="Page_Loaded"
    mc:Ignorable="d">
    <Page.Resources>
        <Converters:BoolToValueConverter
            x:Key="BoolToStringConverter"
            FalseValue="关闭"
            TrueValue="开启" />
    </Page.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50*" />
            <ColumnDefinition Width="50*" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <common:CameraCommon Width="765" Height="640" />
        </Grid>
        <Grid Grid.Column="1">
            <StackPanel>
                <Grid>
                    <Label
                        Margin="30,30,0,0"
                        Content="半自动切割 (1.2)"
                        FontSize="30"
                        FontWeight="Bold" />
                </Grid>
                <Grid>
                    <StackPanel Margin="30,30,0,0">
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                            <Label
                                Width="200"
                                Content="型号参数 No"
                                FontSize="18"
                                FontWeight="Bold" />
                            <Controls:InputTextBox
                                Width="200"
                                IsEnabled="False"
                                Text="{Binding Path=DeviceDataNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                            <Label
                                Width="200"
                                Content="ID"
                                FontSize="18"
                                FontWeight="Bold" />
                            <Controls:InputTextBox
                                Width="200"
                                IsEnabled="False"
                                Text="{Binding Path=DeviceDataId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                            <Label
                                Width="200"
                                Content="切割面"
                                FontSize="18"
                                FontWeight="Bold" />
                            <Controls:InputTextBox
                                Width="200"
                                IsEnabled="False"
                                Text="{Binding Path=ChannelNum, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                            <Label
                                Width="200"
                                Content="刀片高度"
                                FontSize="18"
                                FontWeight="Bold" />
                            <Controls:InputTextBox
                                Width="200"
                                IsEnabled="False"
                                Text="{Binding Path=BladeHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap" />
                            <Label Content="mm" FontSize="16" />
                        </StackPanel>
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                            <Label
                                Width="200"
                                Content="进刀速度"
                                FontSize="18"
                                FontWeight="Bold" />
                            <Controls:InputTextBox
                                Width="200"
                                IsEnabled="False"
                                Text="{Binding Path=FeedSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap" />
                            <Label Content="mm/s" FontSize="16" />
                        </StackPanel>
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                            <Label
                                Width="200"
                                Content="切割方向"
                                FontSize="18"
                                FontWeight="Bold" />
                            <Controls:InputTextBox
                                Width="200"
                                IsEnabled="False"
                                Text="{Binding Path=CutDirection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel
                            x:Name="HeightChangePanel"
                            Margin="0,10,0,0"
                            Orientation="Horizontal">
                            <Label
                                Width="200"
                                Content="刀片高度补偿"
                                FontSize="18"
                                FontWeight="Bold" />
                            <Controls:InputTextBox
                                Width="200"
                                InputType="Decimal"
                                Text="{Binding Path=DepthCompensation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap"
                                XMax="0.3"
                                XMin="-0.3"
                                XPrecision="5" />
                            <Label Content="mm" FontSize="16" />
                        </StackPanel>
                        <StackPanel
                            x:Name="SpeedChangePanel"
                            Margin="0,10,0,0"
                            Orientation="Horizontal">
                            <Label
                                Width="200"
                                Content="变更进刀速度"
                                FontSize="18"
                                FontWeight="Bold" />
                            <Controls:InputTextBox
                                Width="200"
                                InputType="Decimal"
                                Text="{Binding Path=ChangeFeedSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap"
                                XPrecision="3" />
                            <Label Content="mm/s" FontSize="16" />
                        </StackPanel>
                        <StackPanel
                            Margin="0,10,0,0"
                            Orientation="Horizontal"
                            Visibility="Collapsed">
                            <Label
                                Width="200"
                                Content="偏离校准点"
                                FontSize="18"
                                FontWeight="Bold" />
                            <Controls:InputTextBox
                                Width="200"
                                InputType="Decimal"
                                Text="{Binding Path=CutDepthOffset, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap"
                                XPrecision="3" />
                            <Label Content="mm" />
                        </StackPanel>
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                            <Label
                                Width="200"
                                Content="切割刀数(0=ALL)"
                                FontSize="18"
                                FontWeight="Bold" />
                            <Controls:InputTextBox
                                Width="200"
                                InputType="Numeral"
                                Text="{Binding Path=CutLine, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap" />
                            <Label Content="lines" FontSize="16" />
                        </StackPanel>
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                            <Label
                                Width="200"
                                Content="主轴转速"
                                FontSize="18"
                                FontWeight="Bold" />
                            <Controls:InputTextBox
                                Width="200"
                                InputType="Numeral"
                                Text="{Binding Path=SpindleRev, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap" />
                            <Label Content="/min" FontSize="16" />
                        </StackPanel>
                        <StackPanel
                            Margin="0,10,0,0"
                            Orientation="Horizontal"
                            Visibility="Collapsed">
                            <Label
                                Width="200"
                                Content="是否重复循环"
                                FontSize="18"
                                FontWeight="Bold" />
                            <CheckBox
                                x:Name="repeatedCheckbox"
                                Width="50"
                                Height="35"
                                VerticalContentAlignment="Center"
                                Click="repeatedCheckbox_Click"
                                Content="循环"
                                FontSize="16"
                                IsChecked="False">
                                <CheckBox.LayoutTransform>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="1.2" ScaleY="1.2" />
                                        <SkewTransform />
                                        <RotateTransform />
                                        <TranslateTransform />
                                    </TransformGroup>
                                </CheckBox.LayoutTransform>
                            </CheckBox>
                            <CheckBox
                                x:Name="yCompCheckbox"
                                Width="80"
                                Height="35"
                                Margin="20,0,0,0"
                                VerticalContentAlignment="Center"
                                Checked="yCompCheckbox_Checked"
                                Content="Y轴补偿"
                                FontSize="16"
                                IsChecked="False"
                                Unchecked="yCompCheckbox_Unchecked">
                                <CheckBox.LayoutTransform>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="1.2" ScaleY="1.2" />
                                        <SkewTransform />
                                        <RotateTransform />
                                        <TranslateTransform />
                                    </TransformGroup>
                                </CheckBox.LayoutTransform>
                            </CheckBox>
                            <CheckBox
                                x:Name="z1CompCheckbox"
                                Width="80"
                                Height="35"
                                Margin="20,0,0,0"
                                VerticalContentAlignment="Center"
                                Checked="z1CompCheckbox_Checked"
                                Content="Z轴补偿"
                                FontSize="16"
                                IsChecked="False"
                                Unchecked="z1CompCheckbox_Unchecked">
                                <CheckBox.LayoutTransform>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="1.2" ScaleY="1.2" />
                                        <SkewTransform />
                                        <RotateTransform />
                                        <TranslateTransform />
                                    </TransformGroup>
                                </CheckBox.LayoutTransform>
                            </CheckBox>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</Page>