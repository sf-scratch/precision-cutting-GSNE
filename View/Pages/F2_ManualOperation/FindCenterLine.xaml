<UserControl
    x:Class="精密切割系统.View.Pages.F2_ManualOperation.FindCenterLine"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
    xmlns:auto="clr-namespace:WpfAutoGrid;assembly=WpfAutoGrid.Core"
    xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:common="clr-namespace:精密切割系统.View.Pages.common"
    xmlns:cvert="clr-namespace:精密切割系统.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:精密切割系统.View.Pages.F2_ManualOperation"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:精密切割系统.ViewModel"
    d:DataContext="{d:DesignInstance viewModel:FindCenterLineViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="645"
    d:DesignWidth="1565"
    mc:Ignorable="d">
    <behaviors:Interaction.Triggers>
        <behaviors:EventTrigger EventName="Loaded">
            <behaviors:InvokeCommandAction Command="{Binding LoadedCommand}" />
        </behaviors:EventTrigger>
    </behaviors:Interaction.Triggers>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50*" />
            <ColumnDefinition Width="50*" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <common:CameraCommon Width="765" Height="640" />
        </Grid>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Label
                Margin="30,30,0,0"
                Content="切割道中心"
                FontSize="30"
                FontWeight="Bold" />
            <StackPanel Grid.Row="1" Margin="30,30,0,0">
                <common:CommonDimming x:Name="commonDimming" />
                <Controls:RealTimeAxisInfo />
                <auto:AutoGrid
                    Margin="0,20,0,0"
                    ChildMargin="0,5,0,5"
                    Columns="1.5*,3*,1.5*,1.5*,3*,1.5*,1.5*,3*,1.5*"
                    RowCount="7">
                    <Label
                        Content="边1"
                        FontSize="18"
                        FontWeight="Bold" />
                    <Controls:InputTextBox
                        IsEnabled="False"
                        Text="{Binding Line1Position}"
                        TextAlignment="Right"
                        TextWrapping="Wrap" />
                    <Label Content="mm" FontSize="16" />
                    <Label
                        Content="边2"
                        FontSize="18"
                        FontWeight="Bold" />
                    <Controls:InputTextBox
                        IsEnabled="False"
                        Text="{Binding Line2Position}"
                        TextAlignment="Right"
                        TextWrapping="Wrap" />
                    <Label Content="mm" FontSize="16" />
                    <Label
                        Content="中心"
                        FontSize="18"
                        FontWeight="Bold" />
                    <Controls:InputTextBox
                        IsEnabled="False"
                        Text="{Binding CenterLinePosition}"
                        TextAlignment="Right"
                        TextWrapping="Wrap" />
                    <Label Content="mm" FontSize="16" />
                </auto:AutoGrid>
            </StackPanel>
            <common:SimpleDirectOperate
                Grid.Row="2"
                Grid.Column="1"
                Width="600"
                Height="220" />
        </Grid>
    </Grid>
</UserControl>