<UserControl
    x:Class="精密切割系统.View.Pages.F2_ManualOperation.ManualAlignment"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
    xmlns:Converters="clr-namespace:精密切割系统.Converters"
    xmlns:auto="clr-namespace:WpfAutoGrid;assembly=WpfAutoGrid.Core"
    xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:common="clr-namespace:精密切割系统.View.Pages.common"
    xmlns:cvert="clr-namespace:精密切割系统.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:精密切割系统.Helpers"
    xmlns:local="clr-namespace:精密切割系统.View.Pages.F2_ManualOperation"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:精密切割系统.ViewModel"
    d:DataContext="{d:DesignInstance viewModel:MQSemiAutomaticCuttingStopViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="645"
    d:DesignWidth="1560"
    mc:Ignorable="d">
    <behaviors:Interaction.Triggers>
        <behaviors:EventTrigger EventName="Loaded">
            <behaviors:InvokeCommandAction Command="{Binding LoadedCommand}" />
        </behaviors:EventTrigger>
    </behaviors:Interaction.Triggers>
    <UserControl.Resources>
        <!--  布尔到可见性转换器  -->
        <cvert:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50*" />
            <ColumnDefinition Width="50*" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <common:CameraCommon Width="765" Height="640" />
        </Grid>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Label
                Margin="30,30,0,0"
                Content="手动校准 (2.2)"
                FontSize="30"
                FontWeight="Bold" />
            <StackPanel Grid.Row="1" Margin="30,30,0,0">
                <StackPanel Orientation="Horizontal">
                    <Label
                        Width="200"
                        Content="切割面"
                        FontSize="18"
                        FontWeight="Bold" />
                    <Controls:InputTextBox
                        Width="200"
                        Padding="8,0,0,0"
                        FontSize="18"
                        FontWeight="Bold"
                        IsEnabled="False"
                        Text="{Binding CurrentCh}"
                        TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel>
                    <Label Content="校准后，请调整切割道位置。" FontSize="18" />
                    <Label Content="确定后，请按确认按钮。此位置即刀痕检查位置。" FontSize="18" />
                </StackPanel>
                <common:CommonDimming />
                <Controls:RealTimeAxisInfo />
            </StackPanel>
            <common:SimpleDirectOperate
                Grid.Row="2"
                Grid.Column="1"
                Width="600"
                Height="220" />
        </Grid>
    </Grid>
</UserControl>