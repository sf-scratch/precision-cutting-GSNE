<UserControl
    x:Class="精密切割系统.View.Pages.F2_ManualOperation.MQSemiAutomaticCuttingRun"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
    xmlns:auto="clr-namespace:WpfAutoGrid;assembly=WpfAutoGrid.Core"
    xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:convert="clr-namespace:精密切割系统.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:精密切割系统.Helpers"
    xmlns:local="clr-namespace:精密切割系统.View.Pages.F2_ManualOperation"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:精密切割系统.ViewModel"
    d:DataContext="{d:DesignInstance viewModel:MQSemiAutomaticCuttingRunViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="645"
    d:DesignWidth="1560"
    Loaded="Page_Loaded"
    mc:Ignorable="d">
    <behaviors:Interaction.Triggers>
        <behaviors:EventTrigger EventName="Loaded">
            <behaviors:InvokeCommandAction Command="{Binding RunAutoCutCommand}" />
        </behaviors:EventTrigger>
    </behaviors:Interaction.Triggers>
    <UserControl.Resources>
        <convert:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <Style TargetType="Label">
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style BasedOn="{StaticResource InputTextStyle}" TargetType="Controls:InputTextBox">
            <Setter Property="XAllowNull" Value="True" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50*" />
            <ColumnDefinition Width="50*" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <Image
                Width="765"
                Height="640"
                Source="/Assets/picture/大背景.png" />
        </Grid>
        <Grid Grid.Column="1">
            <StackPanel>
                <Grid>
                    <Label
                        Margin="30,30,0,0"
                        Content="切割状态"
                        FontSize="22"
                        FontWeight="Bold" />
                </Grid>
                <auto:AutoGrid
                    Margin="10"
                    ChildMargin="5"
                    Columns="4*,5*,2*,4*,5*,2*"
                    RowCount="7">
                    <Label
                        Content="型号参数 No"
                        FontSize="18"
                        FontWeight="Bold" />
                    <Controls:InputTextBox
                        IsEnabled="False"
                        Text="{Binding Path=CutParam.DeviceDataNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap" />
                    <Label Content="" FontSize="16" />
                    <Label
                        Content="ID"
                        FontSize="18"
                        FontWeight="Bold" />
                    <Controls:InputTextBox
                        IsEnabled="False"
                        Text="{Binding Path=CutParam.DeviceDataId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap" />
                    <Label Content="" FontSize="16" />
                    <Label
                        Content="切割刀数"
                        FontSize="18"
                        FontWeight="Bold" />
                    <StackPanel Orientation="Horizontal">
                        <Controls:InputTextBox
                            IsEnabled="False"
                            Text="{Binding Path=CutParam.RunCutLine, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            TextWrapping="Wrap" />
                        <Label Content=" / " FontSize="18" />
                        <Controls:InputTextBox
                            IsEnabled="False"
                            Text="{Binding Path=CutParam.AllRunCutLine, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <Label Content="" FontSize="16" />
                    <Label
                        Content="切割面"
                        FontSize="18"
                        FontWeight="Bold" />
                    <Controls:InputTextBox
                        IsEnabled="False"
                        Text="{Binding Path=CutParam.ChannelNum, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap" />
                    <Label Content="" FontSize="16" />
                    <Label
                        Content="刀片高度"
                        FontSize="18"
                        FontWeight="Bold" />
                    <Controls:InputTextBox
                        IsEnabled="False"
                        Text="{Binding Path=CutParam.BladeHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap" />
                    <Label Content="mm" FontSize="16" />
                    <Label
                        x:Name="HeightChange1"
                        Content="刀片高度补偿"
                        FontSize="18"
                        FontWeight="Bold" />
                    <Controls:InputTextBox
                        x:Name="HeightChange2"
                        InputType="Decimal"
                        Text="{Binding Path=CutParam.DepthCompensation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap"
                        XPrecision="5" />
                    <Label
                        x:Name="HeightChange3"
                        Content="mm"
                        FontSize="16" />
                    <Label
                        Content="进刀速度"
                        FontSize="18"
                        FontWeight="Bold" />
                    <Controls:InputTextBox
                        IsEnabled="False"
                        Text="{Binding Path=CutParam.FeedSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap" />
                    <Label Content="mm/s" FontSize="16" />
                    <Label
                        x:Name="ChangeFeedSpeed1"
                        Content="变更进刀速度"
                        FontSize="18"
                        FontWeight="Bold" />
                    <Controls:InputTextBox
                        x:Name="ChangeFeedSpeed2"
                        InputType="Decimal"
                        Text="{Binding Path=CutParam.ChangeFeedSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap"
                        XPrecision="3" />
                    <Label
                        x:Name="ChangeFeedSpeed3"
                        Content="mm/s"
                        FontSize="16" />
                    <Label
                        Content="自更换刀片起"
                        FontSize="18"
                        FontWeight="Bold" />
                    <StackPanel Grid.ColumnSpan="2" Orientation="Horizontal">
                        <Controls:InputTextBox
                            IsEnabled="False"
                            Text="{Binding Path=CutParam.AllCutLine, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            TextWrapping="Wrap" />
                        <Label Content="lines" FontSize="16" />
                        <Label Content="" FontSize="16" />
                        <Controls:InputTextBox
                            IsEnabled="False"
                            Text="{Binding Path=CutParam.AllCutLineLength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            TextWrapping="Wrap" />
                        <Label Content="m" FontSize="16" />
                    </StackPanel>
                    <Label
                        Content="预计结束时间"
                        FontSize="18"
                        FontWeight="Bold" />
                    <Controls:InputTextBox
                        IsEnabled="False"
                        Text="{Binding Path=CutParam.ExpectedProcessingEndTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap" />
                    <Label Content="" FontSize="16" />
                </auto:AutoGrid>
                <Grid>
                    <Label
                        Margin="30,5,0,0"
                        Content="轴绝对位置"
                        FontSize="22"
                        FontWeight="Bold" />
                </Grid>
                <auto:AutoGrid
                    Margin="15,10,10,10"
                    ChildMargin="0,5,0,5"
                    Columns="1.5*,3*,1.5*,1.5*,3*,1.5*,1.5*,3*,1.5*"
                    RowCount="7">
                    <Label
                        Content="X轴"
                        FontSize="18"
                        FontWeight="Bold" />
                    <Controls:InputTextBox
                        IsEnabled="False"
                        Text="{Binding XAxisCurrentPosition}"
                        TextAlignment="Right"
                        TextWrapping="Wrap" />
                    <Label Content="mm" FontSize="16" />
                    <Label
                        Content="Y轴"
                        FontSize="18"
                        FontWeight="Bold" />
                    <Controls:InputTextBox
                        IsEnabled="False"
                        Text="{Binding YAxisCurrentPosition}"
                        TextAlignment="Right"
                        TextWrapping="Wrap" />
                    <Label Content="mm" FontSize="16" />
                    <Label
                        Content="Z1轴"
                        FontSize="18"
                        FontWeight="Bold" />
                    <Controls:InputTextBox
                        IsEnabled="False"
                        Text="{Binding ZAxisCurrentPosition}"
                        TextAlignment="Right"
                        TextWrapping="Wrap" />
                    <Label Content="mm" FontSize="16" />
                    <Label
                        Content="Z2轴"
                        FontSize="18"
                        FontWeight="Bold" />
                    <Controls:InputTextBox
                        IsEnabled="False"
                        Text="{Binding Z2AxisCurrentPosition}"
                        TextAlignment="Right"
                        TextWrapping="Wrap" />
                    <Label Content="mm" FontSize="16" />
                    <Label
                        Content="θ轴"
                        FontSize="18"
                        FontWeight="Bold"
                        Visibility="{Binding Source={x:Static helpers:GlobalParams.HasTheta}, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Controls:InputTextBox
                        IsEnabled="False"
                        Text="{Binding ThetaAxisCurrentPosition}"
                        TextAlignment="Right"
                        TextWrapping="Wrap"
                        Visibility="{Binding Source={x:Static helpers:GlobalParams.HasTheta}, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Label
                        Content="°"
                        FontSize="16"
                        Visibility="{Binding Source={x:Static helpers:GlobalParams.HasTheta}, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Label
                        Content="Y偏差"
                        FontSize="18"
                        FontWeight="Bold" />
                    <Controls:InputTextBox
                        HorizontalContentAlignment="Left"
                        IsEnabled="False"
                        Text="{Binding YAxisCutPosition}"
                        TextAlignment="Right"
                        TextWrapping="Wrap" />
                    <Label Content="mm" FontSize="16" />
                </auto:AutoGrid>
                <Controls:RealTimeInfoBox
                    Grid.Row="2"
                    Height="150"
                    Margin="0,5,30,30"
                    Messages="{Binding MessageList}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>