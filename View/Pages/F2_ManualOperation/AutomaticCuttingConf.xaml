<UserControl
    x:Class="精密切割系统.View.Pages.F2_ManualOperation.AutomaticCuttingConf"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
    xmlns:Converters="clr-namespace:精密切割系统.Converters"
    xmlns:auto="clr-namespace:WpfAutoGrid;assembly=WpfAutoGrid.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:精密切割系统.View.Pages.F2_ManualOperation"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:精密切割系统.ViewModel"
    d:DataContext="{d:DesignInstance viewModel:AutomaticCuttingConfViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="645"
    d:DesignWidth="1560"
    mc:Ignorable="d">
    <Grid>
        <Grid.Resources>
            <Style TargetType="Label">
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontWeight" Value="Bold" />
            </Style>
            <Style TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Margin" Value="50,0,0,0" />
            </Style>
            <Style BasedOn="{StaticResource InputTextStyle}" TargetType="Controls:InputTextBox">
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="InputType" Value="Decimal" />
                <Setter Property="XPrecision" Value="3" />
                <Setter Property="FontWeight" Value="Normal" />
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="300" />
        </Grid.RowDefinitions>
        <Label
            Margin="30,30,0,0"
            Content="全自动 (1.0)"
            FontSize="30"
            FontWeight="Bold" />
        <auto:AutoGrid
            Grid.Row="1"
            Margin="10"
            ChildMargin="5"
            Columns="2*,*,*,2*,*,*"
            RowCount="3">
            <TextBlock Text="目录名" />
            <Controls:InputTextBox
                Grid.ColumnSpan="2"
                InputType="Default"
                IsEnabled="False"
                Text="{Binding Path=Model.DirectoryName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="刀片高度补偿" />
            <Controls:InputTextBox Text="{Binding Path=Model.DepthCompensation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Label Content="mm" />
            <TextBlock Text="型号参数 No" />
            <Controls:InputTextBox
                Grid.ColumnSpan="2"
                InputType="Default"
                IsEnabled="False"
                Text="{Binding Path=Model.DeviceDataNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="变更进刀速度" />
            <Controls:InputTextBox Text="{Binding Path=Model.ChangeFeedSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Label Content="mm/s" />
            <TextBlock Text="ID" />
            <Controls:InputTextBox
                Grid.ColumnSpan="2"
                InputType="Default"
                IsEnabled="False"
                Text="{Binding Path=Model.DeviceDataId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </auto:AutoGrid>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <GroupBox
                Margin="50,20,0,0"
                FontSize="20"
                FontWeight="Bold"
                Header="刀片使用寿命">
                <auto:AutoGrid
                    Grid.Row="1"
                    Margin="10"
                    ChildMargin="5"
                    Columns="2*,2*,*,2*,*"
                    RowCount="3">
                    <Label Content="自刀片更换后" />
                    <Controls:InputTextBox IsEnabled="False" Text="{Binding Model.AfterReplaceBladeCutTimes}" />
                    <Label Content="刀" />
                    <Controls:InputTextBox IsEnabled="False" Text="{Binding Model.AfterReplaceBladeCutLength}" />
                    <Label Content="m" />
                    <Label Content="自测高后" />
                    <Controls:InputTextBox IsEnabled="False" Text="{Binding Model.AfterMeasureHeightCutTimes}" />
                    <Label Content="刀" />
                    <Controls:InputTextBox IsEnabled="False" Text="{Binding Model.AfterMeasureHeightCutLength}" />
                    <Label Content="m" />
                    <Label Content="自计数清零后" />
                    <Controls:InputTextBox IsEnabled="False" Text="{Binding Model.AfterClearDataCutTimes}" />
                    <Label Content="刀" />
                    <Controls:InputTextBox IsEnabled="False" Text="{Binding Model.AfterClearDataCutLength}" />
                    <Label Content="m" />
                </auto:AutoGrid>
            </GroupBox>
            <GroupBox
                Grid.Column="1"
                Margin="50,20,0,0"
                FontSize="20"
                FontWeight="Bold"
                Header="型号参数">
                <StackPanel>
                    <auto:AutoGrid
                        Margin="10"
                        ChildMargin="5"
                        Columns="auto,auto,auto"
                        RowCount="3">
                        <Label Width="200" Content="旋转轴转速" />
                        <Controls:InputTextBox
                            Width="120"
                            IsEnabled="False"
                            Text="{Binding Model.SpindleRev}" />
                        <Label Content="/min" />
                    </auto:AutoGrid>
                </StackPanel>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>