<Page x:Class="精密切割系统.View.Pages.F2_ManualOperation.MQAutoCutoConf"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:精密切割系统.View.Pages.F2_ManualOperation" xmlns:Controls="clr-namespace:精密切割系统.View.Controls" xmlns:common="clr-namespace:精密切割系统.View.Pages.common"
      mc:Ignorable="d" 
      d:DesignHeight="655" d:DesignWidth="1570"
      Title="MQAutoCutoConf" Loaded="Page_Loaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50*"/>
            <ColumnDefinition Width="50*"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <common:CameraCommon Width="765" Height="640"></common:CameraCommon>
        </Grid>
        <Grid Grid.Column="1">
            <StackPanel>
                <Grid>
                    <Label Margin="30,30,0,0" Content="自动切割 (1.2)" FontSize="22" FontWeight="Bold"/>
                </Grid>
                <Grid x:Name="contentGrid">
                    <StackPanel Margin="30,30,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Label Content="型号参数 No" FontSize="18" FontWeight="Bold" Width="200"/>
                            <Controls:InputTextBox TextWrapping="Wrap" Text="InputTextBox" Width="200"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Label Content="ID" FontSize="18" FontWeight="Bold" Width="200"/>
                            <Controls:InputTextBox TextWrapping="Wrap" Text="InputTextBox" Width="200"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Label Content="切割面" FontSize="18" FontWeight="Bold" Width="200"/>
                            <Controls:InputTextBox TextWrapping="Wrap" Text="InputTextBox" Width="200"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Label Content="刀片高度" FontSize="18" FontWeight="Bold" Width="200"/>
                            <Controls:InputTextBox TextWrapping="Wrap" Text="InputTextBox" Width="200"/>
                            <Label Content="mm"></Label>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Label Content="进刀速度" FontSize="18" FontWeight="Bold" Width="200"/>
                            <Controls:InputTextBox TextWrapping="Wrap" Text="InputTextBox" Width="200"/>
                            <Label Content="mm"></Label>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Label Content="切割方向" FontSize="18" FontWeight="Bold" Width="200"/>
                            <Controls:InputTextBox TextWrapping="Wrap" Text="InputTextBox" Width="200"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Label Content="刀片高度补偿" FontSize="18" FontWeight="Bold" Width="200"/>
                            <Controls:InputTextBox TextWrapping="Wrap" Text="InputTextBox" Width="200"/>
                            <Label Content="mm"></Label>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Label Content="变更进刀速度" FontSize="18" FontWeight="Bold" Width="200"/>
                            <Controls:InputTextBox TextWrapping="Wrap" Text="InputTextBox" Width="200"/>
                            <Label Content="mm/s"></Label>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
