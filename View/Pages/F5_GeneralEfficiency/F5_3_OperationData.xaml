<Page
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:精密切割系统.View.Pages"
      xmlns:Controls="clr-namespace:精密切割系统.View.Controls" x:Class="精密切割系统.View.Pages.F5_3_FunctionData"
      mc:Ignorable="d"
      Background="#FFDFFCFF"
      d:DesignHeight="655" d:DesignWidth="1570"
      Title="F5_3_FunctionData">
    <Page.DataContext>
        <local:F5_3_FunctionData />
    </Page.DataContext>
    <Grid>
        <Label Content="功能参数维护（5.3）" HorizontalAlignment="Left" Height="51" Width="324" FontSize="18" VerticalContentAlignment="Center" VerticalAlignment="Top"/>
        <CheckBox Content="自动校准" IsChecked="{Binding functionParameter.Alignment}" HorizontalAlignment="Left" Margin="24,123,0,0" VerticalAlignment="Top" Height="37" Width="115" FontSize="14"/>
        <CheckBox Content="切割" IsChecked="{Binding functionParameter.Cut}" HorizontalAlignment="Left" Margin="24,216,0,0" VerticalAlignment="Top" Height="37" Width="73" FontSize="14"/>
        <CheckBox Content="刀痕检查后再确认" IsChecked="{Binding functionParameter.AfterKerfCheck}" HorizontalAlignment="Left" Margin="246,123,0,0" VerticalAlignment="Top" Height="37" Width="194" FontSize="14"/>
        <CheckBox Content="轴润滑维护" IsChecked="{Binding functionParameter.AxisMaintenance}" HorizontalAlignment="Left" Margin="246,216,0,0" VerticalAlignment="Top" Height="37" Width="134" FontSize="14"/>
        <CheckBox Content="旋转轴" IsChecked="{Binding functionParameter.Spindle}" HorizontalAlignment="Left" Margin="24,312,0,0" VerticalAlignment="Top" Height="36" Width="94" FontSize="14"/>
        <CheckBox Content="非接触测高" IsChecked="{Binding functionParameter.NonContactSetup}" HorizontalAlignment="Left" Margin="24,406,0,0" VerticalAlignment="Top" Height="37" Width="134" FontSize="14"/>
        <CheckBox Content="防止工件干燥操作" IsChecked="{Binding functionParameter.KeepWorkWet}" HorizontalAlignment="Left" Margin="246,312,0,0" VerticalAlignment="Top" Height="36" Width="194" FontSize="14"/>
        <CheckBox Content="胶片切割基准校准线" IsChecked="{Binding functionParameter.TapeCutHairlineAdjust}" HorizontalAlignment="Left" Margin="246,406,0,0" VerticalAlignment="Top" Height="37" Width="214" FontSize="14"/>
        <CheckBox Content="刀片破损检测" IsChecked="{Binding functionParameter.Bbd}" HorizontalAlignment="Left" Margin="24,493,0,0" VerticalAlignment="Top" Height="37" Width="155" FontSize="14"/>
        <CheckBox Content="与工作vaz和c/t vac连接" IsChecked="{Binding functionParameter.ConnectedWithWork}" HorizontalAlignment="Left" Margin="246,493,0,0" VerticalAlignment="Top" Height="37" Width="250" FontSize="14"/>
        <Label Content="回转轴空闲时间" HorizontalAlignment="Left" Margin="671,110,0,0" VerticalAlignment="Top" Height="31" Width="114" FontSize="14"/>
        <Label Content="内定单位" HorizontalAlignment="Left" Margin="694,204,0,0" VerticalAlignment="Top" Height="30" Width="85" FontSize="14"/>
        <Label Content="键盘配置" HorizontalAlignment="Left" Margin="694,0,0,0" VerticalAlignment="Center" Height="34" Width="96" FontSize="14"/>
        <Controls:InputTextBox HorizontalAlignment="Left" Margin="823,104,0,0" TextWrapping="Wrap" Text="{Binding functionParameter.SpindleIdlingTime}" VerticalAlignment="Top" Width="202" Height="51" FontSize="14"/>
        <Label Content="Min" HorizontalAlignment="Left" Margin="1048,99,0,0" VerticalAlignment="Top" Height="62" Width="54" FontSize="14"/>
        <Controls:InputTextBox HorizontalAlignment="Left" Margin="823,199,0,0" TextWrapping="Wrap" Text="{Binding functionParameter.DefaultUnit}" VerticalAlignment="Top" Width="202" Height="52" FontSize="14"/>
        <Controls:InputTextBox HorizontalAlignment="Left" Margin="823,305,0,0" TextWrapping="Wrap" Text="{Binding functionParameter.LayoutOfKeyboard}" VerticalAlignment="Top" Width="202" Height="51" FontSize="14"/>
        <Button Content="保存" HorizontalAlignment="Left" Margin="600,39,0,0" VerticalAlignment="Top" Height="31" Width="73" Click="Button_Click"/>
    </Grid>
</Page>
