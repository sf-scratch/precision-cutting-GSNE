                HorizontalAlignment="Left"
                ChildMargin="5"
                Columns="3*,*,3*,*"
                RowCount="10">
                <Label Content="切割结束关水/不关水" />
                <CheckBox
                    x:Name="cutWaterStatus"
                    Grid.ColumnSpan="3"
                    d:IsChecked="False"
                    IsChecked="{Binding IsAutoShutOffWaterWhenCuttingCompleted}">
                    <TextBlock Text="{Binding ElementName=cutWaterStatus, Path=IsChecked, Converter={StaticResource BoolToStringConverter}}" />
                </CheckBox>
                <auto:AutoGrid
                    Grid.RowSpan="3"
                    Grid.ColumnSpan="2"
                    ChildMargin="0,7"
                    Columns="3*,*"
                    RowCount="3"
                    Visibility="{Binding ElementName=cutWaterStatus, Path=IsChecked, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Label Content="- 在关闭真空时自动关水" />
                    <CheckBox x:Name="autoShutOffWaterWhenCloseVacuum" IsChecked="{Binding IsAutoShutOffWaterWhenCloseVacuum}">
