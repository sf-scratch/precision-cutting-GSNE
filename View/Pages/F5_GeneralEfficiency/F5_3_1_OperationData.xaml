                    </CheckBox>
                    <Label Content="- 在进入校准模式时自动关水" />
                    <CheckBox x:Name="autoShutOffWaterWhenEnterCalibration" IsChecked="{Binding IsAutoShutOffWaterWhenEnterCalibration}">
                        <TextBlock Text="{Binding ElementName=autoShutOffWaterWhenEnterCalibration, Path=IsChecked, Converter={StaticResource BoolToStringConverter}}" />
                    </CheckBox>
                    <Label Content="- 使用者手动关水" />
                    <CheckBox x:Name="manuallyTurnOffWater" IsChecked="{Binding IsManuallyTurnOffWater}">
                        <TextBlock Text="{Binding ElementName=manuallyTurnOffWater, Path=IsChecked, Converter={StaticResource BoolToStringConverter}}" />
                    </CheckBox>
                </auto:AutoGrid>
            </auto:AutoGrid>
