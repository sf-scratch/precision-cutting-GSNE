<Page
    x:Class="精密切割系统.View.Pages.F5_3_1_FunctionData"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
    xmlns:Converters="clr-namespace:精密切割系统.Converters"
    xmlns:auto="clr-namespace:WpfAutoGrid;assembly=WpfAutoGrid.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:精密切割系统.Helpers"
    xmlns:local="clr-namespace:精密切割系统.ViewModel"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="F5_3_1_FunctionData"
    d:DataContext="{d:DesignInstance local:F5_3_1_OperationDataViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="645"
    d:DesignWidth="1560"
    Loaded="Page_Loaded"
    mc:Ignorable="d">
    <Page.Resources>
        <Converters:BoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" IsInverse="True" />
        <Converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <Style TargetType="Label">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style BasedOn="{StaticResource MaterialDesignFilterChipSecondaryCheckBox}" TargetType="CheckBox">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style BasedOn="{StaticResource InputTextStyle}" TargetType="Controls:InputTextBox">
            <Setter Property="InputType" Value="Decimal" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="XPrecision" Value="3" />
        </Style>
        <Converters:BoolToValueConverter
            x:Key="BoolToStringConverter"
            FalseValue="不关水"
            TrueValue="关水" />
        <Converters:BoolToValueConverter
            x:Key="BoolToOpenOrCloseConverter"
            FalseValue="关闭"
            TrueValue="开启" />
    </Page.Resources>
    <Page.DataContext>
        <local:F5_3_1_OperationDataViewModel />
    </Page.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition Height="260" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <!--  原5.3.1  -->
        <Label
            x:Name="lbParamForm"
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            Margin="30,30,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="功能参数维护 (4.1)"
            FontSize="30"
            FontWeight="Bold" />
        <StackPanel
            x:Name="sp1"
            Grid.Row="1"
            Grid.Column="0"
            Margin="30,5,0,0">
            <Label
                x:Name="lbSmSuDu"
                Content="扫描速度"
                FontSize="22"
                FontWeight="Bold" />

            <auto:AutoGrid
                Grid.RowSpan="8"
                Width="700"
                HorizontalAlignment="Left"
                ChildMargin="5"
                Columns="60,auto,*,auto,auto,*,auto,*,auto"
                RowCount="10">
                <Label Content="X轴" />
                <Label Content="高速" />
                <Controls:InputTextBox Text="{Binding Path=XScanSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Label HorizontalAlignment="Left" Content="mm/s" />
                <Label Content="低速" />
                <Controls:InputTextBox Text="{Binding Path=XScanSlowSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Label HorizontalAlignment="Left" Content="mm/s" />
                <Controls:InputTextBox Text="{Binding Path=XSscanDistance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" XPrecision="4" />
                <Label HorizontalAlignment="Left" Content="mm" />
                <Label Content="Y轴" />
                <Label Content="高速" />
                <Controls:InputTextBox Text="{Binding Path=YScanSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Label HorizontalAlignment="Left" Content="mm/s" />
                <Label Content="低速" />
                <Controls:InputTextBox Text="{Binding Path=YScanSlowSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Label HorizontalAlignment="Left" Content="mm/s" />
                <Controls:InputTextBox Text="{Binding Path=YSscanDistance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" XPrecision="4" />
                <Label HorizontalAlignment="Left" Content="mm" />
                <Label Content="Z1轴" />
                <Label Content="高速" />
                <Controls:InputTextBox Text="{Binding Path=ZScanSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Label HorizontalAlignment="Left" Content="mm/s" />
                <Label Content="低速" />
                <Controls:InputTextBox Text="{Binding Path=ZScanSlowSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Label HorizontalAlignment="Left" Content="mm/s" />
                <Controls:InputTextBox Text="{Binding Path=ZSscanDistance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" XPrecision="4" />
                <Label HorizontalAlignment="Left" Content="mm" />
                <Label Content="Z2轴" />
                <Label Content="高速" />
                <Controls:InputTextBox Text="{Binding Path=Z2ScanSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Label HorizontalAlignment="Left" Content="mm/s" />
                <Label Content="低速" />
                <Controls:InputTextBox Text="{Binding Path=Z2ScanSlowSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Label HorizontalAlignment="Left" Content="mm/s" />
                <Controls:InputTextBox Text="{Binding Path=Z2SscanDistance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" XPrecision="4" />
                <Label HorizontalAlignment="Left" Content="mm" />
                <Label Content="θ轴" Visibility="{Binding Source={x:Static helpers:GlobalParams.HasTheta}, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Label Content="高速" Visibility="{Binding Source={x:Static helpers:GlobalParams.HasTheta}, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Controls:InputTextBox Text="{Binding Path=RScanSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Visibility="{Binding Source={x:Static helpers:GlobalParams.HasTheta}, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Label
                    HorizontalAlignment="Left"
                    Content="mm/s"
                    Visibility="{Binding Source={x:Static helpers:GlobalParams.HasTheta}, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Label Content="低速" Visibility="{Binding Source={x:Static helpers:GlobalParams.HasTheta}, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Controls:InputTextBox Text="{Binding Path=ThetaScanSlowSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Visibility="{Binding Source={x:Static helpers:GlobalParams.HasTheta}, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Label
                    HorizontalAlignment="Left"
                    Content="mm/s"
                    Visibility="{Binding Source={x:Static helpers:GlobalParams.HasTheta}, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Controls:InputTextBox
                    Text="{Binding Path=RSscanDistance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Visibility="{Binding Source={x:Static helpers:GlobalParams.HasTheta}, Converter={StaticResource BoolToVisibilityConverter}}"
                    XPrecision="4" />
                <Label
                    HorizontalAlignment="Left"
                    Content="mm"
                    Visibility="{Binding Source={x:Static helpers:GlobalParams.HasTheta}, Converter={StaticResource BoolToVisibilityConverter}}" />
            </auto:AutoGrid>
            <StackPanel
                Margin="0,5,0,0"
                Orientation="Horizontal"
                Visibility="Collapsed">
                <Label
                    Width="100"
                    Height="35"
                    Content="容许余量"
                    FontSize="16"
                    FontWeight="Bold" />
                <Controls:InputTextBox
                    Width="150"
                    Height="35"
                    InputType="Decimal"
                    Text="{Binding Path=EscapeRate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    TextWrapping="Wrap"
                    XAllowNull="False"
                    XMax="1"
                    XMin="0"
                    XPrecision="3" />
                <Label
                    Width="80"
                    Height="35"
                    Content="mm"
                    FontSize="16"
                    FontWeight="Bold" />
                <Label
                    Width="80"
                    Height="35"
                    Content="额外余量"
                    FontSize="16"
                    FontWeight="Bold" />
                <Controls:InputTextBox
                    Width="150"
                    Height="35"
                    InputType="Decimal"
                    Text="{Binding Path=ExtraEscapeRate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    TextWrapping="Wrap"
                    XAllowNull="False"
                    XMax="1"
                    XMin="0"
                    XPrecision="3" />
                <Label
                    Width="60"
                    Height="35"
                    Content="mm"
                    FontSize="16"
                    FontWeight="Bold" />
            </StackPanel>
            <StackPanel
                Margin="0,5,0,0"
                Orientation="Horizontal"
                Visibility="Collapsed">
                <Label
                    x:Name="lbZhuzdl"
                    Width="556"
                    Height="35"
                    Content="主轴负载电流"
                    FontSize="16"
                    FontWeight="Bold" />
            </StackPanel>
            <StackPanel
                Margin="0,5,0,0"
                Orientation="Horizontal"
                Visibility="Collapsed">
                <Label
                    Width="100"
                    Height="35"
                    Content="停止操作"
                    FontSize="16"
                    FontWeight="Bold" />
                <Controls:InputTextBox
                    Width="150"
                    Height="35"
                    InputType="Decimal"
                    Text="{Binding Path=MStopElectrical, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    TextWrapping="Wrap"
                    XAllowNull="False"
                    XMax="1"
                    XMin="0"
                    XPrecision="3" />
                <Label
                    Width="160"
                    Height="35"
                    Content="A"
                    FontSize="16"
                    FontWeight="Bold" />
                <Controls:InputTextBox
                    Width="150"
                    Height="35"
                    InputType="Decimal"
                    Text="{Binding Path=MStopTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    TextWrapping="Wrap"
                    XAllowNull="False"
                    XMax="1"
                    XMin="0"
                    XPrecision="1" />
                <Label
                    Width="60"
                    Height="35"
                    Content="s"
                    FontSize="16"
                    FontWeight="Bold" />
            </StackPanel>
            <StackPanel
                Margin="0,5,0,0"
                Orientation="Horizontal"
                Visibility="Collapsed">
                <Label
                    Width="100"
                    Height="35"
                    Content="Z-EM操作"
                    FontSize="16"
                    FontWeight="Bold" />
                <Controls:InputTextBox
                    Width="150"
                    Height="35"
                    InputType="Decimal"
                    Text="{Binding Path=ZStopElectrical, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    TextWrapping="Wrap"
                    XAllowNull="False"
                    XMax="1"
                    XMin="0"
                    XPrecision="3" />
                <Label
                    Width="160"
                    Height="35"
                    Content="A"
                    FontSize="16"
                    FontWeight="Bold" />
                <Controls:InputTextBox
                    Width="150"
                    Height="35"
                    InputType="Decimal"
                    Text="{Binding Path=ZStopTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    TextWrapping="Wrap"
                    XAllowNull="False"
                    XMax="1"
                    XMin="0"
                    XPrecision="1" />
                <Label
                    Width="60"
                    Height="35"
                    Content="s"
                    FontSize="16"
                    FontWeight="Bold" />
            </StackPanel>
        </StackPanel>
        <Grid
            Grid.Row="1"
            Grid.Column="1"
            Margin="30,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="335" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <Label
                    Height="35"
                    Content="默认操作设置"
                    FontSize="22"
                    FontWeight="Bold" />
                <auto:AutoGrid
                    Grid.RowSpan="8"
                    ChildMargin="5"
                    Columns="*,auto"
                    RowCount="10">
                    <Label Content="切割结束关水/不关水" />
                    <CheckBox
                        x:Name="cutWaterStatus"
                        d:IsChecked="False"
                        IsChecked="{Binding IsAutoShutOffWaterWhenCuttingCompleted}">
                        <TextBlock Text="{Binding ElementName=cutWaterStatus, Path=IsChecked, Converter={StaticResource BoolToStringConverter}}" />
                    </CheckBox>
                    <auto:AutoGrid
                        Grid.ColumnSpan="2"
                        ChildMargin="0,7"
                        Columns="3*,*"
                        RowCount="3"
                        Visibility="{Binding ElementName=cutWaterStatus, Path=IsChecked, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <Label Content="- 在关闭真空时自动关水" />
                        <CheckBox x:Name="autoShutOffWaterWhenCloseVacuum" IsChecked="{Binding IsAutoShutOffWaterWhenCloseVacuum}">
                            <TextBlock Text="{Binding ElementName=autoShutOffWaterWhenCloseVacuum, Path=IsChecked, Converter={StaticResource BoolToStringConverter}}" />
                        </CheckBox>
                        <Label Content="- 在进入校准模式时自动关水" />
                        <CheckBox x:Name="autoShutOffWaterWhenEnterCalibration" IsChecked="{Binding IsAutoShutOffWaterWhenEnterCalibration}">
                            <TextBlock Text="{Binding ElementName=autoShutOffWaterWhenEnterCalibration, Path=IsChecked, Converter={StaticResource BoolToStringConverter}}" />
                        </CheckBox>
                        <Label Content="- 使用者手动关水" />
                        <CheckBox x:Name="manuallyTurnOffWater" IsChecked="{Binding IsManuallyTurnOffWater}">
                            <TextBlock Text="{Binding ElementName=manuallyTurnOffWater, Path=IsChecked, Converter={StaticResource BoolToStringConverter}}" />
                        </CheckBox>
                    </auto:AutoGrid>
                </auto:AutoGrid>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="30,0,0,0">
                <Label
                    Height="35"
                    Content=""
                    FontSize="22"
                    FontWeight="Bold" />
                <auto:AutoGrid
                    ChildMargin="0,7"
                    Columns="auto,*"
                    RowCount="10">
                    <Label Content="退出当前切割模式时手动补偿值清零" />
                    <CheckBox
                        x:Name="ExitCutClearManualCompensation"
                        d:IsChecked="False"
                        IsChecked="{Binding IsExitCutClearManualCompensation}">
                        <TextBlock Text="{Binding ElementName=ExitCutClearManualCompensation, Path=IsChecked, Converter={StaticResource BoolToOpenOrCloseConverter}}" />
                    </CheckBox>
                    <Label Content="更换型号参数时手动补偿值清零" />
                    <CheckBox
                        x:Name="UpdateParamClearManualCompensation"
                        d:IsChecked="False"
                        IsChecked="{Binding IsUpdateParamClearManualCompensation}">
                        <TextBlock Text="{Binding ElementName=UpdateParamClearManualCompensation, Path=IsChecked, Converter={StaticResource BoolToOpenOrCloseConverter}}" />
                    </CheckBox>
                    <Label Content="执行换刀后需默认启动预切割" />
                    <CheckBox
                        x:Name="StartPreCuttingAfterChangeBlade"
                        d:IsChecked="False"
                        IsChecked="{Binding IsStartPreCuttingAfterChangeBlade}">
                        <TextBlock Text="{Binding ElementName=StartPreCuttingAfterChangeBlade, Path=IsChecked, Converter={StaticResource BoolToOpenOrCloseConverter}}" />
                    </CheckBox>
                    <Label Content="手动校准每个面必须校准" />
                    <CheckBox
                        x:Name="MustCalibrated"
                        d:IsChecked="False"
                        IsChecked="{Binding IsMustCalibrated}">
                        <TextBlock Text="{Binding ElementName=MustCalibrated, Path=IsChecked, Converter={StaticResource BoolToOpenOrCloseConverter}}" />
                    </CheckBox>
                </auto:AutoGrid>
            </StackPanel>
        </Grid>
        <StackPanel
            Grid.Row="1"
            Grid.Column="1"
            Margin="30,5,0,0"
            HorizontalAlignment="Left"
            Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <Label
                    Width="220"
                    Height="35"
                    Content="ZEM完成后切割开始位置"
                    FontSize="16"
                    FontWeight="Bold" />
                <ComboBox
                    Name="cbxZStopAfterSeq"
                    Width="130"
                    Height="35"
                    VerticalContentAlignment="Center">
                    <ComboBoxItem
                        Height="30"
                        Content="下一刀"
                        Tag="下一刀" />
                    <ComboBoxItem
                        Height="30"
                        Content="同一刀"
                        Tag="同一刀" />
                </ComboBox>
            </StackPanel>
            <StackPanel Margin="50,0,0,0">
                <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                    <Label
                        x:Name="lbZhuzsdl"
                        Width="220"
                        Height="35"
                        Content="切割余量"
                        FontSize="16"
                        FontWeight="Bold" />
                </StackPanel>
                <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                    <Label
                        Width="150"
                        Height="35"
                        Content="X轴开始方向"
                        FontSize="16"
                        FontWeight="Bold" />
                    <Controls:InputTextBox
                        Width="150"
                        Height="35"
                        InputType="Decimal"
                        Text="{Binding Path=XStartClearance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap"
                        XAllowNull="False"
                        XMin="0"
                        XPrecision="3" />
                    <Label
                        Width="100"
                        Height="35"
                        Content="mm"
                        FontSize="16"
                        FontWeight="Bold" />
                </StackPanel>
                <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                    <Label
                        Width="150"
                        Height="35"
                        Content="X轴停止方向"
                        FontSize="16"
                        FontWeight="Bold" />
                    <Controls:InputTextBox
                        Width="150"
                        Height="35"
                        InputType="Decimal"
                        Text="{Binding Path=XEndClearance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap"
                        XAllowNull="False"
                        XMin="0"
                        XPrecision="3" />
                    <Label
                        Width="100"
                        Height="35"
                        Content="mm"
                        FontSize="16"
                        FontWeight="Bold" />
                </StackPanel>
                <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                    <Label
                        Width="150"
                        Height="35"
                        Content="Y轴"
                        FontSize="16"
                        FontWeight="Bold" />
                    <Controls:InputTextBox
                        Width="150"
                        Height="35"
                        InputType="Decimal"
                        Text="{Binding Path=YClearance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap"
                        XAllowNull="False"
                        XMin="0"
                        XPrecision="3" />
                    <Label
                        Width="100"
                        Height="35"
                        Content="mm"
                        FontSize="16"
                        FontWeight="Bold" />
                </StackPanel>
                <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                    <Label
                        Width="150"
                        Height="35"
                        Content="强制检查厚度"
                        FontSize="16"
                        FontWeight="Bold" />
                    <Controls:InputTextBox
                        Width="150"
                        Height="35"
                        InputType="Decimal"
                        Text="{Binding Path=AutoFocusCheckLimit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap"
                        XAllowNull="False"
                        XMin="0"
                        XPrecision="3" />
                    <Label
                        Width="100"
                        Height="35"
                        Content="mm"
                        FontSize="16"
                        FontWeight="Bold" />
                </StackPanel>

                <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                    <Label
                        Width="150"
                        Height="35"
                        Content="吹气动作"
                        FontSize="16"
                        FontWeight="Bold" />
                    <Controls:InputTextBox
                        Width="150"
                        Height="35"
                        InputType="Decimal"
                        Text="{Binding Path=AirCurtainStroke, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap"
                        XAllowNull="False"
                        XMin="0"
                        XPrecision="3" />
                    <Label
                        Width="100"
                        Height="35"
                        Content="mm"
                        FontSize="16"
                        FontWeight="Bold" />
                </StackPanel>
                <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                    <Label
                        Width="150"
                        Height="35"
                        Content="工作真空下限"
                        FontSize="16"
                        FontWeight="Bold" />
                    <Controls:InputTextBox
                        Width="150"
                        Height="35"
                        InputType="Decimal"
                        Text="{Binding Path=VaccumWorkLowerLimit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap"
                        XAllowNull="False"
                        XMax="1"
                        XMin="-200"
                        XPrecision="1" />
                    <Label
                        Width="100"
                        Height="35"
                        Content="Kpa"
                        FontSize="16"
                        FontWeight="Bold" />
                </StackPanel>
                <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                    <Label
                        Width="150"
                        Height="35"
                        Content="夹具真空下限"
                        FontSize="16"
                        FontWeight="Bold" />
                    <Controls:InputTextBox
                        Width="150"
                        Height="35"
                        InputType="Decimal"
                        Text="{Binding Path=VaccumPumpLowerLimitOther, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap"
                        XAllowNull="False"
                        XMax="1"
                        XMin="-200"
                        XPrecision="1" />
                    <Label
                        Width="100"
                        Height="35"
                        Content="Kpa"
                        FontSize="16"
                        FontWeight="Bold" />
                </StackPanel>
                <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                    <Label
                        Width="150"
                        Height="35"
                        Content="切割过程"
                        FontSize="16"
                        FontWeight="Bold" />
                    <Controls:InputTextBox
                        Width="150"
                        Height="35"
                        InputType="Decimal"
                        Text="{Binding Path=LimitDuringCutting, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap"
                        XAllowNull="False"
                        XMax="1"
                        XMin="-200"
                        XPrecision="1" />
                    <Label
                        Width="100"
                        Height="35"
                        Content="Kpa"
                        FontSize="16"
                        FontWeight="Bold" />
                </StackPanel>
                <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                    <Label
                        Width="150"
                        Height="35"
                        Content="真空泵下限"
                        FontSize="16"
                        FontWeight="Bold" />
                    <Controls:InputTextBox
                        Width="150"
                        Height="35"
                        InputType="Decimal"
                        Text="{Binding Path=VaccumPumpLowerLimit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap"
                        XAllowNull="False"
                        XMax="1"
                        XMin="-200"
                        XPrecision="1" />
                    <Label
                        Width="100"
                        Height="35"
                        Content="Kpa"
                        FontSize="16"
                        FontWeight="Bold" />
                </StackPanel>
            </StackPanel>
        </StackPanel>
        <StackPanel
            Grid.Row="2"
            Grid.ColumnSpan="2"
            Margin="0,5,0,0">
            <Label
                Height="35"
                Margin="30,5,0,0"
                Content="轴设置"
                FontSize="22"
                FontWeight="Bold" />
            <auto:AutoGrid
                Grid.RowSpan="8"
                Width="1100"
                Margin="30,0,0,0"
                HorizontalAlignment="Left"
                ChildMargin="5"
                Columns="60,120,*,*,120,*,*,100,*,*"
                RowCount="10">
                <Label Content="X轴" />
                <Label Content="正限位位置" />
                <Controls:InputTextBox x:Name="PositiveLimitPositionX" Text="{Binding Path=PositiveLimitPositionX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Label HorizontalAlignment="Left" Content="mm" />
                <Label Content="负限位位置" />
                <Controls:InputTextBox x:Name="NegativeLimitPositionX" Text="{Binding Path=NegativeLimitPositionX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Label HorizontalAlignment="Left" Content="mm" />
                <Label Content="原点补偿" />
                <Controls:InputTextBox Text="{Binding Path=OriginCompensationX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Label HorizontalAlignment="Left" Content="mm" />
                <Label Content="Y轴" />
                <Label Content="正限位位置" />
                <Controls:InputTextBox x:Name="PositiveLimitPositionY" Text="{Binding Path=PositiveLimitPositionY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Label HorizontalAlignment="Left" Content="mm" />
                <Label Content="负限位位置" />
                <Controls:InputTextBox x:Name="NegativeLimitPositionY" Text="{Binding Path=NegativeLimitPositionY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Label HorizontalAlignment="Left" Content="mm" />
                <Label Content="原点补偿" />
                <Controls:InputTextBox Text="{Binding Path=OriginCompensationY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Label HorizontalAlignment="Left" Content="mm" />
                <Label Content="Z1轴" />
                <Label Content="正限位位置" />
                <Controls:InputTextBox x:Name="PositiveLimitPositionZ1" Text="{Binding Path=PositiveLimitPositionZ1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Label HorizontalAlignment="Left" Content="mm" />
                <Label Content="负限位位置" />
                <Controls:InputTextBox x:Name="NegativeLimitPositionZ1" Text="{Binding Path=NegativeLimitPositionZ1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Label HorizontalAlignment="Left" Content="mm" />
                <Label Content="原点补偿" />
                <Controls:InputTextBox Text="{Binding Path=OriginCompensationZ1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Label HorizontalAlignment="Left" Content="mm" />
                <Label Content="Z2轴" />
                <Label Content="正限位位置" />
                <Controls:InputTextBox x:Name="PositiveLimitPositionZ2" Text="{Binding Path=PositiveLimitPositionZ2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Label HorizontalAlignment="Left" Content="mm" />
                <Label Content="负限位位置" />
