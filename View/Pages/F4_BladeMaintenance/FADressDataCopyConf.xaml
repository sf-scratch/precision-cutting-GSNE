<Page x:Class="精密切割系统.View.Pages.F4_BladeMaintenance.FADressDataCopyConf"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
      xmlns:local="clr-namespace:精密切割系统.View.Pages.F4_BladeMaintenance"
      mc:Ignorable="d" 
      d:DesignHeight="676" d:DesignWidth="1448"
      Title="FADressDataCopyConf" Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="auto"/>
        </Grid.ColumnDefinitions>
        <!--磨刀参数拷贝 -->
        <Label x:Name="labParameterCopy" Content="磨刀参数拷贝" Margin="30,30,0,0" Grid.Row="0"  Grid.Column="0" Grid.ColumnSpan="2" FontSize="30" FontWeight="Bold"/>
        <StackPanel Grid.Row="1" Grid.Column="0" x:Name="sp1" HorizontalAlignment="Center">

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"  Margin="0,30,0,0">
                <Label Width="140" Height="35"  x:Name="labSourceParameterNo" Content="被拷贝的参数号" FontWeight="Bold" FontSize="16"/>
                <Controls:InputTextBox x:Name="tbSourceParameterNo" Width="160" TextWrapping="Wrap" Height="35" InputType="Numeral" XMin="0" XAllowNull="False" IsEnabled="False"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"  Margin="0,30,0,0">
                <Label Width="140" Height="35"  x:Name="labTargetParameterNo" Content="拷贝成参数号" FontWeight="Bold" FontSize="16"/>
                <Controls:InputTextBox x:Name="tbTargetParameterNo" Width="160" TextWrapping="Wrap" Height="35" InputType="Numeral" XMin="1" XAllowNull="False"/>
            </StackPanel>
            <Label  Height="35"  x:Name="labParameterRemark" Content="表示的是被拷贝对象的磨刀参数号" Margin="0,20,0,0" FontWeight="Bold" FontSize="16" HorizontalContentAlignment="Center"/>
            <Label  Height="35"  x:Name="labParameterEnter" Content="输入磨刀参数号后、请按确定键" FontWeight="Bold" FontSize="16" HorizontalContentAlignment="Center"/>

        </StackPanel>
    </Grid>
</Page>
