<Page x:Class="精密切割系统.View.Pages.F4_BladeMaintenance.BmSharpenParameter"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:Controls="clr-namespace:精密切割系统.View.Controls" 
      xmlns:local="clr-namespace:精密切割系统.View.Pages.F4_BladeMaintenance"
      mc:Ignorable="d" 
      d:DesignHeight="676" d:DesignWidth="1448"
      Title="BmSharpenParameter" Loaded="Page_Loaded">

    <Grid >
        <Grid.RowDefinitions >
            <RowDefinition Height="80"/>
            <RowDefinition Height="50"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Label x:Name="lbMdParamList" Content="磨刀参数清单 (3.3)" VerticalAlignment="Center" HorizontalAlignment="Left" Grid.Row="0" Grid.Column="0"  FontWeight="Bold" FontSize="30" Margin="30,30,0,0"/>
        <Grid Grid.Row="1" Grid.Column="0" Margin="30,10,30,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" HorizontalAlignment="Left" >
                <Label  Content="磨刀参数号" FontSize="18" Width="200" Height="35" FontWeight="Bold"  />
            </StackPanel>
            <StackPanel Grid.Column="1" HorizontalAlignment="Right" >
                <Controls:InputTextBox x:Name="labParameterNo"  Width="190" Height="35" InputType="Numeral" XMin="0" XPrecision="0" XWmkText="输入参数号可快捷操作" />
            </StackPanel>
        </Grid>
        <ListView x:Name="pre_listView" Grid.Row="2" Grid.Column="0"  ItemsSource="{Binding Col0_99}" Margin="30,5,30,20" SelectionChanged="pre_listView_SelectionChanged" >
            <ListView.ItemContainerStyle>
                <Style TargetType="{x:Type ListViewItem}">
                    <Setter Property="Height" Value="50"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter Property="Background" Value="Transparent"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="true">
                            <Setter Property="Background" Value="#CBE5ED"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.View>
                <GridView>
                    <GridView.ColumnHeaderContainerStyle>
                        <Style TargetType="GridViewColumnHeader">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </Style>
                    </GridView.ColumnHeaderContainerStyle>
                    <!-- DisplayMemberBinding="{Binding Id}" ,CellTemplate 绑定数据方式二选一 DisplayMemberBinding="{Binding BladeLotID}" Width="80" -->
                    <GridViewColumn >
                        <!-- <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <Label Height="40" Width="850" Content="磨刀号" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate> -->
                         <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel  Height="40" Orientation="Horizontal">
                                    <Label  Content="{Binding BladeLotID}" FontSize="18"  VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate> 
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Page>
