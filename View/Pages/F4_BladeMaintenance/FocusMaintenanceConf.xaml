<Page
    x:Class="精密切割系统.View.Pages.F4_BladeMaintenance.FocusMaintenanceConf"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
    xmlns:common="clr-namespace:精密切割系统.View.Pages.common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:精密切割系统.View.Pages.F4_BladeMaintenance"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="FocusMaintenanceConf"
    d:DesignHeight="655"
    d:DesignWidth="1570"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50*" />
            <ColumnDefinition Width="50*" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <common:CameraCommon Width="765" Height="640" />
        </Grid>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel>
                <Grid>
                    <Label
                        Margin="30,30,0,0"
                        Content="对焦点维护 (4.5)"
                        FontSize="30"
                        FontWeight="Bold" />
                </Grid>
                <Grid x:Name="thetaCenterParamsGrid">
                    <StackPanel Margin="30,30,0,0">
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                            <Label
                                Width="200"
                                Content="对焦点维护位置"
                                FontSize="18"
                                FontWeight="Bold" />
                            <Controls:InputTextBox
                                x:Name="focusSetPostion"
                                Width="200"
                                InputType="Decimal"
                                IsReadOnly="True"
                                TextWrapping="Wrap"
                                XPrecision="5" />
                        </StackPanel>
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                            <Label
                                Width="200"
                                Content="当前相机高度"
                                FontSize="18"
                                FontWeight="Bold" />
                            <Controls:InputTextBox
                                x:Name="z2AbsolutePosition"
                                Width="200"
                                InputType="Decimal"
                                IsReadOnly="True"
                                TextWrapping="Wrap"
                                XPrecision="5" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
                <Grid x:Name="dimmingGrid" Margin="30,40,0,0">
                    <common:CommonDimming />
                </Grid>
            </StackPanel>
            <Grid
                x:Name="directionGrid"
                Grid.Row="1"
                Margin="0,30,60,60">
                <common:SimpleDirectOperate />
            </Grid>
        </Grid>
    </Grid>
</Page>