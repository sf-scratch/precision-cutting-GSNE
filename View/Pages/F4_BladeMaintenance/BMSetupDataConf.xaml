    xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
    xmlns:auto="clr-namespace:WpfAutoGrid;assembly=WpfAutoGrid.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:精密切割系统.ViewModel"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="BMSetupDataConf"
    d:DesignHeight="676"
    d:DesignWidth="1448"
    Loaded="Page_Loaded"
    mc:Ignorable="d">

    <Page.DataContext>
        <local:BladeHeightViewModel />
    </Page.DataContext>
    <Grid Margin="30,30,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Label
            x:Name="labCgcsHeader"
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="测高参数(3.4)"
            FontSize="22"
            FontWeight="Bold" />
        <auto:AutoGrid
            Grid.Row="1"
            Margin="20"
            ChildMargin="5"
            Columns="3*,2*,*"
            RowCount="10">
            <Label
                Height="35"
                Content="旋转轴转速"
                FontSize="16"
                FontWeight="Bold" />
            <Controls:InputTextBox
                x:Name="spindleRev"
                Width="200"
                Height="35"
                InputType="Numeral"
                MaxLength="20"
                TextWrapping="Wrap" />
            <Label
                Height="35"
                Content="/min"
                FontSize="16"
                FontWeight="Bold" />
            <Label
                Height="35"
                Content="测高次数"
                FontSize="16"
                FontWeight="Bold" />
            <Controls:InputTextBox
                x:Name="heightMeasureTimes"
                Width="200"
                Height="35"
                InputType="Numeral"
                MaxLength="20"
                TextWrapping="Wrap"
                XMax="20" />
            <Label
                Height="35"
                Content="次"
                FontSize="16"
                FontWeight="Bold" />
            <Label
                Height="35"
                Content="每次切割前测高"
                FontSize="16"
                FontWeight="Bold" />
            <CheckBox
                x:Name="isAutomHeightMeasureBeforeCutting"
                Grid.ColumnSpan="2"
                Content="自动测高"
                IsChecked="True"
                Style="{StaticResource MaterialDesignFilterChipCheckBox}" />
        </auto:AutoGrid>
