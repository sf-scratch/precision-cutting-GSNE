        <StackPanel
            Grid.Row="1"
            Grid.Column="1"
            Orientation="Vertical">
            <Label
                Margin="10"
                Content="测高信息"
                FontSize="22" />
            <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                <Label
                    Width="130"
                    Margin="30,0,0,0"
                    Content="当前一次" />
                <Controls:InputTextBox IsEnabled="False" Text="{Binding CurrentMeasureValue}" />
                <Label Content="mm" FontSize="18" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label
                    Width="100"
                    Margin="30,0,0,0"
                    VerticalAlignment="Top"
                    Content="历史记录" />
                <ListBox d:ItemsSource="{d:SampleData}" ItemsSource="{Binding BladeMeasureList}">
                    <ListBox.ItemContainerStyle>
                        <Style BasedOn="{StaticResource MaterialDesignListBoxItem}" TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="0,0,0,1" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="materialDesign:ListBoxItemAssist.ShowSelection" Value="False" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                                <Label
                                    Width="30"
                                    Margin="0,0,0,0"
                                    Content="{Binding FieldName}"
                                    FontSize="18"
                                    FontWeight="Bold" />
                                <Controls:InputTextBox IsEnabled="False" Text="{Binding FieldValue}" />
                                <Label Content="mm" FontSize="18" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </StackPanel>
        <Controls:RealTimeInfoBox
            x:Name="RealTimeInfo"
            Grid.Row="1"
            Grid.Column="2"
            Width="400"
            Margin="50,0,0,20" />
    </Grid>
</Page>