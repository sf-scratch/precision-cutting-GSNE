<Page
    x:Class="精密切割系统.View.Pages.F4_BladeMaintenance.BMSetupDataConf"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
    xmlns:Converters="clr-namespace:精密切割系统.Converters"
    xmlns:auto="clr-namespace:WpfAutoGrid;assembly=WpfAutoGrid.Core"
    xmlns:convert="clr-namespace:精密切割系统.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:精密切割系统.Helpers"
    xmlns:local="clr-namespace:精密切割系统.ViewModel"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:精密切割系统.ViewModel"
    Title="BMSetupDataConf"
    d:DataContext="{d:DesignInstance viewModel:BMSetupDataConfViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="676"
    d:DesignWidth="1448"
    Loaded="Page_Loaded"
    mc:Ignorable="d">

    <Page.DataContext>
        <local:BladeHeightViewModel />
    </Page.DataContext>
    <Page.Resources>
        <convert:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <convert:BoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" IsInverse="True" />
        <convert:BoolToValueConverter
            x:Key="MovingDistanceConverter"
            FalseValue="X轴移动距离"
            TrueValue="θ轴移动角度" />
        <convert:BoolToValueConverter
            x:Key="StartPositionConverter"
            FalseValue="X轴移动开始位置"
            TrueValue="θ轴移动开始位置" />
        <convert:BoolToValueConverter
            x:Key="EndPositionConverter"
            FalseValue="X轴移动结束位置"
            TrueValue="θ轴移动结束位置" />
        <convert:BoolToValueConverter
            x:Key="CurPositionConverter"
            FalseValue="X轴移动当前位置"
            TrueValue="θ轴移动当前位置" />
        <convert:BoolToValueConverter
            x:Key="UnitConverter"
            FalseValue="mm"
            TrueValue="deg" />
    </Page.Resources>
    <Grid Margin="30,30,0,0">
        <Grid.Resources>
            <Style BasedOn="{StaticResource MaterialDesignFilterChipSecondaryCheckBox}" TargetType="CheckBox">
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontWeight" Value="Bold" />
            </Style>
            <Converters:BoolToValueConverter
                x:Key="BoolToStringConverter"
                FalseValue="关闭"
                TrueValue="开启" />
            <Style BasedOn="{StaticResource InputTextStyle}" TargetType="Controls:InputTextBox">
                <Setter Property="Width" Value="150" />
                <Setter Property="Height" Value="35" />
                <Setter Property="InputType" Value="Numeral" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>
            <Style TargetType="Label">
                <Setter Property="FontSize" Value="18" />
                <Setter Property="Height" Value="35" />
                <Setter Property="FontWeight" Value="Bold" />
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Label
            x:Name="labCgcsHeader"
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            Height="auto"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="测高(3.3)"
            FontSize="30"
            FontWeight="Bold" />
        <auto:AutoGrid
            Grid.Row="1"
            Margin="20"
            ChildMargin="5"
            Columns="3*,2*,*"
            RowCount="10">
            <Label Content="旋转轴转速" />
            <Controls:InputTextBox
                Text="{Binding BMParameter.SpindleRev}"
                XMax="30000"
                XPrecision="0" />
            <Label Content="/min" />
            <Label Content="刀片外径" />
            <Controls:InputTextBox Text="{Binding BladeOuterDiameter}" />
            <Label Content="mm" />
            <Label Content="测高次数" />
            <Controls:InputTextBox
                Text="{Binding BMParameter.HeightMeasureTimes}"
                TextChanged="heightMeasureTimes_TextChanged"
                XMax="3"
                XPrecision="0" />
            <Label Content="次" />
            <Label Content="{Binding Source={x:Static helpers:GlobalParams.HasTheta}, Converter={StaticResource MovingDistanceConverter}}" />
            <Controls:InputTextBox Text="{Binding BMParameter.ThetaMovementAngle}" XMax="90" />
            <Label Content="{Binding Source={x:Static helpers:GlobalParams.HasTheta}, Converter={StaticResource UnitConverter}}" />
            <Label Content="{Binding Source={x:Static helpers:GlobalParams.HasTheta}, Converter={StaticResource StartPositionConverter}}" />
            <Controls:InputTextBox Text="{Binding BMParameter.ThetaStartingToMovePosition}" IsEnabled="{Binding Source={x:Static helpers:GlobalParams.HasTheta}}" />
            <Label Content="{Binding Source={x:Static helpers:GlobalParams.HasTheta}, Converter={StaticResource UnitConverter}}" />
            <Label Content="{Binding Source={x:Static helpers:GlobalParams.HasTheta}, Converter={StaticResource EndPositionConverter}}" />
            <Controls:InputTextBox Text="{Binding BMParameter.ThetaEndingToMovePosition}" />
            <Label Content="{Binding Source={x:Static helpers:GlobalParams.HasTheta}, Converter={StaticResource UnitConverter}}" />
            <Label Content="{Binding Source={x:Static helpers:GlobalParams.HasTheta}, Converter={StaticResource CurPositionConverter}}" />
            <Controls:InputTextBox Text="{Binding BMParameter.ThetaCurrentLocation}" />
            <Label Content="{Binding Source={x:Static helpers:GlobalParams.HasTheta}, Converter={StaticResource UnitConverter}}" />
            <Label Content="Z1测高极限位置" />
            <Controls:InputTextBox Text="{Binding BladeSetupInitZ1}" />
            <Label Content="mm" />
            <Label Content="每次切割前测高" />
            <CheckBox
                x:Name="isAutomHeightMeasureBeforeCutting"
                Grid.ColumnSpan="2"
                FontSize="18"
                IsChecked="{Binding BMParameter.IsAutomHeightMeasureBeforeCutting}">
                <TextBlock Text="{Binding ElementName=isAutomHeightMeasureBeforeCutting, Path=IsChecked, Converter={StaticResource BoolToStringConverter}}" />
            </CheckBox>
        </auto:AutoGrid>
