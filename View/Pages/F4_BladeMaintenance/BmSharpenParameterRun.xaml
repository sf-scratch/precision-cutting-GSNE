<Page x:Class="精密切割系统.View.Pages.F4_BladeMaintenance.BmSharpenParameterRun"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:精密切割系统.View.Pages.F4_BladeMaintenance"
      xmlns:controls="clr-namespace:精密切割系统.View.Controls"
      xmlns:common="clr-namespace:精密切割系统.View.Pages.common"
      mc:Ignorable="d"
      d:DesignHeight="655" d:DesignWidth="1570"
      Title="BmSharpenParameterRun">
    <Page.Resources>
        <Style TargetType="Label">
            <Setter Property="VerticalAlignment" Value="Center"></Setter>
        </Style>
    </Page.Resources>
    <Grid Loaded="Grid_Loaded">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50*"></ColumnDefinition>
            <ColumnDefinition Width="50*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <Image Source="/Assets/picture/大背景.png" Width="765" Height="640" />
        </Grid>
        <Grid Grid.Column="1">
            <StackPanel>
                <Grid>
                    <Label Margin="30,30,0,0" x:Name="sharpenTitle" Content="磨刀进行状态" FontSize="22" FontWeight="Bold" />
                </Grid>
                <Grid>
                    <StackPanel Margin="30,30,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Label Content="刀片高度" FontSize="18" FontWeight="Bold" Width="170" />
                            <controls:InputTextBox TextWrapping="Wrap" x:Name="bladeHeight" Width="200" IsEnabled="False" />
                            <Label Content="mm"></Label>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Label Content="进刀速度" FontSize="18" FontWeight="Bold" Width="170" />
                            <controls:InputTextBox TextWrapping="Wrap" x:Name="FeedSpeed" IsEnabled="False"
                                                   Width="200" />
                            <Label Content="mm/s"></Label>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Label Content="切割进度" FontSize="18" FontWeight="Bold" Width="170" />
                            <controls:InputTextBox x:Name="currentCutNum" TextWrapping="Wrap" Width="200" IsEnabled="False" />
                            <Label Content=" / "></Label>
                            <controls:InputTextBox x:Name="totalCutNum" TextWrapping="Wrap" Width="200" Margin="0,0,0,0"  IsEnabled="False" />
                        </StackPanel>
                        <Grid x:Name="stopGrid" Margin="0 10 0 0" Visibility="Collapsed">
                            <StackPanel>
                                <Label Content="手动调光" FontSize="18" FontWeight="Bold" Margin="0,20,0,10"></Label>
                                <StackPanel Orientation="Horizontal">
                                    <Label Content="直射" FontSize="16" VerticalAlignment="Center" FontWeight="Bold" />
                                    <controls:InputTextBox x:Name="dirLightRatio" Width="100" Text="100" FontWeight="Bold" Padding="8,0,0,0"></controls:InputTextBox>
                                    <Label Content="%" VerticalAlignment="Center"></Label>
                                    <StackPanel Orientation="Horizontal" Margin="20 0 0 0">
                                        <Button x:Name="subFive" Content="-5%" Width="100" Height="40" Margin="10 0 0 0" Click="SubFive_OnClick" FontSize="18" FontWeight="Bold"></Button>
                                        <Button x:Name="subOne" Content="-1%" Width="100" Margin="10 0 0 0" Click="SubOne_OnClick" FontSize="18" FontWeight="Bold"></Button>
                                        <Button x:Name="addOne" Content="+1%" Width="100" Margin="10 0 0 0" Click="AddOne_OnClick" FontSize="18" FontWeight="Bold"></Button>
                                        <Button x:Name="addFive" Content="+5%" Width="100" Margin="10 0 0 0" Click="AddFive_OnClick" FontSize="18" FontWeight="Bold"></Button>
                                    </StackPanel>
                                </StackPanel>
                                <Grid Margin="0 20" Height="225" Width="600">
                                    <common:SimpleDirectOperate></common:SimpleDirectOperate>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</Page>