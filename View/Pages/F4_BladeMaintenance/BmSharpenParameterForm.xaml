<Page x:Class="精密切割系统.View.Pages.F4_BladeMaintenance.BmSharpenParameterForm"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:Controls="clr-namespace:精密切割系统.View.Controls" 
      xmlns:local="clr-namespace:精密切割系统.View.Pages.F4_BladeMaintenance"
      mc:Ignorable="d" 
      d:DesignHeight="676" d:DesignWidth="1448"
      Title="BmSharpenParameterForm" Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions >
            <RowDefinition Height="80"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Label x:Name="lbParamForm" Margin="30,30,0,0" Content="磨刀程序 (3.3.1)" VerticalAlignment="Center" HorizontalAlignment="Left" Grid.Row="0" Grid.Column="0"  FontWeight="Bold" FontSize="22"/>
        <StackPanel Grid.Row="1" Grid.Column="0" x:Name="sp1" HorizontalAlignment="Left"  Margin="30,0,0,0">
            <StackPanel Orientation="Horizontal" Width="600" HorizontalAlignment="Left" Margin="0,10,0,0">
                <Label x:Name="lbParamLabel" Width="70" Height="35" Content="磨刀号：" FontWeight="Bold" FontSize="16" />
                <Label x:Name="lbBladeLotID" Width="100" Height="35" FontWeight="Bold" FontSize="18" />
            </StackPanel>
            <StackPanel Width="600" Margin="0,0,0,0" Orientation="Horizontal" HorizontalAlignment="Left" Visibility="Hidden" >
                <Label x:Name="labUnit" Width="115" Height="35" Content="单位" FontWeight="Bold" FontSize="16" />
                <RadioButton x:Name="rbMm" Content="mm" FontWeight="Bold" FontSize="18" Height="35" Width="70"  HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="5,0,0,0"/>
                <RadioButton x:Name="rbInch"  Content="inch" FontWeight="Bold" FontSize="18" Height="35"  HorizontalContentAlignment="Center" VerticalContentAlignment="Center"  Width="70" Margin="30,0,0,0" />
            </StackPanel>
            <StackPanel Width="600" Margin="0,10,0,0" Orientation="Horizontal" HorizontalAlignment="Left" >
                <Label x:Name="labRotateSpeed"  Width="120"  Height="35" Content="旋转轴转速" FontWeight="Bold" FontSize="16" />
                <Controls:InputTextBox x:Name="tbRotateSpeed" Width="140"  TextWrapping="Wrap"  Height="35" InputType="Numeral" XMin="0" XPrecision="0"/>
                <Label Height="35" Content="/min" FontWeight="Bold" FontSize="16" />
            </StackPanel>
            <StackPanel Width="600" Margin="0,10,0,0" Orientation="Horizontal" HorizontalAlignment="Left">
                <Label x:Name="labCutMethod"  Width="120"  Height="35" Content="切割方式" FontWeight="Bold" FontSize="16" />
                <!-- cmbCutMethod.Text  取到文本 New -->
                <ComboBox x:Name="cmbCutMethod" Width="140"  Height="35" VerticalContentAlignment="Center" >
                    <ComboBoxItem Content="A" Tag="A" Height="32"/>
                    <ComboBoxItem Content="B" Tag="B" Height="32"/>
                </ComboBox>
            </StackPanel>
            <StackPanel Width="600" Margin="0,10,0,0" Orientation="Horizontal" HorizontalAlignment="Left">
                <Label x:Name="labCutThickness"  Width="120"  Height="35" Content="切割片厚度" FontWeight="Bold" FontSize="16" />
                <Controls:InputTextBox x:Name="tbCutThickness" Width="140"  TextWrapping="Wrap"  Height="35" InputType="Decimal" XMin="0" XPrecision="3" />
                <Label Height="35" Content="mm" FontWeight="Bold" FontSize="14" />
            </StackPanel>
            <StackPanel Width="600" Margin="0,10,0,0" Orientation="Horizontal" HorizontalAlignment="Left">
                <Label x:Name="labCutHeight"  Width="120"  Height="35" Content="刀片高度" FontWeight="Bold" FontSize="16" />
                <Controls:InputTextBox x:Name="tbCutHeight" Width="140"  TextWrapping="Wrap"  Height="35" InputType="Decimal" XMin="0" XPrecision="3"/>
                <Label Height="35" Content="mm" FontWeight="Bold" FontSize="14" />
            </StackPanel>

            <StackPanel Width="620" Margin="0,10,0,0">
                <StackPanel Orientation="Horizontal">
                    <Label x:Name="colHeadName1"  Width="60"  Height="35" Content="序号" FontWeight="Bold" FontSize="16" />
                    <Label x:Name="colHeadName2"  Width="280"  Height="35" Content="进刀速度" FontWeight="Bold" FontSize="16" Margin="10,0,0,0"/>
                    <Label x:Name="colHeadName3"  Width="120"  Height="35" Content="刀" FontWeight="Bold" FontSize="16" Margin="20,0,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                    <Label   Width="60"  Height="35" Content="1" FontWeight="Bold" FontSize="16" />
                    <Controls:InputTextBox x:Name="jdMoCutOneSpeed" Width="200"  TextWrapping="Wrap"  Height="35" InputType="Decimal" XMin="0" XPrecision="3"/>
                    <Label  Width="100"  Height="35" Content="mm/s" FontWeight="Bold" FontSize="16" />
                    <Controls:InputTextBox x:Name="jdMoCutOneNo" Width="120"  TextWrapping="Wrap"  Height="35" InputType="Numeral" XMin="0" XPrecision="0"/>
                    <Label  Width="60"  Height="35" Content="刀" FontWeight="Bold" FontSize="16" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <Label   Width="60"  Height="35" Content="2" FontWeight="Bold" FontSize="16" />
                    <Controls:InputTextBox x:Name="jdMoCutTwoSpeed" Width="200"  TextWrapping="Wrap"  Height="35" InputType="Decimal" XMin="0" XPrecision="3"/>
                    <Label  Width="100"  Height="35" Content="mm/s" FontWeight="Bold" FontSize="16" />
                    <Controls:InputTextBox x:Name="jdMoCutTwoNo" Width="120"  TextWrapping="Wrap"  Height="35" InputType="Numeral" XMin="0" XPrecision="0"/>
                    <Label  Width="60"  Height="35" Content="刀" FontWeight="Bold" FontSize="16" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <Label   Width="60"  Height="35" Content="3" FontWeight="Bold" FontSize="16" />
                    <Controls:InputTextBox x:Name="jdMoCutThreeSpeed" Width="200"  TextWrapping="Wrap"  Height="35" InputType="Decimal" XMin="0" XPrecision="3"/>
                    <Label  Width="100"  Height="35" Content="mm/s" FontWeight="Bold" FontSize="16" />
                    <Controls:InputTextBox x:Name="jdMoCutThreeNo" Width="120"  TextWrapping="Wrap"  Height="35" InputType="Numeral" XMin="0" XPrecision="0"/>
                    <Label  Width="60"  Height="35" Content="刀" FontWeight="Bold" FontSize="16" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <Label   Width="60"  Height="35" Content="4" FontWeight="Bold" FontSize="16" />
                    <Controls:InputTextBox x:Name="jdMoCutFourSpeed" Width="200"  TextWrapping="Wrap"  Height="35" InputType="Decimal" XMin="0" XPrecision="3"/>
                    <Label  Width="100"  Height="35" Content="mm/s" FontWeight="Bold" FontSize="16" />
                    <Controls:InputTextBox x:Name="jdMoCutFourNo" Width="120"  TextWrapping="Wrap"  Height="35" InputType="Numeral" XMin="0" XPrecision="0"/>
                    <Label  Width="60"  Height="35" Content="刀" FontWeight="Bold" FontSize="16" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <Label   Width="60"  Height="35" Content="5" FontWeight="Bold" FontSize="16" />
                    <Controls:InputTextBox x:Name="jdMoCutFiveSpeed" Width="200"  TextWrapping="Wrap"  Height="35" InputType="Decimal" XMin="0" XPrecision="3"/>
                    <Label  Width="100"  Height="35" Content="mm/s" FontWeight="Bold" FontSize="16" />
                    <Controls:InputTextBox x:Name="jdMoCutFiveNo" Width="120"  TextWrapping="Wrap"  Height="35" InputType="Numeral" XMin="0" XPrecision="0"/>
                    <Label  Width="60"  Height="35" Content="刀" FontWeight="Bold" FontSize="16" />
                </StackPanel>

            </StackPanel>

        </StackPanel>
        <StackPanel Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" HorizontalAlignment="Left" Width="620" >
            <StackPanel Orientation="Horizontal" Width="600" Margin="0,35,0,0" Visibility="Hidden" >
                <CheckBox x:Name="cbIfCorrectHeight" Width="220" Content="刀具修正修刀片测高" Height="35" VerticalContentAlignment="Center" Margin="50,0,0,0" FontWeight="Bold" FontSize="16" />
            </StackPanel>
            <StackPanel Width="600" Margin="0,5,0,0" Orientation="Horizontal" >
                <Label x:Name="labCoCutNum"  Width="160"  Height="35" Content="切割刀片数(0/全部)" FontWeight="Bold" FontSize="16" />
                <Controls:InputTextBox x:Name="tbCoCutNum" Width="140"  TextWrapping="Wrap"  Height="35" InputType="Numeral" XMin="0" XMax="10" XPrecision="0"/>
            </StackPanel>
            <StackPanel Width="600" Margin="0,5,0,0" Orientation="Horizontal" >
                <Label x:Name="labCoXDistance"  Width="120"  Height="35" Content="X轴行程" FontWeight="Bold" FontSize="16" />
                <Controls:InputTextBox x:Name="tbCoXDistance" Width="140"  TextWrapping="Wrap"  Height="35" InputType="Decimal" XMin="0" XPrecision="3"/>
                <Label Height="35" Content="mm" FontWeight="Bold" FontSize="14" />
            </StackPanel>
            <StackPanel Width="600" Margin="0,5,0,0" Orientation="Horizontal">
                <Label x:Name="labCoYDistance"  Width="120"  Height="35" Content="Y轴行程" FontWeight="Bold" FontSize="16" />
                <Controls:InputTextBox x:Name="tbCoYDistance" Width="140"  TextWrapping="Wrap"  Height="35" InputType="Decimal" XMin="0" XPrecision="3"/>
                <Label Height="35" Content="mm" FontWeight="Bold" FontSize="14" />
            </StackPanel>
            <StackPanel Width="600" Margin="0,5,0,0" Orientation="Horizontal">
                <Label x:Name="labCoJiaoHeight"  Width="120"  Height="35" Content="膠片厚度" FontWeight="Bold" FontSize="16" />
                <Controls:InputTextBox x:Name="tbCoJiaoHeight" Width="140"  TextWrapping="Wrap"  Height="35" InputType="Decimal" XMin="0" XPrecision="3"/>
                <Label Height="35" Content="mm" FontWeight="Bold" FontSize="14" />
            </StackPanel>
            <StackPanel Width="600" Margin="0,5,0,0" Orientation="Horizontal">
                <Label x:Name="labCoCutSize"  Width="120"  Height="35" Content="进刀尺寸" FontWeight="Bold" FontSize="16" />
                <Controls:InputTextBox x:Name="tbCoCutSize" Width="140"  TextWrapping="Wrap"  Height="35" InputType="Decimal" XMin="0" XPrecision="3"/>
                <Label Height="35" Content="mm" FontWeight="Bold" FontSize="14" />
            </StackPanel>
            <StackPanel Width="600" Margin="0,5,0,0" Orientation="Horizontal">
                <Label x:Name="labCoOffsetX"  Width="120"  Height="35" Content="X轴偏移" FontWeight="Bold" FontSize="16" />
                <Controls:InputTextBox x:Name="tbCoOffsetX" Width="140"  TextWrapping="Wrap"  Height="35" InputType="Decimal" XMin="0" XPrecision="3"/>
                <Label Height="35" Content="mm" FontWeight="Bold" FontSize="14" />
            </StackPanel>
            <StackPanel Width="600" Margin="0,5,0,0" Orientation="Horizontal">
                <Label x:Name="labCoCutDirection"  Width="120"  Height="35" Content="切割方向" FontWeight="Bold" FontSize="16" />
                <Controls:InputTextBox x:Name="tbCoCutDirection" Width="140"  TextWrapping="Wrap"  Height="35" InputType="Default" />
            </StackPanel>

            <StackPanel Width="620" Margin="10,10,0,0">
                <StackPanel Orientation="Horizontal">
                    <Label x:Name="col1HeadName1"  Width="60"  Height="35" Content="序号" FontWeight="Bold" FontSize="16" />
                    <Label x:Name="col1HeadName2"  Width="300"  Height="35" Content="进刀速度" FontWeight="Bold" FontSize="16" Margin="10,0,0,0"/>
                    <Label x:Name="col1HeadName3"  Width="120"  Height="35" Content="刀" FontWeight="Bold" FontSize="16" Margin="20,0,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                    <Label   Width="60"  Height="35" Content="6" FontWeight="Bold" FontSize="16" />
                    <Controls:InputTextBox x:Name="jdMoCutSixSpeed" Width="220"  TextWrapping="Wrap"  Height="35" InputType="Decimal" XMin="0" XPrecision="3"/>
                    <Label  Width="100"  Height="35" Content="mm/s" FontWeight="Bold" FontSize="16" />
                    <Controls:InputTextBox x:Name="jdMoCutSixNo" Width="120"  TextWrapping="Wrap"  Height="35" InputType="Numeral" XMin="0" XPrecision="0"/>
                    <Label  Width="60"  Height="35" Content="刀" FontWeight="Bold" FontSize="16" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <Label   Width="60"  Height="35" Content="7" FontWeight="Bold" FontSize="16" />
                    <Controls:InputTextBox x:Name="jdMoCutSevenSpeed" Width="220"  TextWrapping="Wrap"  Height="35" InputType="Decimal" XMin="0" XPrecision="3"/>
                    <Label  Width="100"  Height="35" Content="mm/s" FontWeight="Bold" FontSize="16" />
                    <Controls:InputTextBox x:Name="jdMoCutSevenNo" Width="120"  TextWrapping="Wrap"  Height="35" InputType="Numeral" XMin="0" XPrecision="0"/>
                    <Label  Width="60"  Height="35" Content="刀" FontWeight="Bold" FontSize="16" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <Label   Width="60"  Height="35" Content="8" FontWeight="Bold" FontSize="16" />
                    <Controls:InputTextBox x:Name="jdMoCutEightSpeed" Width="220"  TextWrapping="Wrap"  Height="35" InputType="Decimal" XMin="0" XPrecision="3"/>
                    <Label  Width="100"  Height="35" Content="mm/s" FontWeight="Bold" FontSize="16" />
                    <Controls:InputTextBox x:Name="jdMoCutEightNo" Width="120"  TextWrapping="Wrap"  Height="35" InputType="Numeral" XMin="0" XPrecision="0"/>
                    <Label  Width="60"  Height="35" Content="刀" FontWeight="Bold" FontSize="16" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <Label   Width="60"  Height="35" Content="9" FontWeight="Bold" FontSize="16" />
                    <Controls:InputTextBox x:Name="jdMoCutNineSpeed" Width="220"  TextWrapping="Wrap"  Height="35" InputType="Decimal" XMin="0" XPrecision="3"/>
                    <Label  Width="100"  Height="35" Content="mm/s" FontWeight="Bold" FontSize="16" />
                    <Controls:InputTextBox x:Name="jdMoCutNineNo" Width="120"  TextWrapping="Wrap"  Height="35" InputType="Numeral" XMin="0" XPrecision="0"/>
                    <Label  Width="60"  Height="35" Content="刀" FontWeight="Bold" FontSize="16" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <Label   Width="60"  Height="35" Content="10" FontWeight="Bold" FontSize="16" />
                    <Controls:InputTextBox x:Name="jdMoCutTenSpeed" Width="220"  TextWrapping="Wrap"  Height="35" InputType="Decimal" XMin="0" XPrecision="3"/>
                    <Label  Width="100"  Height="35" Content="mm/s" FontWeight="Bold" FontSize="16" />
                    <Controls:InputTextBox x:Name="jdMoCutTenNo" Width="120"  TextWrapping="Wrap"  Height="35" InputType="Numeral" XMin="0" XPrecision="0"/>
                    <Label  Width="60"  Height="35" Content="刀" FontWeight="Bold" FontSize="16" />
                </StackPanel>
            </StackPanel>
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Grid.Column="2" x:Name="sp2"  HorizontalAlignment="Left" >
            
        </StackPanel>
    </Grid>
</Page>
