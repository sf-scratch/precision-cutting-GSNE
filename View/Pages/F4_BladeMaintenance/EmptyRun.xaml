<UserControl
    x:Class="精密切割系统.View.Pages.F4_BladeMaintenance.EmptyRun"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
    xmlns:auto="clr-namespace:WpfAutoGrid;assembly=WpfAutoGrid.Core"
    xmlns:convert="clr-namespace:精密切割系统.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:精密切割系统.Helpers"
    xmlns:local="clr-namespace:精密切割系统.View.Pages.F4_BladeMaintenance"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:精密切割系统.ViewModel"
    d:DataContext="{d:DesignInstance viewModel:EmptyRunViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="655"
    d:DesignWidth="1570"
    mc:Ignorable="d">
    <Grid>
        <Grid.Resources>
            <convert:AnyTrueConverter x:Key="AnyTrueConverter" />
            <convert:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <Style BasedOn="{StaticResource MaterialDesignUserForegroundCheckBox}" TargetType="CheckBox">
                <Setter Property="Margin" Value="10" />
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Height" Value="35" />
            </Style>
            <Style BasedOn="{StaticResource InputTextStyle}" TargetType="Controls:InputTextBox">
                <Setter Property="Width" Value="100" />
                <Setter Property="Height" Value="35" />
                <Setter Property="InputType" Value="Numeral" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>
            <Style TargetType="Label">
                <Setter Property="FontSize" Value="18" />
                <Setter Property="Height" Value="35" />
                <Setter Property="FontWeight" Value="Bold" />
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Label
            Grid.Row="0"
            Grid.Column="0"
            Height="auto"
            Margin="30,30,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="空运行(4.4)"
            FontSize="30"
            FontWeight="Bold" />
        <auto:AutoGrid
            Grid.Row="1"
            Margin="20"
            HorizontalAlignment="Center"
            ChildMargin="10"
            Columns="*,*,*"
            IsEnabled="{Binding IsEnabledGrid}"
            RowCount="8">
            <Label />
            <StackPanel Orientation="Horizontal">
                <Label
                    Width="100"
                    HorizontalContentAlignment="Center"
                    Content="速度"
                    FontSize="18" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label
                    Width="100"
                    HorizontalContentAlignment="Center"
                    Content="次数"
                    FontSize="18" />
            </StackPanel>
            <CheckBox Content="X轴" IsChecked="{Binding RunX}" />
            <StackPanel Orientation="Horizontal">
                <Controls:InputTextBox
                    InputType="Decimal"
                    Text="{Binding SpeedX}"
                    XPrecision="3" />
                <Label Content="mm/s " FontSize="18" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Controls:InputTextBox
                    InputType="Decimal"
                    Text="{Binding RepeatCountX}"
                    XPrecision="0" />
                <Label Content="次 " FontSize="18" />
            </StackPanel>
            <CheckBox Content="Y轴" IsChecked="{Binding RunY}" />
            <StackPanel Orientation="Horizontal">
                <Controls:InputTextBox
                    InputType="Decimal"
                    Text="{Binding SpeedY}"
                    XPrecision="3" />
                <Label Content="mm/s " FontSize="18" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Controls:InputTextBox
                    InputType="Decimal"
                    Text="{Binding RepeatCountY}"
                    XPrecision="0" />
                <Label Content="次 " FontSize="18" />
            </StackPanel>
            <CheckBox Content="Z1轴" IsChecked="{Binding RunZ1}" />
            <StackPanel Orientation="Horizontal">
                <Controls:InputTextBox
                    InputType="Decimal"
                    Text="{Binding SpeedZ1}"
                    XPrecision="3" />
                <Label Content="mm/s " FontSize="18" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Controls:InputTextBox
                    InputType="Decimal"
                    Text="{Binding RepeatCountZ1}"
                    XPrecision="0" />
                <Label Content="次 " FontSize="18" />
            </StackPanel>
            <CheckBox Content="Z2轴" IsChecked="{Binding RunZ2}" />
            <StackPanel Orientation="Horizontal">
                <Controls:InputTextBox
                    InputType="Decimal"
                    Text="{Binding SpeedZ2}"
                    XPrecision="3" />
                <Label Content="mm/s " FontSize="18" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Controls:InputTextBox
                    InputType="Decimal"
                    Text="{Binding RepeatCountZ2}"
                    XPrecision="0" />
                <Label Content="次 " FontSize="18" />
            </StackPanel>
            <CheckBox
                Content="θ轴"
                IsChecked="{Binding RunTheta}"
                Visibility="{Binding Source={x:Static helpers:GlobalParams.HasTheta}, Converter={StaticResource BoolToVisibilityConverter}}" />
            <StackPanel Orientation="Horizontal">
                <Controls:InputTextBox
                    InputType="Decimal"
                    Text="{Binding SpeedTheta}"
                    XPrecision="3" />
                <Label Content="mm/s " FontSize="18" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Controls:InputTextBox
                    InputType="Decimal"
                    Text="{Binding RepeatCountTheta}"
                    XPrecision="0" />
                <Label Content="次 " FontSize="18" />
            </StackPanel>
            <CheckBox
                Grid.ColumnSpan="3"
                Content="切割水"
                IsChecked="{Binding IsOpenWater}" />
            <CheckBox
                Grid.ColumnSpan="3"
                Content="吹气"
                IsChecked="{Binding IsFlowing}" />
        </auto:AutoGrid>
    </Grid>
</UserControl>