<UserControl x:Class="精密切割系统.View.Pages.F4_BladeMaintenance.BladeReplacementConfiguration"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:精密切割系统.View.Pages.F4_BladeMaintenance"
      xmlns:viewModel="clr-namespace:精密切割系统.ViewModel"
      xmlns:auto="clr-namespace:WpfAutoGrid;assembly=WpfAutoGrid.Core" xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
      xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
      mc:Ignorable="d" 
      d:DesignHeight="676" d:DesignWidth="1448"
      d:DataContext="{d:DesignInstance viewModel:BladeReplacementConfigurationViewModel, IsDesignTimeCreatable=True}">
    <!--<behaviors:Interaction.Triggers>
        <behaviors:EventTrigger EventName="Loaded">
            <behaviors:InvokeCommandAction 
                Command="{Binding InitCommand}"/>
        </behaviors:EventTrigger>
    </behaviors:Interaction.Triggers>-->
    <Control.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button">
            <!-- 基本样式设置 -->
            <Setter Property="Background" Value="#39D11A"/>
            <!-- 主色 -->
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#388E3C"/>
            <!-- 边框色 -->
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12 6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <!-- 按钮视觉结构 -->
                        <Border x:Name="border" 
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="4"
                        SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="contentPresenter"
                                    Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <!-- 按钮的视觉状态 -->
                        <ControlTemplate.Triggers>
                            <!-- 鼠标悬停效果 -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#43A047"/>
                                <!-- 深一点的颜色 -->
                                <Setter Property="BorderBrush" Value="#2E7D32"/>
                            </Trigger>

                            <!-- 按下效果 -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#388E3C"/>
                                <Setter Property="BorderBrush" Value="#1B5E20"/>
                                <Setter TargetName="contentPresenter" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>

                            <!-- 禁用状态 -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#BDBDBD"/>
                                <Setter Property="BorderBrush" Value="#9E9E9E"/>
                                <Setter Property="Foreground" Value="#757575"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Control.Resources>
    <Grid Margin="30,30,0,0">
        <Grid.RowDefinitions >
            <RowDefinition Height="60"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Label Content="刀片更换(3.1)" VerticalAlignment="Center" FontWeight="Bold" FontSize="22"/>

        <StackPanel Grid.Row="1">
            <GroupBox Margin="10">
                <GroupBox.Header>
                    <TextBlock Text="轮毂信息" FontWeight="Bold" FontSize="20"/>
                </GroupBox.Header>
                <auto:AutoGrid Margin="10" Columns="2*,3*,*,2*,5*" RowCount="7" ChildMargin="5">
                    <TextBlock Text="轮毂号"/>
                    <Controls:InputTextBox x:Name="lunguTextBox" Text="{Binding LunguId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <!--<behaviors:Interaction.Triggers>
                            <behaviors:EventTrigger EventName="KeyUp">
                                <behaviors:InvokeCommandAction Command="{Binding InitCommand}" CommandParameter="{Binding Text, ElementName=lunguTextBox}"/>
                            </behaviors:EventTrigger>
                        </behaviors:Interaction.Triggers>-->
                        <TextBox.InputBindings>
                            <KeyBinding  Key="Enter" Command="{Binding InitCommand}" CommandParameter="{Binding Text, ElementName=lunguTextBox}"/>
                        </TextBox.InputBindings>
                    </Controls:InputTextBox>
                    <TextBlock HorizontalAlignment="Left" Text=""/>
                    <TextBlock Text="实际刀刃规格"/>
                    <Controls:InputTextBox Text="{Binding LunguSksj.SjSpec}"/>
                    <TextBlock Text="刀刃平均厚度"/>
                    <Controls:InputTextBox Text="{Binding LunguSksj.ABAverageThickness}"/>
                    <TextBlock HorizontalAlignment="Left" Text="um"/>
                    <TextBlock Text="刀片类型"/>
                    <Controls:InputTextBox Text="{Binding LunguSksj.BladeType}"/>
                    <TextBlock Text="最长刀刃长度"/>
                    <Controls:InputTextBox Text="{Binding LunguSksj.LongestBlade}"/>
                    <TextBlock HorizontalAlignment="Left" Text="um"/>
                    <TextBlock Text="刀刃规格"/>
                    <Controls:InputTextBox Text="{Binding LunguSksj.BladeEdgeType}"/>
                    <TextBlock Text="刀片外径"/>
                    <Controls:InputTextBox Text="{Binding LunguSksj.BladeOuterDiameter}"/>
                    <TextBlock HorizontalAlignment="Left" Text="um"/>
                </auto:AutoGrid>
            </GroupBox>

            <GroupBox Margin="10">
                <GroupBox.Header>
                    <TextBlock Text="切割参数" FontWeight="Bold" FontSize="20"/>
                </GroupBox.Header>
                <auto:AutoGrid Margin="10" Columns="2*,2*,*,2*,2*,*" RowCount="7" ChildMargin="5">
                    <TextBlock Text="型号参数号"/>
                    <Controls:InputTextBox Text="{Binding CutParams.DeviceDataNo}"/>
                    <TextBlock HorizontalAlignment="Left" Text=""/>
                    <TextBlock Text="胶片厚度"/>
                    <Controls:InputTextBox Text="{Binding CutParams.TapeThickness}"/>
                    <TextBlock HorizontalAlignment="Left" Text="mm"/>
                    <TextBlock Text="旋转轴转速"/>
                    <Controls:InputTextBox Text="{Binding CutParams.SpindleRev}"/>
                    <TextBlock HorizontalAlignment="Left" Text="转/min"/>
                    <TextBlock Text="刀片高度"/>
                    <Controls:InputTextBox Text="{Binding CutParams.CutHeight}"/>
                    <TextBlock HorizontalAlignment="Left" Text="mm"/>
                    <TextBlock Text="预切割过程No"/>
                    <Controls:InputTextBox Text="{Binding CutParams.PrecutProcessNo}"/>
                    <TextBlock HorizontalAlignment="Left" Text=""/>
                    <TextBlock Text="最高切割速率"/>
                    <Controls:InputTextBox Text="{Binding CutParams.MaxCutSpeed}"/>
                    <TextBlock HorizontalAlignment="Left" Text="mm/s"/>
                    <TextBlock Text="晶片尺寸"/>
                    <Controls:InputTextBox/>
                    <TextBlock HorizontalAlignment="Left" Text="mm"/>
                    <TextBlock Text="切割刀数"/>
                    <Controls:InputTextBox Text="{Binding CutParams.CutNum}"/>
                    <TextBlock HorizontalAlignment="Left" Text="刀"/>
                    <TextBlock Text="晶片厚度"/>
                    <Controls:InputTextBox Text="{Binding CutParams.WorkThickness}"/>
                    <TextBlock HorizontalAlignment="Left" Text="mm"/>
                </auto:AutoGrid>
            </GroupBox>
        </StackPanel>
        <StackPanel Grid.Column="2" Grid.Row="1">
            <GroupBox Margin="10">
                <GroupBox.Header>
                    <TextBlock Text="磨刀参数" FontWeight="Bold" FontSize="20"/>
                </GroupBox.Header>
                <StackPanel>
                    <auto:AutoGrid Margin="10" Columns="2*,2*,*,2*,2*,*" RowCount="7" ChildMargin="5">
                        <TextBlock Text="旋转轴转速"/>
                        <Controls:InputTextBox Text="{Binding SharpenParams.RotateSpeed}"/>
                        <TextBlock HorizontalAlignment="Left" Text="转/min"/>
                        <TextBlock Text="磨刀板尺寸"/>
                        <Controls:InputTextBox/>
                        <TextBlock HorizontalAlignment="Left" Text="mm"/>
                        <TextBlock Text="磨刀板厚度"/>
                        <Controls:InputTextBox Text="{Binding SharpenParams.CutThickness}"/>
                        <TextBlock HorizontalAlignment="Left" Text="mm"/>
                        <TextBlock Text="胶片厚度"/>
                        <Controls:InputTextBox Text="{Binding SharpenParams.CoJiaoHeight}"/>
                        <TextBlock HorizontalAlignment="Left" Text="mm"/>
                        <TextBlock Text="刀片高度"/>
                        <Controls:InputTextBox Text="{Binding SharpenParams.CutHeight}"/>
                        <TextBlock HorizontalAlignment="Left" Text="mm"/>
                        <TextBlock Text="进刀尺寸"/>
                        <Controls:InputTextBox Text="{Binding SharpenParams.CutSize}"/>
                        <TextBlock HorizontalAlignment="Left" Text="mm"/>
                        <TextBlock Text="磨刀刀数"/>
                        <Controls:InputTextBox Text="{Binding SharpenParams.CutNum}"/>
                        <TextBlock HorizontalAlignment="Left" Text="刀"/>
                        <TextBlock Text="X轴偏移量"/>
                        <Controls:InputTextBox Text="{Binding SharpenParams.CoOffsetX}"/>
                        <TextBlock HorizontalAlignment="Left" Text="mm"/>
                        <TextBlock Text="最高磨刀速率"/>
                        <Controls:InputTextBox Text="{Binding SharpenParams.HightestCutSpeed}"/>
                        <TextBlock HorizontalAlignment="Left" Text="mm/s"/>
                    </auto:AutoGrid>
                </StackPanel>
            </GroupBox>
            <!--<Controls:RightButton
                        BackFlag="False"
                        BackgroundDefColor="#39D11A"
                        BackgroundDownColor="#39B41A"
                        ContentText="开始"
                        ImagePath="/Assets/icon/right/enter.png"
                        Visibility="Visible"/>-->
            <!--<Button Content="自动执行" FontSize="30" Width="200" HorizontalAlignment="Right" Margin="20" Command="{Binding AutoRunCommand}"/>-->
        </StackPanel>
    </Grid>
</UserControl>
