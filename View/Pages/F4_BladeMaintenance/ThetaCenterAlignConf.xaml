<Page
    x:Class="精密切割系统.View.Pages.F4_BladeMaintenance.ThetaCenterAlignConf"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
    xmlns:common="clr-namespace:精密切割系统.View.Pages.common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:精密切割系统.View.Pages.F4_BladeMaintenance"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:精密切割系统.ViewModel"
    Title="ThetaCenterAlignConf"
    d:DataContext="{d:DesignInstance viewModel:ThetaCenterAlignConfViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="655"
    d:DesignWidth="1570"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50*" />
            <ColumnDefinition Width="50*" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <common:CameraCommon Width="765" Height="640" />
        </Grid>
        <Grid Grid.Column="1">
            <StackPanel>
                <Grid>
                    <Label
                        Margin="30,30,0,0"
                        Content="工作盘中心点校准 (4.4)"
                        FontSize="22"
                        FontWeight="Bold" />
                </Grid>
                <Grid x:Name="thetaCenterParamsGrid">
                    <StackPanel Margin="30,30,0,0">
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                            <Label
                                Width="200"
                                Content="工件尺寸"
                                FontSize="18"
                                FontWeight="Bold" />
                            <Controls:InputTextBox
                                Width="200"
                                InputType="Decimal"
                                Text="{Binding WorkSize, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                            <Label
                                Width="200"
                                Content="工件厚度"
                                FontSize="18"
                                FontWeight="Bold" />
                            <Controls:InputTextBox
                                Width="200"
                                InputType="Decimal"
                                Text="{Binding WorkThickness, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                            <Label
                                Width="200"
                                Content="膜的厚度"
                                FontSize="18"
                                FontWeight="Bold" />
                            <Controls:InputTextBox
                                Width="200"
                                InputType="Decimal"
                                Text="{Binding TapeThickness, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                            <Label
                                Width="200"
                                Content="刀片高度"
                                FontSize="18"
                                FontWeight="Bold" />
                            <Controls:InputTextBox
                                Width="200"
                                InputType="Decimal"
                                Text="{Binding BladeHeight, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                            <Label
                                Width="200"
                                Content="进刀速度"
                                FontSize="18"
                                FontWeight="Bold" />
                            <Controls:InputTextBox
                                Width="200"
                                InputType="Decimal"
                                Text="{Binding CutSpeed, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                            <Label
                                Width="200"
                                Content="主轴转速"
                                FontSize="18"
                                FontWeight="Bold" />
                            <Controls:InputTextBox
                                Width="200"
                                InputType="Numeral"
                                Text="{Binding SpindleSpeed, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap"
                                XMax="30000"
                                XMin="0" />
                        </StackPanel>
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                            <Label
                                Width="200"
                                Content="θ轴相机中心点位置"
                                FontSize="18"
                                FontWeight="Bold" />
                            <Label
                                Width="30"
                                Content="X"
                                FontSize="18"
                                FontWeight="Bold" />
                            <Controls:InputTextBox
                                x:Name="thetaCenterX"
                                Width="120"
                                InputType="Numeral"
                                TextWrapping="Wrap" />
                            <Label
                                Width="30"
                                Margin="20,0,0,0"
                                Content="Y"
                                FontSize="18"
                                FontWeight="Bold" />
                            <Controls:InputTextBox
                                x:Name="thetaCenterY"
                                Width="120"
                                InputType="Numeral"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                            <Label
                                Width="200"
                                Content="轴当前位置"
                                FontSize="18"
                                FontWeight="Bold" />
                            <Label
                                Width="30"
                                Content="X"
                                FontSize="18"
                                FontWeight="Bold" />
                            <Controls:InputTextBox
                                x:Name="currentX"
                                Width="120"
                                InputType="Numeral"
                                IsEnabled="False"
                                TextWrapping="Wrap" />
                            <Label
                                Width="30"
                                Margin="20,0,0,0"
                                Content="Y"
                                FontSize="18"
                                FontWeight="Bold" />
                            <Controls:InputTextBox
                                x:Name="currentY"
                                Width="120"
                                InputType="Numeral"
                                IsEnabled="False"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <common:CommonDimming Margin="0,10,0,0" />
                    </StackPanel>
                </Grid>
                <Grid
                    x:Name="dimmingGrid"
                    Margin="30,80,0,0"
                    Visibility="Collapsed">
                    <common:CommonDimming />
                </Grid>
                <Grid
                    x:Name="directionGrid"
                    Margin="0,60,0,0"
                    Visibility="Collapsed">
                    <common:SimpleDirectOperate />
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</Page>