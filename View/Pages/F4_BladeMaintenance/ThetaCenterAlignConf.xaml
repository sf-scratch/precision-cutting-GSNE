<Page x:Class="精密切割系统.View.Pages.F4_BladeMaintenance.ThetaCenterAlignConf"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:精密切割系统.View.Pages.F4_BladeMaintenance" xmlns:common="clr-namespace:精密切割系统.View.Pages.common" xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="655"
      d:DesignWidth="1570"
      xmlns:viewModel="clr-namespace:精密切割系统.ViewModel"
      d:DataContext="{d:DesignInstance viewModel:ThetaCenterAlignConfViewModel, IsDesignTimeCreatable=True}"
      Title="ThetaCenterAlignConf" Loaded="Page_Loaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50*" />
            <ColumnDefinition Width="50*" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <common:CameraCommon Width="765" Height="640" />
        </Grid>
        <Grid Grid.Column="1">
            <StackPanel>
                <Grid>
                    <Label
                        Margin="30,30,0,0"
                        Content="工作盘中心点校准 (4.4)"
                        FontSize="22"
                        FontWeight="Bold" />
                </Grid>
                <Grid x:Name="thetaCenterParamsGrid">
                    <StackPanel Margin="30,30,0,0">
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                            <Label
                                Width="200"
                                Content="工件尺寸"
                                FontSize="18"
                                FontWeight="Bold" />
                            <Controls:InputTextBox Width="200" InputType="Decimal" TextWrapping="Wrap" Text="{Binding WorkSize, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                            <Label
                                Width="200"
                                Content="工件厚度"
                                FontSize="18"
                                FontWeight="Bold" />
                            <Controls:InputTextBox
                                Width="200"
                                InputType="Decimal"
                                TextWrapping="Wrap" Text="{Binding WorkThickness, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                            <Label
                                Width="200"
                                Content="膜的厚度"
                                FontSize="18"
                                FontWeight="Bold" />
                            <Controls:InputTextBox
                                Width="200"
                                InputType="Decimal"
                                TextWrapping="Wrap" Text="{Binding TapeThickness, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                            <Label
                                Width="200"
                                Content="刀片高度"
                                FontSize="18"
                                FontWeight="Bold" />
                            <Controls:InputTextBox
                                Width="200"
                                InputType="Decimal"
                                TextWrapping="Wrap" Text="{Binding BladeHeight, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                            <Label
                                Width="200"
                                Content="进刀速度"
                                FontSize="18"
                                FontWeight="Bold" />
                            <Controls:InputTextBox
                                Width="200"
                                InputType="Decimal"
                                TextWrapping="Wrap" Text="{Binding CutSpeed, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                            <Label
                                Width="200"
                                Content="主轴转速"
                                FontSize="18"
                                FontWeight="Bold" />
                            <Controls:InputTextBox
                                Width="200"
                                InputType="Numeral"
                                XMax="30000"
                                XMin="0"
                                TextWrapping="Wrap" Text="{Binding SpindleSpeed, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
                <Grid x:Name="centerPanel" Visibility="Collapsed">
                    <StackPanel  Margin="30,30,0,10">
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal" >
                        <Label
                            Width="200"
                            Content="θ中心位置"
                            FontSize="18"
                            FontWeight="Bold" />
                        <Label
                            Width="30"
                            Content="X"
                            FontSize="18"
                            FontWeight="Bold" />
                        <Controls:InputTextBox
                            Width="120"
                            InputType="Numeral"
                            x:Name="thetaCenterX"
                            TextWrapping="Wrap" />
                        <Label
                            Width="30"
                            Margin="20 0 0 0"
                            Content="Y"
                            FontSize="18"
                            FontWeight="Bold" />
                        <Controls:InputTextBox
                            Width="120"
                            InputType="Numeral"
                            x:Name="thetaCenterY"
                            TextWrapping="Wrap" />
                    </StackPanel>
                    </StackPanel>
                </Grid>
                <Grid x:Name="dimmingGrid" Visibility="Collapsed" Margin="30,80,0,0">
                    <common:CommonDimming></common:CommonDimming>
                </Grid>
                <Grid x:Name="directionGrid" Visibility="Collapsed" Margin="0 60 0 0">
                    <common:CommonDirection></common:CommonDirection>
                </Grid>
            </StackPanel>
            
        </Grid>
    </Grid>
</Page>
