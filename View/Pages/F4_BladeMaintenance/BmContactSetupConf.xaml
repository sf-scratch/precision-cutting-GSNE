<Page x:Class="精密切割系统.View.Pages.F4_BladeMaintenance.BmContactSetupConf"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:Controls="clr-namespace:精密切割系统.View.Controls" 
      xmlns:local="clr-namespace:精密切割系统.View.Pages.F4_BladeMaintenance"
      mc:Ignorable="d" 
      d:DesignHeight="676" d:DesignWidth="1448"
      Title="BmContactSetupConf" Loaded="Page_Loaded" Unloaded="Page_Unloaded">

    <Grid Margin="30,30,0,0">
        <Grid.RowDefinitions >
            <RowDefinition Height="60"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="520"/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Label x:Name="labContactSetup" Content="工作盘测高(3.2)" VerticalAlignment="Center" HorizontalAlignment="Left" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"  FontWeight="Bold" FontSize="22"/>
        <StackPanel Grid.Row="1" Grid.Column="0" x:Name="sp1" HorizontalAlignment="Left" >
            <!--
            <StackPanel Width="250" Margin="0,0,0,0" HorizontalAlignment="Left" >
                <Label x:Name="labSpindleRev"  Height="35" Content="旋转轴转速" FontWeight="Bold" FontSize="16" />
                <StackPanel Width="250" Orientation="Horizontal" >
                    <Controls:InputTextBox IsEnabled="False" x:Name="inputTextBox5" Width="180"  TextWrapping="Wrap"  Height="35" InputType="Decimal" XMin="0" />
                    <Label Height="35" Content="/min" FontWeight="Bold" FontSize="16" />
                </StackPanel>
            </StackPanel>
            -->
            <StackPanel Margin="0,0,0,0" HorizontalAlignment="Left">
                <Label x:Name="labLotID"  Height="35" Content="批号ID" FontWeight="Bold" FontSize="16" />
                <StackPanel   Orientation="Horizontal">
                    <Controls:InputTextBox IsEnabled="False" x:Name="tbBladeLotID" Width="355"  TextWrapping="Wrap"  Height="35" />
                </StackPanel>
            </StackPanel>
            <StackPanel Margin="0,0,0,0" HorizontalAlignment="Left">
                <Label x:Name="labSpec"  Height="35" Content="品种名称" FontWeight="Bold" FontSize="16" />
                <StackPanel Orientation="Horizontal" >
                    <Controls:InputTextBox IsEnabled="False" x:Name="tbSpecName" Width="355"  TextWrapping="Wrap"  Height="35" />
                </StackPanel>
            </StackPanel>
            <StackPanel Margin="0,0,0,0" Orientation="Horizontal" HorizontalAlignment="Left">
                <StackPanel Width="165" >
                    <Label x:Name="labBlade0D"  Height="35" Content="刀片外经" FontWeight="Bold" FontSize="16" />
                    <StackPanel Width="165" Orientation="Horizontal" >
                        <Controls:InputTextBox IsEnabled="False" x:Name="tbBladeOutside" Width="130"  TextWrapping="Wrap"  Height="35" InputType="Decimal" XMin="0" XPrecision="3" />
                        <Label Height="35" Content="mm" FontWeight="Bold" FontSize="16" />
                    </StackPanel>
                </StackPanel>
                <!--
                <StackPanel Width="165" Margin="15,0,0,0" >
                    <Label x:Name="labNCSCalibration"  Height="35" Content="工作盘敏感间距" FontWeight="Bold" FontSize="16" />
                    <StackPanel Width="165" Orientation="Horizontal" >
                        <Controls:InputTextBox IsEnabled="False" x:Name="inputTextBox4" Width="120"  TextWrapping="Wrap"  Height="35" InputType="Decimal" XMin="0" />
                        <Label Height="35" Content="mm" FontWeight="Bold" FontSize="16" />
                    </StackPanel>
                </StackPanel>
                -->
                <StackPanel Width="165" Margin="15,0,0,0"  >
                    <Label x:Name="labSetupPosition"  Height="35" Content="测高位置" FontWeight="Bold" FontSize="16" />
                    <StackPanel Width="165" Orientation="Horizontal" >
                        <Controls:InputTextBox IsEnabled="False" x:Name="inputTextBox6" Width="120"  TextWrapping="Wrap"  Height="35" InputType="Decimal" XMin="0" XPrecision="5"/>
                        <Label Height="35" Content="mm" FontWeight="Bold" FontSize="16" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
            <Label x:Name="labWearAmountSince"  Height="35" Content="耗损量" FontWeight="Bold" FontSize="16" Margin="0,10,0,0" Visibility="Collapsed"/>
            <StackPanel Width="450" Margin="0,0,0,0" Orientation="Horizontal" HorizontalAlignment="Left" Visibility="Collapsed">
                <Label x:Name="labBladeReplacement" Width="180"  Height="35" Content="自刀片更换算起" FontWeight="Bold" FontSize="16" />
                <Controls:InputTextBox IsEnabled="False" x:Name="inputTextBox7" Width="180"  TextWrapping="Wrap"  Height="35" InputType="Decimal" XMin="0" XPrecision="3"/>
                <Label Height="35" Content="mm" FontWeight="Bold" FontSize="16" />
            </StackPanel>
            <StackPanel Width="450" Margin="0,5,0,0" Orientation="Horizontal" HorizontalAlignment="Left" Visibility="Collapsed">
                <Label x:Name="labLastSetup" Width="180"  Height="35" Content="自上次测高算起" FontWeight="Bold" FontSize="16" />
                <Controls:InputTextBox IsEnabled="False" x:Name="inputTextBox8" Width="180"  TextWrapping="Wrap"  Height="35" InputType="Decimal" XMin="0" XPrecision="3"/>
                <Label Height="35" Content="mm" FontWeight="Bold" FontSize="16" />
            </StackPanel>
            <StackPanel Width="450" Margin="0,5,0,0" Orientation="Horizontal" HorizontalAlignment="Left" Visibility="Collapsed">
                <Label x:Name="labCurrentBladeExp" Width="180"  Height="35" Content="当前刀刃长度" FontWeight="Bold" FontSize="16" />
                <Controls:InputTextBox IsEnabled="False" x:Name="tbHardBladeLength" Width="180"  TextWrapping="Wrap"  Height="35" InputType="Decimal" XMin="0" XPrecision="3" />
                <Label Height="35" Content="mm" FontWeight="Bold" FontSize="16" />
            </StackPanel>
            <StackPanel Width="450" Margin="0,5,0,0" Orientation="Horizontal" HorizontalAlignment="Left" Visibility="Collapsed">
                <Label x:Name="labAutoDownAmount" Width="180"  Height="35" Content="自动下滑量" FontWeight="Bold" FontSize="16" />
                <Controls:InputTextBox IsEnabled="False" x:Name="inputTextBox10" Width="180"  TextWrapping="Wrap"  Height="35" InputType="Decimal" XMin="0" XPrecision="3"/>
                <Label Height="35" Content="mm" FontWeight="Bold" FontSize="16" />
            </StackPanel>
        </StackPanel>
        <StackPanel Grid.Row="1" Width="550" Grid.Column="1" x:Name="sp2"  HorizontalAlignment="Left" Margin="10,0,0,0">
            <Label x:Name="label21" Width="150"  Height="35" Content="工作盘形状" FontWeight="Bold" FontSize="16"  HorizontalAlignment="Left"/>
            <StackPanel Width="350" Margin="0,0,0,0" Orientation="Horizontal" HorizontalAlignment="Left">
                <Controls:InputTextBox IsEnabled="False" x:Name="tbChuckTableShape" Width="130"  TextWrapping="Wrap"  Height="35" />
                <Label x:Name="label22" Width="50" Height="35" Content="类型" FontWeight="Bold" FontSize="16"/>
                <Controls:InputTextBox IsEnabled="False" x:Name="tbTableType" Width="130"  TextWrapping="Wrap"  Height="35" />
            </StackPanel>
            <!--圆形时候显示-->
            <StackPanel Width="350" Margin="0,0,0,0" Orientation="Horizontal" HorizontalAlignment="Left" x:Name="showRound">
                <StackPanel Width="350" >
                    <Label x:Name="labTableSize"  Height="35" Content="工作盘尺寸" FontWeight="Bold" FontSize="16" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" >
                        <Controls:InputTextBox IsEnabled="False" x:Name="tbChuckTableSize" Width="130"  TextWrapping="Wrap"  Height="35" />
                        <!--<Label Width="50" Height="35" Content="inch" FontWeight="Bold" FontSize="16"  />-->
                    </StackPanel>
                </StackPanel>
            </StackPanel>
            <StackPanel Width="350" Margin="0,0,0,0" Orientation="Horizontal" HorizontalAlignment="Left">
                <StackPanel Width="350" >
                    <Label x:Name="labCumulativeCutSince"  Height="35" Content="刀片寿命记录" FontWeight="Bold" FontSize="18" Margin="0,10,0,0"/>
                    <Label x:Name="lablabBladeReplacementTitle"  Height="35" Content="自刀片更换算起" FontWeight="Bold" FontSize="16" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Controls:InputTextBox IsEnabled="False" x:Name="inputTextBox14" Width="130"  TextWrapping="Wrap"  Height="35" InputType="Decimal" XMin="0" XPrecision="3" />
                        <Label Width="50" Height="35" Content="m" FontWeight="Bold" FontSize="16"  />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,5,0,0" >
                        <Controls:InputTextBox IsEnabled="False" x:Name="inputTextBox15" Width="130"  TextWrapping="Wrap"  Height="35" InputType="Numeral" XMin="0" />
                        <Label Width="50" Height="35" Content="lines" FontWeight="Bold" FontSize="16"  />
                    </StackPanel>
                    
                    <Label x:Name="labLastSetupTitle"  Height="35" Content="自上次测高算起" FontWeight="Bold" FontSize="16" Margin="0,0,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" >
                        <Controls:InputTextBox IsEnabled="False" x:Name="inputTextBox17" Width="130"  TextWrapping="Wrap"  Height="35" InputType="Decimal" XMin="0" XPrecision="3" />
                        <Label Width="50" Height="35" Content="m" FontWeight="Bold" FontSize="16"  />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,5,0,0" >
                        <Controls:InputTextBox IsEnabled="False" x:Name="inputTextBox16" Width="130"  TextWrapping="Wrap"  Height="35" InputType="Numeral" XMin="0" />
                        <Label Width="50" Height="35" Content="lines" FontWeight="Bold" FontSize="16"  />
                    </StackPanel>

                    <Label x:Name="labLastReset"  Height="35" Content="自上次清除算起" FontWeight="Bold" FontSize="16" Margin="0,0,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" >
                        <Controls:InputTextBox IsEnabled="False" x:Name="inputTextBox19" Width="130"  TextWrapping="Wrap"  Height="35" InputType="Decimal" XMin="0" XPrecision="5" />
                        <Label Width="50" Height="35" Content="m" FontWeight="Bold" FontSize="16"  />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,5,0,0" >
                        <Controls:InputTextBox IsEnabled="False" x:Name="inputTextBox18" Width="130"  TextWrapping="Wrap"  Height="35" InputType="Numeral" XMin="0" />
                        <Label Width="50" Height="35" Content="lines" FontWeight="Bold" FontSize="16"  />
                    </StackPanel>

                </StackPanel>
            </StackPanel>
        </StackPanel>
        <StackPanel Grid.Row="1" Grid.Column="2" x:Name="sp3" HorizontalAlignment="Left">
            <Label x:Name="labSetupData"  Height="35" Content="测高数据" FontWeight="Bold" FontSize="16" Margin="0,10,0,0"/>
            <StackPanel Width="450" Margin="0,0,0,0" Orientation="Horizontal" HorizontalAlignment="Left">
                <Label x:Name="labFirstSetupValue" Width="180"  Height="35" Content="第一次测高" FontWeight="Bold" FontSize="16" />
                <Controls:InputTextBox IsEnabled="False" x:Name="firstSetupValue" Width="180"  TextWrapping="Wrap"  Height="35" InputType="Decimal" XMin="0" XPrecision="5"/>
                <Label Height="35" Content="mm" FontWeight="Bold" FontSize="16" />
            </StackPanel>
            <StackPanel Width="450" Margin="0,10,0,0" Orientation="Horizontal" HorizontalAlignment="Left" x:Name="secondSetupValuePanel">
                <Label x:Name="labSecondSetupValue" Width="180"  Height="35" Content="第二次测高" FontWeight="Bold" FontSize="16" />
                <Controls:InputTextBox IsEnabled="False" x:Name="secondSetupValue" Width="180"  TextWrapping="Wrap"  Height="35" InputType="Decimal" XMin="0" XPrecision="5"/>
                <Label Height="35" Content="mm" FontWeight="Bold" FontSize="16" />
            </StackPanel>
            <StackPanel Width="450" Margin="0,10,0,0" Orientation="Horizontal" HorizontalAlignment="Left" x:Name="threadSetupValuePanel">
                <Label x:Name="labThreadSetupValue" Width="180"  Height="35" Content="第三次测高" FontWeight="Bold" FontSize="16" />
                <Controls:InputTextBox IsEnabled="False" x:Name="threadSetupValue" Width="180"  TextWrapping="Wrap"  Height="35" InputType="Decimal" XMin="0" XPrecision="5"/>
                <Label Height="35" Content="mm" FontWeight="Bold" FontSize="16" />
            </StackPanel>
        </StackPanel>
        
    </Grid>
    
</Page>
