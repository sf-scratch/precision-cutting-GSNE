<Page x:Class="精密切割系统.View.Pages.Hader.HeaderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:精密切割系统.View.Pages.Hader"
      mc:Ignorable="d" 
      d:DesignHeight="140" d:DesignWidth="1920"
      Title="HeaderPage" Loaded="HeaderPage_Loaded">

    <Grid Background="#DFFCFF" >
        <Image Height="80"  VerticalAlignment="Top" Source="/Assets/picture/head_bg.png" Stretch="Fill" TouchDown="Image_TouchDown" MouseDown="Image_MouseDown"/>
        <WrapPanel VerticalAlignment="Center" Width="Auto" HorizontalAlignment="Left" Margin="20,-20,0,0" Grid.ColumnSpan="2">
            <Label x:Name="labelDay" Content="00:00:00" FontSize="28" FontWeight="Bold" />
            <Label x:Name="labelTime" Content="1990-10-10" FontSize="24" Margin="10,0,10,3" VerticalAlignment="Bottom" />
            <Label x:Name="labelWeek" Content="星期一" FontSize="22" Margin="0,0,0,3" VerticalAlignment="Bottom" FontWeight="Bold" />
        </WrapPanel>
        <WrapPanel VerticalAlignment="Bottom" Width="Auto" HorizontalAlignment="Right" Margin="0,0,30,0" Grid.ColumnSpan="2">
            <StackPanel  VerticalAlignment="Bottom" Width="Auto" HorizontalAlignment="Left" Margin="0 0 20 0" x:Name="urgentRaiseBtn" Orientation="Vertical" TouchDown="urgentRaiseBtn_TouchDown" MouseDown="urgentRaiseBtn_MouseDown">
                <Image Width="58" Height="58" RenderTransformOrigin="0.964,1.2" Source="/Assets/icon/header/up_arrow2_icon.ico"/>
                <Label  Content="紧急抬起" FontSize="20"  Foreground="#1D2123" HorizontalAlignment="Center" FontWeight="Bold" />
            </StackPanel>
            <StackPanel x:Name="sensorBtn" Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center" Width="100" Margin="0 0 20 0">
                <Image  Width="58" Height="58" RenderTransformOrigin="0.964,1.2" Source="/Assets/picture/icon_sensor.png"/>
                <Label  Content="敏感器" FontSize="20"  Foreground="#1D2123" HorizontalAlignment="Center" FontWeight="Bold" />
            </StackPanel>
            <!--<StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center" Width="80" Margin="15,0,15,0">
                <Image  Width="58" Height="58" RenderTransformOrigin="0.964,1.2" Source="/Assets/picture/icon_detecting_terminals.png"/>
                <Label  Content="检测端子" FontSize="15"  Foreground="#1D2123"  HorizontalAlignment="Center"/>
            </StackPanel>-->
            <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center" Width="100" TouchDown="StackPanel_TouchDown" MouseDown="StackPanel_MouseDown">
                <Image  Width="58" Height="58" RenderTransformOrigin="0.964,1.2" Source="/Assets/picture/icon_alarm release.png"/>
                <Label  Content="报警/解除" FontSize="20"  Foreground="#1D2123" HorizontalAlignment="Center" FontWeight="Bold" />
            </StackPanel>
        </WrapPanel>
        <DockPanel  VerticalAlignment="Bottom" Margin="20,0,0,0"    Width="1200" HorizontalAlignment="Left">
            <Label  Content="语言切换占位" FontSize="20" Background="#A3A3A3" Height="45" Width="150" Margin="0,0,30,0" Visibility="Hidden"  />
            <DockPanel  x:Name="messgePanel" Visibility="Collapsed">
                <Border x:Name="messgesBorder" BorderBrush="Red" Background="#A3A3A3" BorderThickness="1" Padding="5,0,5,0">
                    <Label x:Name="messgeLabel" Content="21322132" VerticalContentAlignment="Center" FontSize="26" FontWeight="Bold"  Height="45" HorizontalAlignment="Left"    />
                </Border>
            </DockPanel>
            </DockPanel>
    
        <Button Content="退出应用" Visibility="Collapsed" HorizontalAlignment="Left" Margin="1334,104,0,0" VerticalAlignment="Top" Height="28" Width="93" Click="BtnQuit_Click"/>
    </Grid>
</Page>
