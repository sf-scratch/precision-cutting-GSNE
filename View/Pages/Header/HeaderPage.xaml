<Page
    x:Class="精密切割系统.View.Pages.Hader.HeaderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:精密切割系统.View.Pages.Hader"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="HeaderPage"
    d:DesignHeight="140"
    d:DesignWidth="1920"
    Loaded="HeaderPage_Loaded"
    mc:Ignorable="d">

    <Grid Background="#DFFCFF">
        <Image
            Height="80"
            VerticalAlignment="Top"
            MouseDown="Image_MouseDown"
            Source="/Assets/picture/head_bg.png"
            Stretch="Fill"
            TouchDown="Image_TouchDown" />
        <WrapPanel
            Grid.ColumnSpan="2"
            Width="Auto"
            Margin="20,-20,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center">
            <Label
                x:Name="labelDay"
                Content="00:00:00"
                FontSize="28"
                FontWeight="Bold" />
            <Label
                x:Name="labelTime"
                Margin="10,0,10,3"
                VerticalAlignment="Bottom"
                Content="1990-10-10"
                FontSize="24" />
            <Label
                x:Name="labelWeek"
                Margin="0,0,0,3"
                VerticalAlignment="Bottom"
                Content="星期一"
                FontSize="22"
                FontWeight="Bold" />
        </WrapPanel>
        <WrapPanel
            Grid.ColumnSpan="2"
            Width="Auto"
            Margin="0,0,30,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom">
            <StackPanel
                x:Name="urgentRaiseBtn"
                Width="Auto"
                Margin="0,0,20,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                MouseDown="urgentRaiseBtn_MouseDown"
                Orientation="Vertical"
                TouchDown="urgentRaiseBtn_TouchDown">
                <Image
                    Width="58"
                    Height="58"
                    RenderTransformOrigin="0.964,1.2"
                    Source="/Assets/icon/header/up_arrow2_icon.ico" />
                <Label
                    HorizontalAlignment="Center"
                    Content="紧急抬起"
                    FontSize="20"
                    FontWeight="Bold"
                    Foreground="#1D2123" />
            </StackPanel>
            <StackPanel
                x:Name="sensorBtn"
                Width="100"
                Margin="0,0,20,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Vertical">
                <Image
                    Width="58"
                    Height="58"
                    RenderTransformOrigin="0.964,1.2"
                    Source="/Assets/picture/icon_sensor.png" />
                <Label
                    HorizontalAlignment="Center"
                    Content="敏感器"
                    FontSize="20"
                    FontWeight="Bold"
                    Foreground="#1D2123" />
            </StackPanel>
            <!--<StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center" Width="80" Margin="15,0,15,0">
                <Image  Width="58" Height="58" RenderTransformOrigin="0.964,1.2" Source="/Assets/picture/icon_detecting_terminals.png"/>
                <Label  Content="检测端子" FontSize="15"  Foreground="#1D2123"  HorizontalAlignment="Center"/>
            </StackPanel>-->
            <StackPanel
                Width="100"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MouseDown="StackPanel_MouseDown"
                Orientation="Vertical"
                TouchDown="StackPanel_TouchDown">
                <Image
                    Width="58"
                    Height="58"
                    RenderTransformOrigin="0.964,1.2"
                    Source="/Assets/picture/icon_alarm release.png" />
                <Label
                    HorizontalAlignment="Center"
                    Content="报警/解除"
                    FontSize="20"
                    FontWeight="Bold"
                    Foreground="#1D2123" />
            </StackPanel>
        </WrapPanel>
        <DockPanel
            Width="1200"
            Margin="20,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom">
            <Label
                Width="150"
                Height="45"
                Margin="0,0,30,0"
                Background="#A3A3A3"
                Content="语言切换占位"
                FontSize="20"
                Visibility="Hidden" />
            <DockPanel x:Name="messgePanel" Visibility="Collapsed">
                <Border
                    x:Name="messgesBorder"
                    Padding="5,0,5,0"
                    Background="#A3A3A3"
                    BorderBrush="Red"
                    BorderThickness="1">
                    <Label
                        x:Name="messgeLabel"
                        Height="45"
                        HorizontalAlignment="Left"
                        VerticalContentAlignment="Center"
                        Content="21322132"
                        FontSize="26"
                        FontWeight="Bold" />
                </Border>
            </DockPanel>
        </DockPanel>

        <Button
            Width="93"
            Height="28"
            Margin="1334,104,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Click="BtnQuit_Click"
            Content="退出应用"
            Visibility="Collapsed" />
    </Grid>
</Page>
