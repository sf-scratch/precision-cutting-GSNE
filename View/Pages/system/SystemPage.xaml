<Page
    x:Class="精密切割系统.View.Pages.system.SystemPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:精密切割系统.View.Pages.system"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="SystemPage"
    d:DesignHeight="655"
    d:DesignWidth="1570"
    Loaded="Page_Loaded"
    mc:Ignorable="d">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Label
            Grid.Row="0"
            Margin="0,0,0,30"
            Padding="0,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Content="密码"
            FontSize="30"
            FontWeight="Bold" />
        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <Label
                Width="300"
                Margin="0,0,0,15"
                Content="输入密码："
                FontSize="16" />
            <PasswordBox
                x:Name="inputText"
                Width="300"
                Height="35"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                VerticalContentAlignment="Center"
                PreviewMouseDown="inputText_PreviewMouseDown"
                TouchDown="inputText_TouchDown" />
        </StackPanel>
    </Grid>
</Page>
