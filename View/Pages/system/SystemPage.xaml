<Page x:Class="精密切割系统.View.Pages.system.SystemPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:精密切割系统.View.Pages.system" xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="655" d:DesignWidth="1570"
      Title="SystemPage" Loaded="Page_Loaded">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Label Grid.Row="0" Content="密码" HorizontalAlignment="Left" VerticalAlignment="Bottom" FontSize="30" FontWeight="Bold" Padding="0,0,0,0" Margin="0,0,0,30"/>
        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <Label Content="输入密码：" FontSize="16" Width="300" Margin="0,0,0,15"/>
            <Controls:InputTextBox x:Name="inputText" Width="300" Height="35" VerticalAlignment="Center" InputType="Numeral"  />
        </StackPanel>
    </Grid>
</Page>
