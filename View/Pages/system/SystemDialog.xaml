<Window
    x:Class="精密切割系统.View.Pages.system.SystemDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:精密切割系统.View.Pages.system"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="SystemDialog"
    Width="1920"
    Height="1080"
    AllowsTransparency="True"
    Background="Transparent"
    Loaded="Window_Loaded"
    ResizeMode="NoResize"
    WindowStyle="None"
    mc:Ignorable="d">
    <Grid>
        <Border
            Width="300"
            Height="400"
            Panel.ZIndex="999"
            Background="White"
            CornerRadius="10">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Controls:RightButton
                    x:Name="btnExit"
                    Margin="0,20,0,0"
                    BackFlag="False"
                    BackgroundDefColor="#39D11A"
                    BackgroundDownColor="#39B41A"
                    ContentText="退出系统"
                    ImagePath="/Assets/icon/right/enter.png" />
                <Controls:RightButton
                    x:Name="btnMinimized"
                    Margin="0,20,0,0"
                    BackFlag="False"
                    BackgroundDefColor="#FFAD00"
                    BackgroundDownColor="#C8AD00"
                    ContentText="最小化"
                    ImagePath="/Assets/icon/right/back.png" />
                <Controls:RightButton
                    x:Name="btnCanle"
                    Margin="0,20,0,0"
                    BackFlag="False"
                    BackgroundDefColor="#C6C6C6"
                    BackgroundDownColor="#818181"
                    ContentText="取消"
                    ImagePath="/Assets/icon/right/back.png" />
            </StackPanel>
        </Border>
        <StackPanel
            x:Name="spMasking"
            Background="Black"
            Opacity="0.4" />
    </Grid>
</Window>
