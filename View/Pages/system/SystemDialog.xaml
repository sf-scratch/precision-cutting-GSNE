<Window x:Class="精密切割系统.View.Pages.system.SystemDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:精密切割系统.View.Pages.system" xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
        mc:Ignorable="d"
        Title="SystemDialog" Height="1080" Width="1920" AllowsTransparency="True" ResizeMode="NoResize" WindowStyle="None" Loaded="Window_Loaded" Background="Transparent">
    <Grid>
        <Border Width="300" Height="400" Background="White" Panel.ZIndex="999" CornerRadius="10">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Controls:RightButton  x:Name="btnExit" Margin="0,20,0,0" BackFlag="False"  ContentText="退出系统" ImagePath="/Assets/icon/right/enter.png" BackgroundDefColor="#39D11A" BackgroundDownColor="#39B41A"   />
                <Controls:RightButton x:Name="btnMinimized" Margin="0,20,0,0" BackFlag="False"   ContentText="最小化" ImagePath="/Assets/icon/right/back.png" BackgroundDefColor="#FFAD00" BackgroundDownColor="#C8AD00" />
                <Controls:RightButton x:Name="btnCanle"  BackFlag="False" Margin="0,20,0,0"   ContentText="取消" ImagePath="/Assets/icon/right/back.png" BackgroundDefColor="#C6C6C6" BackgroundDownColor="#818181" />
            </StackPanel>
        </Border>
        <StackPanel x:Name="spMasking" Opacity="0.4" Background="Black" />
    </Grid>
</Window>
