<Page
    x:Class="精密切割系统.View.page.right.RightPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:精密切割系统.View.page.right"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:精密切割系统.ViewModel"
    xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
    Title="RightPage"
    d:DesignHeight="905"
    d:DesignWidth="290"
    d:DataContext="{d:DesignInstance viewModel:RightPageViewModel, IsDesignTimeCreatable=True}"
    Loaded="Page_Loaded"
    mc:Ignorable="d">
    <Page.Resources>
        <Style TargetType="Controls:RightButton">
            <Setter Property="Margin" Value="0,20,0,0" />
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </Page.Resources>
    <Page.DataContext>
        <viewModel:RightPageViewModel></viewModel:RightPageViewModel>
    </Page.DataContext>
    <Grid>
        <StackPanel>
            <!-- 转速、状态显示 -->
            <StackPanel x:Name="ShowTemplate">
                <!-- 头部按钮 -->
                <!--<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Border Grid.Row="0" Grid.Column="0" x:Name="btnPres" Width="120" CornerRadius="10" Background="#177CFA"  Height="40" Margin="0,0,5,0">
                        <Label Content="PRES" Foreground="White" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="1" x:Name="btnSpdl" Width="120" CornerRadius="10" Background="#08DEFE" Height="40" Margin="5,0,0,0">
                        <Label Content="SPDL" Foreground="White" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>
                </StackPanel>
                -->
                <StackPanel Grid.Row="1" Grid.ColumnSpan="2">
                    <StackPanel Margin="20,20,20,0" Orientation="Horizontal">
                        <Label
                            Width="120"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Right"
                            Content="主轴转速"
                            FontSize="20" FontWeight="Bold" />
                        <Label
                            x:Name="spindleSpeedValue"
                            Margin="2,0,0,0"
                            VerticalAlignment="Center"
                            Content="0"
                            FontSize="20" FontWeight="Bold" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Margin="0,20,0,0">
                    <StackPanel Margin="20 10 0 0" HorizontalAlignment="Left">
                        <StackPanel
                            Grid.Row="2"
                            Grid.Column="0"
                            Width="145"
                            Orientation="Horizontal">
                            <Label
                                Margin="0,0,0,0"
                                Width="120"
                                Content="工作盘真空"
                                FontSize="20" FontWeight="Bold" HorizontalContentAlignment="Right" />
                            <Image
                                x:Name="vacuumStateStatusIcon"
                                Width="20"
                                Height="22.86"
                                Margin="5,0,0,0"
                                Source="/Assets/picture/lamp_normal.png" />
                        </StackPanel>
                        <StackPanel
                            Grid.Row="2"
                            Grid.Column="1"
                            Width="145"
                            Margin="0 10 0 10"
                            Orientation="Horizontal">
                            <Label
                                Margin="0,0,0,0"
                                Width="120"
                                Content="主轴气源"
                                FontSize="20" FontWeight="Bold" HorizontalContentAlignment="Right" />
                            <Image
                                x:Name="spindleAirStatusIcon"
                                Width="20"
Height="22.86"
                                Margin="5,0,0,0"
                                Source="/Assets/picture/lamp_error.png" />
                        </StackPanel>
                        <StackPanel
                            Grid.Row="3"
                            Grid.Column="0"
                            Width="145"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                                                    <Label
                                Width="120"
        
                                Content="主轴冷却水"
                                FontSize="20" FontWeight="Bold" HorizontalContentAlignment="Right" />
                                                    <Image
                                x:Name="spindleCoolingWaterStatusIcon"
                                Width="20"
Height="22.86"
                                Margin="5,0,0,0"
                                Source="/Assets/picture/lamp_normal.png" />
                                                </StackPanel>
                                   <StackPanel
                                        Grid.Row="3"
                                        Grid.Column="1"
                                        Width="145"
                                       Margin="0 10 0 0"
                                        Orientation="Horizontal">
                                                    <Label
                                Margin="0,0,0,0"
                                                        
                                Width="120"
                                Content="切割水"
                                FontSize="20" FontWeight="Bold" HorizontalContentAlignment="Right" MouseDown="Label_MouseDown" />
                                                    <Image
                                x:Name="spindleCuttingWaterStatusIcon"
                                Width="20"
Height="22.86"
                                Margin="5,0,0,0"
                                Source="/Assets/picture/lamp_normal.png" />
                                                </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <ListBox Margin="0,0,0,125"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Bottom"
                 Visibility="Visible"
                 Background="Transparent"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.CanContentScroll="True"
                 VirtualizingPanel.ScrollUnit="Pixel"
                 SelectionMode="Extended"
                 BorderThickness="0"
                 BorderBrush="Transparent"
                 ItemsSource="{Binding RightButtonParams}" d:ItemsSource="{d:SampleData}">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Background" Value="Transparent"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="Transparent"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Controls:RightButton
                        BackFlag="{Binding BackFlag}"
                        BackgroundDefColor="{Binding BackgroundDefColor}"
                        BackgroundDownColor="{Binding BackgroundDownColor}"
                        ContentText="{Binding ContentText}"
                        ContentTextFontSize="{Binding ContentTextFontSize}"
                        ImagePath="{Binding ImagePath}"
                        Visibility="{Binding Visibility}">
                        <behaviors:Interaction.Triggers>
                            <behaviors:EventTrigger EventName="RightButtonClicked">
                                <behaviors:InvokeCommandAction Command="{Binding RightClickCommand}"/>
                            </behaviors:EventTrigger>
                            <!-- 按下时开始触发 -->
                            <behaviors:EventTrigger EventName="PreviewMouseDown">
                                <behaviors:InvokeCommandAction Command="{Binding StartCommand}"/>
                            </behaviors:EventTrigger>
                            <!-- 松开时停止 -->
                            <behaviors:EventTrigger EventName="PreviewMouseUp">
                                <behaviors:InvokeCommandAction Command="{Binding StopCommand}"/>
                            </behaviors:EventTrigger>
                            <!-- 鼠标移开时停止 -->
                            <behaviors:EventTrigger EventName="MouseLeave">
                                <behaviors:InvokeCommandAction Command="{Binding StopCommand}"/>
                            </behaviors:EventTrigger>
                            <!-- 支持触摸屏 -->
                            <behaviors:EventTrigger EventName="PreviewTouchDown">
                                <behaviors:InvokeCommandAction Command="{Binding StartCommand}"/>
                            </behaviors:EventTrigger>
                            <behaviors:EventTrigger EventName="PreviewTouchUp">
                                <behaviors:InvokeCommandAction Command="{Binding StopCommand}"/>
                            </behaviors:EventTrigger>
                            <behaviors:EventTrigger EventName="TouchLeave">
                                <behaviors:InvokeCommandAction Command="{Binding StopCommand}"/>
                            </behaviors:EventTrigger>
                        </behaviors:Interaction.Triggers>
                    </Controls:RightButton>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <!--  -底部按钮项项  -->
        <StackPanel
            x:Name="PanelAction"
            Margin="0,0,0,125"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Visibility="Collapsed">
            <!--  半自动切割  -->
            <Controls:RightButton
                x:Name="btnCutStart"
                BackFlag="False"
                BackgroundDefColor="#39D11A"
                BackgroundDownColor="#39B41A"
                ContentText="开始"
                ImagePath="/Assets/icon/right/enter.png"
                Visibility="Collapsed" />
            <Controls:RightButton
                x:Name="btnCutReStart"
                BackFlag="False"
                BackgroundDefColor="#39D11A"
                BackgroundDownColor="#39B41A"
                ContentText="开始"
                ImagePath="/Assets/icon/right/enter.png"
                Visibility="Collapsed" />
            <Controls:RightButton
                x:Name="btnCutPause"
                BackFlag="False"
                BackgroundDefColor="#FFAD00"
                BackgroundDownColor="#C8AD00"
                ContentText="暂停/停止"
                ImagePath="/Assets/icon/right/enter.png"
                Visibility="Collapsed" />
            <Controls:RightButton
                x:Name="btnCutBackward"
                BackFlag="False"
                BackgroundDefColor="#FFAD00"
                BackgroundDownColor="#C8AD00"
                ContentText="向后切"
                ImagePath="/Assets/icon/right/enter.png"
                Visibility="Collapsed" />
            <Controls:RightButton
                x:Name="btnCutFront"
                BackFlag="False"
                BackgroundDefColor="#FFAD00"
                BackgroundDownColor="#C8AD00"
                ContentText="向前切"
                ImagePath="/Assets/icon/right/enter.png"
                Visibility="Collapsed" />
            <!--  半自动切割end  -->
            <!--  手动校准  -->

            <!--  手动校准end  -->
            <!--  测高  -->
            <Controls:RightButton
                x:Name="btnContactSetupSure"
                BackFlag="False"
                BackgroundDefColor="#39D11A"
                BackgroundDownColor="#39B41A"
                ContentText="确定测高"
                ImagePath="/Assets/icon/right/enter.png"
                Visibility="Collapsed" />
            <!--  测高 end  -->
            <Controls:RightButton
                x:Name="btnStartSetup"
                BackFlag="False"
                BackgroundDefColor="#39D11A"
                BackgroundDownColor="#39B41A"
                ContentText="开始测高"
                ImagePath="/Assets/icon/right/enter.png"
                Visibility="Collapsed" />
            <!--  电火花修刀  -->
            <Controls:RightButton
                x:Name="btnElectricalStart"
                BackFlag="False"
                BackgroundDefColor="#39D11A"
                BackgroundDownColor="#39B41A"
                ContentText="开始修刀"
                ImagePath="/Assets/icon/right/enter.png"
                Visibility="Collapsed" />
            <Controls:RightButton
                x:Name="btnElectricalPause"
                BackFlag="False"
                BackgroundDefColor="#39D11A"
                BackgroundDownColor="#39B41A"
                ContentText="暂停修刀"
                ImagePath="/Assets/icon/right/enter.png"
                Visibility="Collapsed" />
            <!--  电火花修刀end  -->
            <Controls:RightButton
                x:Name="btnSee"
                BackFlag="False"
                BackgroundDefColor="#39D11A"
                BackgroundDownColor="#39B41A"
                ContentText="查看"
                ImagePath="/Assets/icon/right/enter.png"
                Visibility="Collapsed" />
            <Controls:RightButton
                x:Name="btnSure"
                BackFlag="False"
                BackgroundDefColor="#39D11A"
                BackgroundDownColor="#39B41A"
                ContentText="确定"
                ImagePath="/Assets/icon/right/enter.png"
                Visibility="Collapsed" />
            <Controls:RightButton
                x:Name="btnBack"
                BackFlag="True"
                BackgroundDefColor="#FFAD00"
                BackgroundDownColor="#C8AD00"
                ContentText="返回"
                ImagePath="/Assets/icon/right/back.png"
                Visibility="Collapsed" />
        </StackPanel>
        <!--  Machine ID  -->
        <StackPanel
            x:Name="MachinePanel"
            VerticalAlignment="Bottom"
            Visibility="Collapsed">
            <StackPanel
                Grid.Row="5"
                Grid.ColumnSpan="2"
                Margin="15,10,15,20">
                <Label
                    Margin="0,0,0,3"
                    Content="机器ID"
                    FontSize="20"
                    FontWeight="Bold" />
                <Controls:InputTextBox
                    x:Name="machineID"
                    Height="40"
                    FontWeight="Bold"
                    IsEnabled="False" />
            </StackPanel>
        </StackPanel>
    </Grid>

</Page>
