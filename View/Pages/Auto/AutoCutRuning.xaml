<UserControl x:Class="精密切割系统.View.Pages.Auto.AutoCutRuning"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:精密切割系统.View.Pages.Auto"
      xmlns:viewModel="clr-namespace:精密切割系统.ViewModel"
      xmlns:custom="clr-namespace:精密切割系统.CustomControls"
      xmlns:auto="clr-namespace:WpfAutoGrid;assembly=WpfAutoGrid.Core" 
      xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
      xmlns:common="clr-namespace:精密切割系统.View.Pages.common"
      xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d"
      d:DesignHeight="676" d:DesignWidth="724"
      d:DataContext="{d:DesignInstance viewModel:AutoCutRuningViewModel, IsDesignTimeCreatable=True}">
    <behaviors:Interaction.Triggers>
        <behaviors:EventTrigger EventName="Loaded">
            <behaviors:InvokeCommandAction
                Command="{Binding RunAutoCutCommand}"
                CommandParameter="可选参数"/>
        </behaviors:EventTrigger>
    </behaviors:Interaction.Triggers>
    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.Resources>
            <ResourceDictionary Source="/Themes/MaterialDesignResources.xaml"/>
        </Grid.Resources>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.ColumnSpan="2" Margin="30,30,0,0" Content="自动执行状态" FontSize="25" FontWeight="Bold" />
            <auto:AutoGrid Grid.Row="1" Margin="10" Columns="4*,4*,2*" RowCount="10" ChildMargin="5">
                <TextBlock Text="测高位置"/>
                <Controls:InputTextBox Text="{Binding AfterHeightMeasurementZ}" IsEnabled="False"/>
                <TextBlock HorizontalAlignment="Left" Text="mm"/>
                <TextBlock Text="磨刀刀片高度"/>
                <Controls:InputTextBox Text="{Binding SharpenBladeHeight}" IsEnabled="False"/>
                <TextBlock HorizontalAlignment="Left" Text="mm"/>
                <TextBlock Text="磨刀速度"/>
                <Controls:InputTextBox Text="{Binding SharpenSpeed}" IsEnabled="False"/>
                <TextBlock HorizontalAlignment="Left" Text="mm/s"/>
                <TextBlock Text="磨刀进度"/>
                <Controls:InputTextBox Text="{Binding SharpenProgress}" IsEnabled="False"/>
                <TextBlock HorizontalAlignment="Left" Text=""/>
                <TextBlock Text="总磨损量"/>
                <Controls:InputTextBox Text="{Binding TotalWearAmount}" IsEnabled="False"/>
                <TextBlock HorizontalAlignment="Left" Text="mm"/>
                <TextBlock Text="型号参数No"/>
                <Controls:InputTextBox Text="{Binding DeviceDataNo}" IsEnabled="False"/>
                <TextBlock HorizontalAlignment="Left" Text=""/>
                <TextBlock Text="切割刀片高度"/>
                <Controls:InputTextBox Text="{Binding CutBladeHeight}" IsEnabled="False"/>
                <TextBlock HorizontalAlignment="Left" Text="mm"/>
                <TextBlock Text="切割速度"/>
                <Controls:InputTextBox Text="{Binding CutSpeed}" IsEnabled="False"/>
                <TextBlock HorizontalAlignment="Left" Text="mm/s"/>
                <TextBlock Text="切割进度"/>
                <Controls:InputTextBox Text="{Binding CutProgress}" IsEnabled="False"/>
                <TextBlock HorizontalAlignment="Left" Text=""/>
                <TextBlock Text="自更换刀片起"/>
                <Controls:InputTextBox Text="{Binding AfterReplaceBladeCutTimes}" IsEnabled="False"/>
                <TextBlock HorizontalAlignment="Left" Text="刀"/>
            </auto:AutoGrid>
            <GroupBox Grid.Row="1" Grid.Column="1" materialDesign:ColorZoneAssist.Mode="SecondaryMid" Margin="0,0,10,0">
                <GroupBox.Resources>
                    <ResourceDictionary>
                        <ResourceDictionary.MergedDictionaries>
                            <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml"/>
                        </ResourceDictionary.MergedDictionaries>
                    </ResourceDictionary>
                </GroupBox.Resources>
                <GroupBox.HeaderTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Width="32" Height="32" VerticalAlignment="Center" Kind="InformationSlabBox" />
                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" FontSize="18" Text="实时信息" FontWeight="Bold"/>
                        </StackPanel>
                    </DataTemplate>
                </GroupBox.HeaderTemplate>
                <custom:ShowLastListBox ItemsSource="{Binding MessageList}" d:ItemsSource="{d:SampleData ItemCount=20}" Style="{StaticResource MaterialDesignListBox}" Height="300">
                    <custom:ShowLastListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesignListBoxItem}">
                            <Setter Property="Margin" Value="0,0,0,1"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="materialDesign:ListBoxItemAssist.ShowSelection" Value="False"/>
                        </Style>
                    </custom:ShowLastListBox.ItemContainerStyle>
                    <custom:ShowLastListBox.ItemTemplate>
                        <DataTemplate>
                            <Border>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontSize="10" Text="{Binding Time}" />
                                        <TextBlock FontSize="12" TextWrapping="Wrap" FontWeight="Bold" Text="{Binding Message}" d:Text="999999999999999999999999999999999999999999999"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </custom:ShowLastListBox.ItemTemplate>
                </custom:ShowLastListBox>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>
