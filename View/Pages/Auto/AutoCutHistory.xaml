<UserControl
    x:Class="精密切割系统.View.Pages.Auto.AutoCutHistory"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:behvr="clr-namespace:精密切割系统.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:精密切割系统.View.Pages.Auto"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:viewModel="clr-namespace:精密切割系统.ViewModel"
    d:DataContext="{d:DesignInstance viewModel:AutoCutHistoryViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="676"
    d:DesignWidth="1448"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="CenteredTextBlockStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
        </Style>
        <Style x:Key="HeaderTextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="16" />
        </Style>
        <Style x:Key="CenteredImageStyle" TargetType="Image">
            <Setter Property="Width" Value="120" />
            <Setter Property="Height" Value="80" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Stretch" Value="UniformToFill" />
        </Style>
        <Style x:Key="MaxImageStyle" TargetType="Image">
            <!--<Setter Property="Width" Value="1920"/>-->
            <Setter Property="Height" Value="1000" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Stretch" Value="UniformToFill" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="30,30,0,0">
        <Grid.Resources>
            <ResourceDictionary Source="pack://application:,,,/精密切割系统;component/Themes/MaterialDesignResources.xaml" />
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
            <Label
                Margin="0,0,10,0"
                VerticalAlignment="Bottom"
                Content="自动切割操作记录"
                FontSize="22"
                FontWeight="Bold" />
            <StackPanel Margin="10,0,0,0" Orientation="Horizontal">
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="20"
                    Text="{Binding StartDate, StringFormat={}{0:yyyy年MM月dd日}}" />
                <Button
                    Margin="8,0,0,0"
                    Command="{Binding SelectStartDateDialogCommand}"
                    Content="{materialDesign:PackIcon CalendarRange}" />
            </StackPanel>
            <StackPanel Margin="50,0,0,0" Orientation="Horizontal">
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="20"
                    Text="{Binding EndDate, StringFormat={}{0:yyyy年MM月dd日}}" />
                <Button
                    Margin="8,0,0,0"
                    Command="{Binding SelectEndDateDialogCommand}"
                    Content="{materialDesign:PackIcon CalendarRange}" />
            </StackPanel>
        </StackPanel>
        <ProgressBar
            Grid.Row="1"
            IsIndeterminate="True"
            Style="{StaticResource MaterialDesignCircularProgressBar}"
            Visibility="{Binding ProgressBarVisibility}"
            Value="0" />
        <ListView
            Grid.Row="1"
            d:ItemsSource="{d:SampleData}"
            Grid.IsSharedSizeScope="True"
            ItemsSource="{Binding KnifeWearList}">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <!--  让内容填充整个单元格  -->
                    <Setter Property="Margin" Value="0,0,0,5" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="materialDesign:ListBoxItemAssist.ShowSelection" Value="False" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.View>
                <GridView>
                    <GridViewColumn>
                        <GridViewColumn.Header>
                            <TextBlock Style="{StaticResource HeaderTextBlockStyle}" Text="开始时间" />
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource CenteredTextBlockStyle}" Text="{Binding StartTime, StringFormat='MM-dd HH:mm'}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn>
                        <GridViewColumn.Header>
                            <TextBlock Style="{StaticResource HeaderTextBlockStyle}" Text="结束时间" />
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource CenteredTextBlockStyle}" Text="{Binding EndTime, StringFormat='MM-dd HH:mm'}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn>
                        <GridViewColumn.Header>
                            <TextBlock Style="{StaticResource HeaderTextBlockStyle}" Text="第一刀刀痕" />
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Image Source="{Binding FirstCutImage}" Style="{StaticResource CenteredImageStyle}">
                                    <behaviors:Interaction.Behaviors>
                                        <behvr:TouchAndClickBehavior TouchAndClickCommand="{x:Static materialDesign:DialogHost.OpenDialogCommand}">
                                            <behvr:TouchAndClickBehavior.CommandParameter>
                                                <Grid>
                                                    <Image Source="{Binding FirstCutImage}" Style="{StaticResource MaxImageStyle}">
                                                        <behaviors:Interaction.Behaviors>
                                                            <behvr:TouchAndClickBehavior TouchAndClickCommand="{x:Static materialDesign:DialogHost.CloseDialogCommand}" />
                                                        </behaviors:Interaction.Behaviors>
                                                    </Image>
                                                </Grid>
                                            </behvr:TouchAndClickBehavior.CommandParameter>
                                        </behvr:TouchAndClickBehavior>
                                    </behaviors:Interaction.Behaviors>
                                </Image>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn>
                        <GridViewColumn.Header>
                            <TextBlock Style="{StaticResource HeaderTextBlockStyle}" Text="第二刀刀痕" />
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Image Source="{Binding SecondCutImage}" Style="{StaticResource CenteredImageStyle}">
                                    <behaviors:Interaction.Behaviors>
                                        <behvr:TouchAndClickBehavior TouchAndClickCommand="{x:Static materialDesign:DialogHost.OpenDialogCommand}">
                                            <behvr:TouchAndClickBehavior.CommandParameter>
                                                <Grid>
                                                    <Image Source="{Binding SecondCutImage}" Style="{StaticResource MaxImageStyle}">
                                                        <behaviors:Interaction.Behaviors>
                                                            <behvr:TouchAndClickBehavior TouchAndClickCommand="{x:Static materialDesign:DialogHost.CloseDialogCommand}" />
                                                        </behaviors:Interaction.Behaviors>
                                                    </Image>
                                                </Grid>
                                            </behvr:TouchAndClickBehavior.CommandParameter>
                                        </behvr:TouchAndClickBehavior>
                                    </behaviors:Interaction.Behaviors>
                                </Image>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn>
                        <GridViewColumn.Header>
                            <TextBlock Style="{StaticResource HeaderTextBlockStyle}" Text="最后一刀刀痕" />
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Image Source="{Binding LastCutImage}" Style="{StaticResource CenteredImageStyle}">
                                    <behaviors:Interaction.Behaviors>
                                        <behvr:TouchAndClickBehavior TouchAndClickCommand="{x:Static materialDesign:DialogHost.OpenDialogCommand}">
                                            <behvr:TouchAndClickBehavior.CommandParameter>
                                                <Grid>
                                                    <Image
                                                        Source="{Binding LastCutImage}"
                                                        Stretch="Uniform"
                                                        Style="{StaticResource MaxImageStyle}">
                                                        <behaviors:Interaction.Behaviors>
                                                            <behvr:TouchAndClickBehavior TouchAndClickCommand="{x:Static materialDesign:DialogHost.CloseDialogCommand}" />
                                                        </behaviors:Interaction.Behaviors>
                                                    </Image>
                                                </Grid>
                                            </behvr:TouchAndClickBehavior.CommandParameter>
                                        </behvr:TouchAndClickBehavior>
                                    </behaviors:Interaction.Behaviors>
                                </Image>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn>
                        <GridViewColumn.Header>
                            <TextBlock Style="{StaticResource HeaderTextBlockStyle}" Text="磨刀次数" />
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource CenteredTextBlockStyle}" Text="{Binding SharpenCount}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn>
                        <GridViewColumn.Header>
                            <TextBlock Style="{StaticResource HeaderTextBlockStyle}" Text="磨损量(mm)" />
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource CenteredTextBlockStyle}" Text="{Binding WearAmount}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn>
                        <GridViewColumn.Header>
                            <TextBlock Style="{StaticResource HeaderTextBlockStyle}" Text="最后磨刀次数" />
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource CenteredTextBlockStyle}" Text="{Binding LastSharpenCount}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn>
                        <GridViewColumn.Header>
                            <TextBlock Style="{StaticResource HeaderTextBlockStyle}" Text="最后磨损量(mm)" />
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource CenteredTextBlockStyle}" Text="{Binding LastWearAmount}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn>
                        <GridViewColumn.Header>
                            <TextBlock Style="{StaticResource HeaderTextBlockStyle}" Text="切割刀数" />
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource CenteredTextBlockStyle}" Text="{Binding CutCount}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>
