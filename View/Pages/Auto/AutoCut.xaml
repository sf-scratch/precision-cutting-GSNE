<UserControl x:Class="精密切割系统.View.Pages.Auto.AutoCut"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:精密切割系统.View.Pages.Auto"
             xmlns:common="clr-namespace:精密切割系统.View.Pages.common"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d" 
             d:DesignHeight="676" d:DesignWidth="1448">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <common:CameraCommon/>
        <ContentControl Grid.Column="1" prism:RegionManager.RegionName="AutoCutStateRegion">
            <d:ContentControl.Content>
                <local:AutoCutRuning/>
            </d:ContentControl.Content>
        </ContentControl>
    </Grid>
</UserControl>
