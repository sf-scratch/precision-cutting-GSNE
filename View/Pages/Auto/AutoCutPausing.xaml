<UserControl x:Class="精密切割系统.View.Pages.Auto.AutoCutPausing"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:精密切割系统.View.Pages.Auto"
      xmlns:viewModel="clr-namespace:精密切割系统.ViewModel"
      xmlns:auto="clr-namespace:WpfAutoGrid;assembly=WpfAutoGrid.Core" 
      xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
      xmlns:common="clr-namespace:精密切割系统.View.Pages.common"
      xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d" 
      d:DesignHeight="676" d:DesignWidth="724"
      d:DataContext="{d:DesignInstance viewModel:AutoCutPausingViewModel, IsDesignTimeCreatable=True}"
      Loaded="Page_Loaded">
    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="greenButton" TargetType="Button">
            <!-- 基本样式设置 -->
            <Setter Property="Background" Value="#39D11A"/>
            <!-- 主色 -->
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#388E3C"/>
            <!-- 边框色 -->
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12 6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <!-- 按钮视觉结构 -->
                        <Border x:Name="border" 
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="4"
                    SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="contentPresenter"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <!-- 按钮的视觉状态 -->
                        <ControlTemplate.Triggers>
                            <!-- 鼠标悬停效果 -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#43A047"/>
                                <!-- 深一点的颜色 -->
                                <Setter Property="BorderBrush" Value="#2E7D32"/>
                            </Trigger>

                            <!-- 按下效果 -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#388E3C"/>
                                <Setter Property="BorderBrush" Value="#1B5E20"/>
                                <Setter TargetName="contentPresenter" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>

                            <!-- 禁用状态 -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#BDBDBD"/>
                                <Setter Property="BorderBrush" Value="#9E9E9E"/>
                                <Setter Property="Foreground" Value="#757575"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="redButton" TargetType="Button">
            <!-- 基本样式设置 -->
            <Setter Property="Background" Value="#FFFF6E3B"/>
            <!-- 主色 -->
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFFF6E3B"/>
            <!-- 边框色 -->
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12 6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <!-- 按钮视觉结构 -->
                        <Border x:Name="border" 
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="4"
                    SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="contentPresenter"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <!-- 按钮的视觉状态 -->
                        <ControlTemplate.Triggers>
                            <!-- 鼠标悬停效果 -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFFF3D3B"/>
                                <!-- 深一点的颜色 -->
                                <Setter Property="BorderBrush" Value="#FFFF3D3B"/>
                            </Trigger>

                            <!-- 按下效果 -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FFFF3D6B"/>
                                <Setter Property="BorderBrush" Value="#FFFF3D6B"/>
                                <Setter TargetName="contentPresenter" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>

                            <!-- 禁用状态 -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#BDBDBD"/>
                                <Setter Property="BorderBrush" Value="#9E9E9E"/>
                                <Setter Property="Foreground" Value="#757575"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.Resources>
            <ResourceDictionary Source="pack://application:,,,/精密切割系统;component/Themes/MaterialDesignResources.xaml"/>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Grid>
            <Label Margin="30,30,0,0" Content="暂停/修整界面" FontSize="25" FontWeight="Bold" />
        </Grid>
        <auto:AutoGrid Grid.Row="1" Margin="10" Columns="2*,2*,*,2*,2*,*" RowCount="6" ChildMargin="4">
            <TextBlock Text="测高位置"/>
            <Controls:InputTextBox Text="{Binding AfterHeightMeasurementZ}" IsEnabled="False"/>
            <TextBlock HorizontalAlignment="Left" Text="mm"/>
            <TextBlock Text="型号参数No"/>
            <Controls:InputTextBox Text="{Binding DeviceDataNo}" IsEnabled="False"/>
            <TextBlock HorizontalAlignment="Left" Text="ID"/>
            <TextBlock Text="磨刀片高度"/>
            <Controls:InputTextBox Text="{Binding SharpenBladeHeight}" IsEnabled="False"/>
            <TextBlock HorizontalAlignment="Left" Text="mm"/>
            <TextBlock Text="切割刀片高度"/>
            <Controls:InputTextBox Text="{Binding CutBladeHeight}" IsEnabled="False"/>
            <TextBlock HorizontalAlignment="Left" Text="mm"/>
            <TextBlock Text="磨刀速度"/>
            <Controls:InputTextBox Text="{Binding SharpenSpeed}" IsEnabled="False"/>
            <TextBlock HorizontalAlignment="Left" Text="mm/s"/>
            <TextBlock Text="切割速度"/>
            <Controls:InputTextBox Text="{Binding CutSpeed}" IsEnabled="False"/>
            <TextBlock HorizontalAlignment="Left" Text="mm/s"/>
            <TextBlock Text="磨刀进度"/>
            <Controls:InputTextBox Text="{Binding SharpenProgress}" IsEnabled="False"/>
            <TextBlock HorizontalAlignment="Left" Text=""/>
            <TextBlock Text="切割进度"/>
            <Controls:InputTextBox Text="{Binding CutProgress}" IsEnabled="False"/>
            <TextBlock HorizontalAlignment="Left" Text=""/>
            <TextBlock Text="自更换刀片起"/>
            <Controls:InputTextBox Text="{Binding AfterReplaceBladeCutTimes}" IsEnabled="False"/>
            <TextBlock HorizontalAlignment="Left" Text="刀"/>
            <TextBlock HorizontalAlignment="Left" Text=""/>
            <TextBlock HorizontalAlignment="Left" Text=""/>
            <TextBlock HorizontalAlignment="Left" Text=""/>
            <TextBlock Text="基准线宽度"/>
            <Controls:InputTextBox Text="{Binding BaselineWidth}" IsEnabled="False"/>
            <TextBlock HorizontalAlignment="Left" Text="mm"/>
            <TextBlock Text="崩边宽度"/>
            <Controls:InputTextBox Text="{Binding BrokenEdgeWidth}" IsEnabled="False"/>
            <TextBlock HorizontalAlignment="Left" Text="mm"/>
        </auto:AutoGrid>
        <!--<common:CommonDirection Grid.Row="2"/>-->
    </Grid>
</UserControl>
