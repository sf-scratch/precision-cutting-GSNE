<Page x:Class="精密切割系统.View.F7_ElectricSpark.ESAxisDataConf"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
      xmlns:local="clr-namespace:精密切割系统.View.F7_ElectricSpark"
      mc:Ignorable="d" 
      d:DesignHeight="676" d:DesignWidth="1520"
      Title="ESAxisDataConf" Loaded="Page_Loaded">
    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1500" />
        </Grid.ColumnDefinitions>
        <!--第一行 跨2列 -->
        <StackPanel Grid.Row="0" Grid.Column="0" x:Name="sp1" Margin="30,30,0,0" Grid.ColumnSpan="2" Orientation="Horizontal" VerticalAlignment="Center" >
            <Label Height="40"  x:Name="lblAxisTitle" Content="轴运动补偿设定(5.1)" FontWeight="Bold" FontSize="22" />
            <Label Height="40" Width="150" x:Name="lblAxis" Content="运动轴" FontWeight="Bold" FontSize="22" HorizontalContentAlignment="Right" />
            <ComboBox x:Name="cbbAxis" Width="120" Height="30" Margin="10,0,0,0" VerticalContentAlignment="Center" SelectionChanged="cbbAxis_SelectedIndexChanged">
                <ComboBox.ItemContainerStyle>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Height" Value="35"/>
                    </Style>
                </ComboBox.ItemContainerStyle>
            </ComboBox>
            <Button x:Name="btnSave10" Content="保存" Width="100" Height="30"  Margin="40,0,0,0" Click="btnSave10_Click"/>
            <Button x:Name="btnExport" Content="数据导出" Width="100" Height="30"  Margin="50,0,0,0" Click="btnExport_Click_1"/>
            <Button x:Name="btnImport" Content="数据导入" Width="100" Height="30"  Margin="20,0,0,0" Click="btnImport_Click_1"/>
        </StackPanel>
        <!--第2行 第1列 -->
        <ScrollViewer Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="30,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!--wpf listview虚拟化IsVirtualizing  Recycling和Standard-->
                <ListView x:Name="pre_listView" Grid.Row="0" Grid.Column="0" ItemsSource="{Binding Col0_99}" 
                    VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" Width="500" >
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel Orientation="Vertical" VerticalAlignment="Top" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="{x:Type ListViewItem}">
                            <Setter Property="Height" Value="45"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView>
                            <!-- DisplayMemberBinding="{Binding Id}" ,CellTemplate 绑定数据方式二选一 -->
                            <GridViewColumn Header="序号" Width="60">
                                <GridViewColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <StackPanel >
                                            <Label Height="35" Width="55" Content="序号" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.HeaderTemplate>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel >
                                            <Label Height="40" Width="55" Content="{Binding Id}" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                                        </StackPanel>                                        
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="位置(毫米)" Width="190">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Controls:InputTextBox Width="175" Height="35"  Text="{Binding AxisPosition}" InputType="Decimal" XMin="-300"  XPrecision="6" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="实际位置激光(毫米)" Width="190">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Controls:InputTextBox Width="175" Height="35" Text="{Binding AxisCompensate}" InputType="Decimal" XMin="-300" XPrecision="6"  />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <!--<GridViewColumn Header="实际位置光栅尺(毫米)" Width="140">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Controls:InputTextBox Width="125" Height="35" Text="{Binding AxisGratingRuler}" InputType="Decimal" XMin="-300" XPrecision="6"  />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>-->
                        </GridView>
                    </ListView.View>
                </ListView>
                <ListView x:Name="pre_listView1" Grid.Row="0" Grid.Column="1" ItemsSource="{Binding Col100_199}" 
                          VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" Width="500">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel Orientation="Vertical" VerticalAlignment="Top"/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="{x:Type ListViewItem}">
                            <Setter Property="Height" Value="45"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView>
                            <!-- DisplayMemberBinding="{Binding Id}" ,CellTemplate 绑定数据方式二选一 -->
                            <GridViewColumn Header="序号" Width="60">
                                <GridViewColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <StackPanel >
                                            <Label Height="35" Width="55" Content="序号" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.HeaderTemplate>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel >
                                            <Label Height="40" Width="55" Content="{Binding Id}" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="位置(毫米)" Width="190">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Controls:InputTextBox Width="175" Height="35"  Text="{Binding AxisPosition}" InputType="Decimal" XMin="-300"  XPrecision="6" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="实际位置激光(毫米)" Width="190">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Controls:InputTextBox Width="175" Height="35" Text="{Binding AxisCompensate}" InputType="Decimal" XMin="-300" XPrecision="6"  />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <!--<GridViewColumn Header="实际位置光栅尺(毫米)" Width="140">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Controls:InputTextBox Width="125" Height="35" Text="{Binding AxisGratingRuler}" InputType="Decimal" XMin="-300" XPrecision="6"  />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>-->
                        </GridView>
                    </ListView.View>
                </ListView>
                <ListView x:Name="pre_listView2"  Grid.Row="0" Grid.Column="2" ItemsSource="{Binding Col200_299}" 
                          VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" Width="500" >
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel Orientation="Vertical" VerticalAlignment="Top"/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="{x:Type ListViewItem}">
                            <Setter Property="Height" Value="45"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView>
                            <!-- DisplayMemberBinding="{Binding Id}" ,CellTemplate 绑定数据方式二选一 -->
                            <GridViewColumn Header="序号" Width="60">
                                <GridViewColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <StackPanel >
                                            <Label Height="35" Width="55" Content="序号" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.HeaderTemplate>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel >
                                            <Label Height="40" Width="55" Content="{Binding Id}" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="位置(毫米)" Width="190">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Controls:InputTextBox Width="175" Height="35"  Text="{Binding AxisPosition}" InputType="Decimal" XMin="-300"  XPrecision="6" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="实际位置激光(毫米)" Width="190">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Controls:InputTextBox Width="175" Height="35" Text="{Binding AxisCompensate}" InputType="Decimal" XMin="-300" XPrecision="6"  />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <!--<GridViewColumn Header="实际位置光栅尺(毫米)" Width="140">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Controls:InputTextBox Width="125" Height="35" Text="{Binding AxisGratingRuler}" InputType="Decimal" XMin="-300" XPrecision="6"  />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>-->
                        </GridView>
                    </ListView.View>
                </ListView>

            </Grid>
        </ScrollViewer>
        <!--第2行 第2列 -->
        <!--<Grid Grid.Row="1" Grid.Column="1">
            <StackPanel Orientation="Vertical" >
                <StackPanel Orientation="Horizontal" Margin="0,50,0,0">
                    <Label Width="100"  Height="35"  x:Name="label8" Content="选择轴" FontWeight="Bold" FontSize="16" HorizontalContentAlignment="Right"/>
                    <ComboBox x:Name="cbShowAxis" Width="140" Height="35" Margin="5,0,0,0" VerticalContentAlignment="Center">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Height" Value="35"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <Label Width="100"  Height="35"  x:Name="label7" Content="位置" FontWeight="Bold" FontSize="16" HorizontalContentAlignment="Right" />
                    <Controls:InputTextBox x:Name="textBox1" TextWrapping="Wrap" Width="140" Height="35" InputType="Decimal" XMin="-2000"  Margin="5,0,0,0" />
