                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <Label Width="100"  Height="35"  x:Name="zwzhi001" Content="" FontWeight="Bold" FontSize="16" HorizontalContentAlignment="Right" />
