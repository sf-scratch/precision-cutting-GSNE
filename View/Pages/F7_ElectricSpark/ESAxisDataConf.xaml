                                                VerticalContentAlignment="Center"
                                                Content="{Binding Id}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="190" Header="位置(毫米)">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Controls:InputTextBox
                                            Width="175"
                                            Height="35"
                                            InputType="Decimal"
                                            Text="{Binding AxisPosition}"
                                            XMin="-300"
                                            XPrecision="6" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="190" Header="实际位置激光(毫米)">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Controls:InputTextBox
                                            Width="175"
                                            Height="35"
                                            InputType="Decimal"
                                            Text="{Binding AxisCompensate}"
                                            XMin="-300"
                                            XPrecision="6" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <!--<GridViewColumn Header="实际位置光栅尺(毫米)" Width="140">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Controls:InputTextBox Width="125" Height="35" Text="{Binding AxisGratingRuler}" InputType="Decimal" XMin="-300" XPrecision="6" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>-->
                        </GridView>
                    </ListView.View>
                </ListView>
                <ListView
                    x:Name="pre_listView2"
                    Grid.Row="0"
                    Grid.Column="2"
                    Width="500"
                    ItemsSource="{Binding Col200_299}"
                    VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel VerticalAlignment="Top" Orientation="Vertical" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="{x:Type ListViewItem}">
                            <Setter Property="Height" Value="45" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView>
                            <!--  DisplayMemberBinding="{Binding Id}" ,CellTemplate 绑定数据方式二选一  -->
                            <GridViewColumn Width="60" Header="序号">
                                <GridViewColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <Label
                                                Width="55"
                                                Height="35"
                                                HorizontalContentAlignment="Center"
                                                VerticalContentAlignment="Center"
                                                Content="序号" />
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.HeaderTemplate>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <Label
                                                Width="55"
                                                Height="40"
                                                HorizontalContentAlignment="Center"
                                                VerticalContentAlignment="Center"
                                                Content="{Binding Id}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="190" Header="位置(毫米)">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Controls:InputTextBox
                                            Width="175"
                                            Height="35"
                                            InputType="Decimal"
                                            Text="{Binding AxisPosition}"
                                            XMin="-300"
                                            XPrecision="6" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="190" Header="实际位置激光(毫米)">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Controls:InputTextBox
                                            Width="175"
                                            Height="35"
                                            InputType="Decimal"
                                            Text="{Binding AxisCompensate}"
                                            XMin="-300"
                                            XPrecision="6" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <!--<GridViewColumn Header="实际位置光栅尺(毫米)" Width="140">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Controls:InputTextBox Width="125" Height="35" Text="{Binding AxisGratingRuler}" InputType="Decimal" XMin="-300" XPrecision="6" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>-->
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </ScrollViewer>
        <!--  第2行 第2列  -->
