<Page
    x:Class="精密切割系统.View.F7_ElectricSpark.ESAxisDataConf"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:精密切割系统.View.F7_ElectricSpark"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="ESAxisDataConf"
    d:DesignHeight="676"
    d:DesignWidth="1520"
    Loaded="Page_Loaded"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="550" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1500" />
        </Grid.ColumnDefinitions>
        <!--  第一行 跨2列  -->
        <StackPanel
            x:Name="sp1"
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Margin="30,30,0,0"
            VerticalAlignment="Center"
            Orientation="Horizontal">
            <Label
                x:Name="lblAxisTitle"
                Content="轴运动补偿设定(5.2)"
                FontSize="30"
                FontWeight="Bold" />
            <Label
                x:Name="lblAxis"
                Width="150"
                Height="40"
                HorizontalContentAlignment="Right"
                Content="运动轴"
                FontSize="22"
                FontWeight="Bold" />
            <ComboBox
                x:Name="cbbAxis"
                Width="120"
                Height="30"
                Margin="10,0,0,0"
                VerticalContentAlignment="Center"
                SelectionChanged="cbbAxis_SelectedIndexChanged">
                <ComboBox.ItemContainerStyle>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Height" Value="35" />
                    </Style>
                </ComboBox.ItemContainerStyle>
            </ComboBox>
            <Button
                x:Name="btnSave10"
                Width="100"
                Height="30"
                Margin="40,0,0,0"
                Click="btnSave10_Click"
                Content="保存" />
            <Button
                x:Name="btnExport"
                Width="100"
                Height="30"
                Margin="50,0,0,0"
                Click="btnExport_Click_1"
                Content="数据导出" />
            <Button
                x:Name="btnImport"
                Width="100"
                Height="30"
                Margin="20,0,0,0"
                Click="btnImport_Click_1"
                Content="数据导入" />
        </StackPanel>
        <!--  第2行 第1列  -->
        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Label
                HorizontalContentAlignment="Right"
                Content="补偿使用状态"
                FontSize="22"
                FontWeight="Bold" />
            <ComboBox
                x:Name="cmbUsageStatus"
                Width="200"
                Height="30"
                Margin="10,0,0,0"
                VerticalContentAlignment="Center">
                <ComboBox.ItemContainerStyle>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Height" Value="35" />
                    </Style>
                </ComboBox.ItemContainerStyle>
            </ComboBox>
        </StackPanel>
        <!--  第3行 第1列  -->
        <ScrollViewer
            Grid.Row="2"
            Grid.Column="0"
            Margin="30,0,0,80"
            VerticalScrollBarVisibility="Auto">
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <!--  wpf listview虚拟化IsVirtualizing  Recycling和Standard  -->
                <ListView
                    x:Name="pre_listView"
                    Width="500"
                    ItemsSource="{Binding Col0_99}"
                    VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel VerticalAlignment="Top" Orientation="Vertical" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="{x:Type ListViewItem}">
                            <Setter Property="Height" Value="45" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView>
                            <!--  DisplayMemberBinding="{Binding Id}" ,CellTemplate 绑定数据方式二选一  -->
                            <GridViewColumn Width="60" Header="序号">
                                <GridViewColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <Label
                                                Width="55"
                                                Height="35"
                                                HorizontalContentAlignment="Center"
                                                VerticalContentAlignment="Center"
                                                Content="序号" />
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.HeaderTemplate>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <Label
                                                Width="55"
                                                Height="40"
                                                HorizontalContentAlignment="Center"
                                                VerticalContentAlignment="Center"
                                                Content="{Binding Id}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="190" Header="位置(毫米)">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Controls:InputTextBox
                                            Width="175"
                                            Height="35"
                                            InputType="Decimal"
                                            Text="{Binding AxisPosition}"
                                            XMin="-300"
                                            XPrecision="6" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="190" Header="实际位置激光(毫米)">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Controls:InputTextBox
                                            Width="175"
                                            Height="35"
                                            InputType="Decimal"
                                            Text="{Binding AxisCompensate}"
                                            XMin="-300"
                                            XPrecision="6" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <!--<GridViewColumn Header="实际位置光栅尺(毫米)" Width="140">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Controls:InputTextBox Width="125" Height="35" Text="{Binding AxisGratingRuler}" InputType="Decimal" XMin="-300" XPrecision="6" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>-->
                        </GridView>
                    </ListView.View>
                </ListView>
                <ListView
                    x:Name="pre_listView1"
                    Grid.Row="0"
                    Grid.Column="1"
                    Width="500"
                    ItemsSource="{Binding Col100_199}"
                    VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel VerticalAlignment="Top" Orientation="Vertical" />
