            <StackPanel Orientation="Vertical">
                <StackPanel Orientation="Horizontal" Margin="0,50,0,0">
                    <Label Width="100"  Height="35"  x:Name="label8" Content="选择轴" FontWeight="Bold" FontSize="16" HorizontalContentAlignment="Right" />
