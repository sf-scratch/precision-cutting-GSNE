                    <Label Width="100"  Height="35"  x:Name="label9" Content="当前位置" FontWeight="Bold" FontSize="16" HorizontalContentAlignment="Right" />
                    <Controls:InputTextBox x:Name="textBox2" TextWrapping="Wrap" Width="140" Height="35" InputType="Decimal" XMin="-2000"  Margin="5,0,0,0" />
