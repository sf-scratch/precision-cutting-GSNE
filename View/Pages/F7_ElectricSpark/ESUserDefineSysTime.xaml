<Page x:Class="精密切割系统.View.Pages.F7_ElectricSpark.ESUserDefineSysTime"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
      xmlns:local="clr-namespace:精密切割系统.View.Pages.F7_ElectricSpark"
      mc:Ignorable="d" 
      d:DesignHeight="657" d:DesignWidth="1587"
      Title="ESUserDefineSysTime" Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions >
            <RowDefinition Height="80"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Label x:Name="lbTilteForm" Margin="30,30,0,0" Content="系统时间设置 (5.3.1)" VerticalAlignment="Center" HorizontalAlignment="Left" Grid.Row="0" Grid.Column="0"  FontWeight="Bold" FontSize="22"/>
        <StackPanel Grid.Row="1" Grid.Column="0" x:Name="sp1" HorizontalAlignment="Left"  Margin="30,0,0,0">
            <StackPanel   Margin="0,40,0,0" Orientation="Horizontal" HorizontalAlignment="Left" >
                <Label Content="当前日期" x:Name="labRotateSpeed"  Width="105"  Height="35" FontWeight="Bold" FontSize="16" HorizontalContentAlignment="Right"/>
                <Controls:InputTextBox x:Name="tbNowTime" Width="340"  Height="35" InputType="Default" IsEnabled="False"/>
            </StackPanel>
             
            <StackPanel   Margin="0,50,0,0" Orientation="Horizontal" HorizontalAlignment="Left">
                <Label Content="年：" Width="100" Height="35" FontWeight="Bold" FontSize="16" HorizontalContentAlignment="Right"/>
                <Controls:InputTextBox x:Name="tbYear" Width="100"  Height="35" Margin="5" InputType="Numeral" XMin="1947" XMax="29999" XAllowNull="False"/>
                <Label Content="月：" Width="70" Height="35" FontWeight="Bold" FontSize="16" HorizontalContentAlignment="Right"/>
                <Controls:InputTextBox x:Name="tbMonth" Width="100"  Height="35" Margin="5" InputType="Numeral" XMin="1" XMax="12" XAllowNull="False"/>
                <Label Content="日：" Width="70" Height="35" FontWeight="Bold" FontSize="16" HorizontalContentAlignment="Right"/>
                <Controls:InputTextBox x:Name="tbDay" Width="100"  Height="35" Margin="5" InputType="Numeral" XMin="1" XMax="31" XAllowNull="False"/>
            </StackPanel>
            <StackPanel  Margin="0,10,0,0" Orientation="Horizontal" HorizontalAlignment="Left">
                <Label Content="时：" Width="100" Height="35" FontWeight="Bold" FontSize="16" HorizontalContentAlignment="Right"/>
                <Controls:InputTextBox x:Name="tbHour" Width="100"  Height="35" Margin="5" InputType="Numeral" XMin="0" XMax="24" XAllowNull="False"/>
                <Label Content="分：" Width="70" Height="35" FontWeight="Bold" FontSize="16" HorizontalContentAlignment="Right" />
                <Controls:InputTextBox x:Name="tbMinute" Width="100"  Height="35" Margin="5" InputType="Numeral" XMin="0" XMax="59" XAllowNull="False"/>
                <Label Content="秒：" Width="70" Height="35" FontWeight="Bold" FontSize="16" HorizontalContentAlignment="Right"/>
                <Controls:InputTextBox x:Name="tbSecond" Width="100"  Height="35" Margin="5" InputType="Numeral" XMin="0" XMax="59" XAllowNull="False"/>
            </StackPanel> 
        </StackPanel> 
    </Grid>
</Page>
