<UserControl
    x:Class="精密切割系统.View.Pages.F7_ElectricSpark.F7_2_Axis_Operation"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
    xmlns:auto="clr-namespace:WpfAutoGrid;assembly=WpfAutoGrid.Core"
    xmlns:behav="clr-namespace:精密切割系统.Behaviors"
    xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:converters="clr-namespace:精密切割系统.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:精密切割系统.ViewModel"
    d:DataContext="{d:DesignInstance viewModel:F7_2_AxisOperationViewModel}"
    d:DesignHeight="676"
    d:DesignWidth="1448"
    Background="#FFDFFCFF"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:BooleanToColorConverter
            x:Key="BoolToColorConverter"
            FalseColor="OrangeRed"
            TrueColor="LawnGreen" />
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FFDFFCFF" />
            <Setter Property="BorderBrush" Value="LightBlue" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Width" Value="152" />
            <Setter Property="Height" Value="52" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="16" />
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="Background" Value="#FFDFFCFF" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style BasedOn="{StaticResource InputTextStyle}" TargetType="Controls:InputTextBox">
            <Setter Property="Width" Value="152" />
            <Setter Property="Height" Value="52" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style BasedOn="{StaticResource MaterialDesignFloatingHintTextBox}" TargetType="TextBox">
            <Setter Property="Width" Value="152" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="18" />
        </Style>
    </UserControl.Resources>
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid>
            <Label
                Padding="0,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Content="轴运动控制"
                FontSize="30"
                FontWeight="Bold" />
        </Grid>
        <ListBox
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            d:ItemsSource="{d:SampleData ItemCount=3}"
            ItemsSource="{Binding AxisOperationList}"
            ScrollViewer.CanContentScroll="True"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            SelectionMode="Extended"
            VirtualizingPanel.ScrollUnit="Pixel"
            Visibility="Visible">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Background" Value="Transparent" />
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="Transparent" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <auto:AutoGrid
                        ChildMargin="20,20"
                        Columns="*,*,*,*,*,*"
                        Orientation="Horizontal"
                        RowCount="2">
                        <RadioButton
                            Width="152"
                            Height="52"
                            Margin="20,0"
                            Content="{Binding AxisName}"
                            FontSize="20"
                            FontWeight="Bold"
                            GroupName="GroupChoiceChip"
                            IsChecked="{Binding IsChecked}"
                            Style="{StaticResource MaterialDesignChoiceChipSecondaryRadioButton}" />
                        <TextBox
                            materialDesign:HintAssist.Hint="当前位置(mm)"
                            IsEnabled="False"
                            Text="{Binding CurPosition}" />
                        <TextBox
                            materialDesign:HintAssist.Hint="轴慢速度(mm/s)"
                            IsEnabled="False"
                            Text="{Binding AxisSlowSpeed}" />
                        <TextBox materialDesign:HintAssist.Hint="轴速度(mm/s)" Text="{Binding AxisSpeed}" />
                        <TextBox materialDesign:HintAssist.Hint="相对运动长度(mm)" Text="{Binding RelativeDistance}" />
                        <materialDesign:PackIcon
                            Width="40"
                            Height="40"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{Binding IsReady, Converter={StaticResource BoolToColorConverter}}">
                            <materialDesign:PackIcon.Style>
                                <Style TargetType="materialDesign:PackIcon">
                                    <Setter Property="Kind" Value="LightbulbOn" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsReady}" Value="False">
                                            <Setter Property="Kind" Value="LightbulbAlert" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </materialDesign:PackIcon.Style>
                        </materialDesign:PackIcon>
                        <!--<Controls:InputTextBox Background="{Binding IsReady, Converter={StaticResource BoolToColorConverter}}" IsEnabled="False" />-->
                    </auto:AutoGrid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
