<Page x:Class="精密切割系统.View.F7_ElectricSpark.ESUserDefineDataConf"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:精密切割系统.ViewModel"
      xmlns:Controls="clr-namespace:精密切割系统.View.Controls" 
      mc:Ignorable="d" 
      d:DesignHeight="657" d:DesignWidth="1587"
      Title="ESUserDefineDataConf" Loaded="Page_Loaded">
    <Page.DataContext>
        <local:UserDefineDataViewModel></local:UserDefineDataViewModel>
    </Page.DataContext>
    <Grid x:Name="bigGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"></RowDefinition>
            <RowDefinition Height="65"></RowDefinition>
            <RowDefinition Height="65"></RowDefinition>
            <RowDefinition Height="65"></RowDefinition>
            <RowDefinition Height="65"></RowDefinition>
            <RowDefinition Height="65"></RowDefinition>
            <RowDefinition Height="65"></RowDefinition>
            <RowDefinition Height="65"></RowDefinition>
            <RowDefinition Height="65"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="800"/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Label x:Name="labUserDefineData" Content="功能参数设定（5.3）" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="30" Margin="30,30,0,0" FontWeight="Bold"/>
        <Label Content="机器ID" HorizontalAlignment="Left" Grid.Row="1" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="30,0,0,0" />
        <Controls:InputTextBox x:Name="inputMachineId" Text="{Binding Path=MachineId,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Grid.ColumnSpan="1" HorizontalAlignment="Left" Grid.Row="1" TextWrapping="Wrap" VerticalAlignment="Top" Width="300" Height="32" Margin="35,30,0,0" MaxLength="20" XAllowNull="False"/>

        <Label x:Name="labPassword" Content="密码" HorizontalAlignment="Left" Grid.Row="2" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="30,0,0,0"/>
        <PasswordBox x:Name="inputPassword" Grid.ColumnSpan="2" HorizontalAlignment="Left" Grid.Row="2" VerticalAlignment="Top" Width="300" Height="32" Margin="35,30,0,0" />

        <Label x:Name="labAtomizingNozzlePosition" Content="雾化喷嘴位置" HorizontalAlignment="Left" Grid.Row="3" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="30,0,0,0"/>
        <Label Content="X" HorizontalAlignment="Left" Grid.Row="3" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="30,31,0,0"/>
        <Controls:InputTextBox x:Name="inputAtomizingNozzlePositionX" Text="{Binding Path=AtomizingNozzlePositionX,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Grid.ColumnSpan="3" HorizontalAlignment="Left" Grid.Row="3" TextWrapping="Wrap" VerticalAlignment="Top" Width="128" Height="32"   XMax="300" XMin="-200" Margin="60,30,0,0" InputType="Decimal"/>
        <Label Content="mm" HorizontalAlignment="Left" Grid.Row="3" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="190,30,0,0"/>

        <Label Content="Y" HorizontalAlignment="Left" Grid.Row="4" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="30,5,0,0"/>
        <Controls:InputTextBox x:Name="inputAtomizingNozzlePositionY" Text="{Binding Path=AtomizingNozzlePositionY,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Grid.ColumnSpan="4" HorizontalAlignment="Left" Grid.Row="4" TextWrapping="Wrap" VerticalAlignment="Top" Width="128" Height="32"   XMax="300" XMin="-200" Margin="60,4,0,0" InputType="Decimal" />
        <Label Content="mm" HorizontalAlignment="Left" Grid.Row="4" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="190,4,0,0"/>

        <Label x:Name="labPosAfterEdgeDress" Content="刀座修整时Y轴位置" HorizontalAlignment="Left" Grid.Row="5" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="30,0,0,0"/>
        <Controls:InputTextBox x:Name="inputAfterEdgeDressPos" Text="{Binding Path=AfterEdgeDressPos,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Grid.ColumnSpan="5" HorizontalAlignment="Left" Grid.Row="5" TextWrapping="Wrap" VerticalAlignment="Top" Width="128" Height="32"   XMax="300" XMin="-200" Margin="35,30,0,0" InputType="Decimal" />
        <Label Content="mm" HorizontalAlignment="Left" Grid.Row="5" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="165,30,0,0"/>

        <Label x:Name="labBladeExchangeYPos" Content="交换刀片时Y轴位置" HorizontalAlignment="Left" Grid.Row="5" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="220,0,0,0"/>
        <Controls:InputTextBox x:Name="inputBladeExchangeYPos" Text="{Binding Path=BladeExchangeYPos,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Grid.ColumnSpan="5" HorizontalAlignment="Left" Grid.Row="5" TextWrapping="Wrap" VerticalAlignment="Top" Width="128" Height="32"    XMax="300" XMin="-200" Margin="225,30,0,0" InputType="Decimal" />
        <Label Content="mm" HorizontalAlignment="Left" Grid.Row="5" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="355,30,0,0"/>

        <Label x:Name="label14" Content="基准线调整极限" HorizontalAlignment="Left" Grid.Row="5" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="450,0,0,0"/>
        <Controls:InputTextBox x:Name="inputHairlineAdjustLimit" Text="{Binding Path=HairlineAdjustLimit,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Grid.ColumnSpan="5" HorizontalAlignment="Left" Grid.Row="5" TextWrapping="Wrap" VerticalAlignment="Top" Width="128" Height="32"   XMax="300" XMin="-200" Margin="455,30,0,0" InputType="Decimal" />
        <Label Content="mm" HorizontalAlignment="Left" Grid.Row="5" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="590,30,0,0"/>

        <Label x:Name="labBlowTimeCT" Content="吹气时间（C/T）" HorizontalAlignment="Left" Grid.Row="6" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="30,0,0,0"/>
        <Controls:InputTextBox x:Name="inputBlowTime" Text="{Binding Path=BlowTime,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Grid.ColumnSpan="6" HorizontalAlignment="Left" Grid.Row="6" TextWrapping="Wrap" VerticalAlignment="Top" Width="128" Height="32"   XMax="300" XMin="-200" Margin="35,30,0,0" InputType="Decimal" />
        <Label x:Name="label18" Content="s" HorizontalAlignment="Left" Grid.Row="6" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="165,30,0,0"/>

        <Label Content="工作真空检查时间" Visibility="Collapsed" HorizontalAlignment="Left" Grid.Row="6" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="220,0,0,0"/>
        <Controls:InputTextBox Visibility="Collapsed" Text="{Binding Path=WorkVacuumCheckTime,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Grid.ColumnSpan="6" HorizontalAlignment="Left" Grid.Row="6" TextWrapping="Wrap" VerticalAlignment="Top" Width="128" Height="32"   XMax="300" XMin="-200" Margin="225,30,0,0" InputType="Decimal" />
        <Label Content="s" Visibility="Collapsed" HorizontalAlignment="Left" Grid.Row="6" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="355,30,0,0"/>

        <Label Content="节能时间" Visibility="Collapsed" HorizontalAlignment="Left" Grid.Row="6" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="450,0,0,0"/>
        <Controls:InputTextBox Visibility="Collapsed" Text="{Binding Path=WaitTimeUntilEnergySavingMode,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Grid.ColumnSpan="6" HorizontalAlignment="Left" Grid.Row="6" TextWrapping="Wrap" VerticalAlignment="Top" Width="128" Height="32"   XMax="300" XMin="-200" Margin="455,30,0,0" InputType="Decimal"/>
        <Label Content="mm" Visibility="Collapsed" HorizontalAlignment="Left" Grid.Row="6" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="590,30,0,0"/>
        <CheckBox Content="BBO被检出时回云轴停止" Visibility="Collapsed" HorizontalAlignment="Left" IsChecked="{Binding Path=StopSpindleByBbd,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Grid.Row="7" VerticalAlignment="Top" Margin="35,20,0,0" FontSize="16" FontWeight="Bold"/>

        <Label Content="语言" HorizontalAlignment="Left" Grid.Column="1" Grid.Row="1" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="0,0,0,0"/>
        <ComboBox ItemsSource="{Binding Path= Languages}" Text="{Binding Path=Language,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Top" Width="300" Height="32" Margin="5,31,0,0"  Grid.Row="1" SelectionChanged="ComboBox_SelectionChanged" FontSize="14" FontWeight="Bold" VerticalContentAlignment="Center">
        </ComboBox>

        <Label Content="型号改变后速度清零" Visibility="Collapsed" HorizontalAlignment="Left" Grid.Column="1" Grid.Row="1" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="0,0,0,0"/>
        <ComboBox Visibility="Collapsed" ItemsSource="{Binding Path= DeviceChangeCutSpeeds}" Text="{Binding Path=DeviceChangeCutSpeed,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Grid.Column="1"  HorizontalAlignment="Left" VerticalAlignment="Top" Width="300" Height="32" Margin="5,31,0,0"  Grid.Row="2" SelectionChanged="ComboBox_SelectionChanged" FontSize="14" FontWeight="Bold" VerticalContentAlignment="Center">
        </ComboBox>

        <Label Content="速度变更" HorizontalAlignment="Left" Grid.Column="1" Grid.Row="2" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="0,0,0,0"/>
        <ComboBox Grid.Column="1" ItemsSource="{Binding Path= SpeedChanges}" Text="{Binding Path=SpeedChange,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" VerticalAlignment="Top" Width="300" Height="32" Margin="5,31,0,0"  Grid.Row="2" SelectionChanged="ComboBox_SelectionChanged" FontSize="14" FontWeight="Bold" VerticalContentAlignment="Center" >
        </ComboBox>

        <Label Content="高度补偿" HorizontalAlignment="Left" Grid.Column="1" Grid.Row="3" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="0,0,0,0"/>
        <ComboBox Grid.Column="1" ItemsSource="{Binding Path= HeightChanges}" Text="{Binding Path=HeightChange,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" VerticalAlignment="Top" Width="300" Height="32" Margin="5,31,0,0"  Grid.Row="3" SelectionChanged="ComboBox_SelectionChanged" FontSize="14" FontWeight="Bold" VerticalContentAlignment="Center">
        </ComboBox>

        <Label Content="校准时是否进行过切割的检查" Visibility="Collapsed" HorizontalAlignment="Left" Grid.Column="1" Grid.Row="4" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="0,0,0,0"/>
        <ComboBox Visibility="Collapsed" ItemsSource="{Binding Path= CutWorkCheckWhenAlignments}" Grid.Column="1" Text="{Binding Path=CutWorkCheckWhenAlignment,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" VerticalAlignment="Top" Width="300" Height="32" Margin="5,31,0,0"  Grid.Row="4" SelectionChanged="ComboBox_SelectionChanged" FontSize="14" FontWeight="Bold" VerticalContentAlignment="Center">
        </ComboBox>

        <Label Content="刀片使用限制错误后继续" Visibility="Collapsed" HorizontalAlignment="Left" Grid.Column="1" Grid.Row="5" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="0,0,0,0"/>
        <ComboBox Visibility="Collapsed" ItemsSource="{Binding Path= ContinueAfterBladeUserLimitErrors }" Grid.Column="1" Text="{Binding Path=ContinueAfterBladeUserLimitError,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" VerticalAlignment="Top" Width="300" Height="32" Margin="5,31,0,0"  Grid.Row="5" SelectionChanged="ComboBox_SelectionChanged" FontSize="14" FontWeight="Bold" VerticalContentAlignment="Center">
        </ComboBox>

        <Label Visibility="Collapsed" Content="刀片使用极限误差处理" HorizontalAlignment="Left" Grid.Column="1" Grid.Row="6" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="0,0,0,0"/>
        <ComboBox Visibility="Collapsed" ItemsSource="{Binding Path= ProcessingAfterBladeUserLimitErrors }" Grid.Column="1" Text="{Binding Path=ProcessingAfterBladeUserLimitError,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" VerticalAlignment="Top" Width="300" Height="32" Margin="5,31,0,0"  Grid.Row="6" SelectionChanged="ComboBox_SelectionChanged" FontSize="14" FontWeight="Bold" VerticalContentAlignment="Center">
        </ComboBox>

        <Label Visibility="Collapsed" Content="BBD动作时刻" HorizontalAlignment="Left" Grid.Column="1" Grid.Row="7" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="0,0,0,0"/>
        <ComboBox Visibility="Collapsed" ItemsSource="{Binding Path= BBDTimings }" Grid.Column="1" Text="{Binding Path=BBDTiming,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" VerticalAlignment="Top" Width="300" Height="32" Margin="5,31,0,0"  Grid.Row="7" SelectionChanged="ComboBox_SelectionChanged" FontSize="14" FontWeight="Bold" VerticalContentAlignment="Center">
        </ComboBox>

        <Label Content="基准线校准" Visibility="Collapsed" HorizontalAlignment="Left" Grid.Column="2" Grid.Row="1" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="0,0,0,0"/>
        <ComboBox Visibility="Collapsed" ItemsSource="{Binding Path= HairlineAdjustments }" Grid.Column="2" Text="{Binding Path=HairlineAdjustment,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" VerticalAlignment="Top" Width="300" Height="32" Margin="5,31,0,0"  Grid.Row="1" SelectionChanged="ComboBox_SelectionChanged" FontSize="14" FontWeight="Bold" VerticalContentAlignment="Center">
        </ComboBox>

        <Label Content="手动调光" Visibility="Collapsed" HorizontalAlignment="Left" Grid.Column="2" Grid.Row="2" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="0,0,0,0"/>
        <ComboBox Visibility="Collapsed" ItemsSource="{Binding Path= LightingAdjustments }" Grid.Column="2" Text="{Binding Path=LightingAdjustment,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" VerticalAlignment="Top" Width="300" Height="32" Margin="5,31,0,0"  Grid.Row="2" SelectionChanged="ComboBox_SelectionChanged" FontSize="14" FontWeight="Bold" VerticalContentAlignment="Center">
        </ComboBox>

        <Label Content="刀片更换检查" Visibility="Collapsed" HorizontalAlignment="Left" Grid.Column="2" Grid.Row="3" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="0,0,0,0"/>
        <ComboBox Visibility="Collapsed" ItemsSource="{Binding Path= BladeReplacementChecks }" Grid.Column="2" Text="{Binding Path=BladeReplacementCheck,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" VerticalAlignment="Top" Width="300" Height="32" Margin="5,31,0,0"  Grid.Row="3" SelectionChanged="ComboBox_SelectionChanged" FontSize="14" FontWeight="Bold" VerticalContentAlignment="Center">
        </ComboBox>

        <Label Content="Z轴加工数据选择" Visibility="Collapsed" HorizontalAlignment="Left" Grid.Column="2" Grid.Row="4" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="0,0,0,0"/>
        <ComboBox Visibility="Collapsed" ItemsSource="{Binding Path= ZProcessingDataSelections }" Grid.Column="2" Text="{Binding Path=ZProcessingDataSelection,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" VerticalAlignment="Top" Width="300" Height="32" Margin="5,31,0,0"  Grid.Row="4" SelectionChanged="ComboBox_SelectionChanged" FontSize="14" FontWeight="Bold" VerticalContentAlignment="Center">
        </ComboBox>

        <Label Visibility="Collapsed" Content="半自动切割时是否对齐" HorizontalAlignment="Left" Grid.Column="2" Grid.Row="5" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="0,0,0,0"/>
        <ComboBox Visibility="Collapsed" ItemsSource="{Binding Path= AlignSelectionsWhenSemiAutoCutting }" Grid.Column="2" Text="{Binding Path=AlignSelectionWhenSemiAutoCutting,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" VerticalAlignment="Top" Width="300" Height="32" Margin="5,31,0,0"  Grid.Row="5" SelectionChanged="ComboBox_SelectionChanged" FontSize="14" FontWeight="Bold" VerticalContentAlignment="Center">
        </ComboBox>

        <Label Visibility="Collapsed" Content="主轴中心位置（偏移）" HorizontalAlignment="Left" Grid.Row="6" VerticalAlignment="Top" FontSize="16" FontWeight="Bold"  Grid.Column="2"/>
        <Controls:InputTextBox Visibility="Collapsed" Text="{Binding Path=SpindleCenterPositionOffset,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Grid.Column="2" Grid.ColumnSpan="2" HorizontalAlignment="Left" Grid.Row="6" TextWrapping="Wrap" VerticalAlignment="Top" Width="300" Height="32"  XMax="300" XMin="-200" Margin="5,30,0,0" />
        <Label Visibility="Collapsed" Content="mm" HorizontalAlignment="Left" Grid.Row="6" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="305,30,0,0" Grid.Column="2"/>

        <Label Content="水泵开启频率" Visibility="Collapsed" HorizontalAlignment="Left" Grid.Row="7" VerticalAlignment="Top" FontSize="16" FontWeight="Bold"  Grid.Column="2"/>
        <Controls:InputTextBox Visibility="Collapsed" Text="{Binding Path=WaterPumpOnTimer,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Grid.Column="2" Grid.ColumnSpan="2" HorizontalAlignment="Left" Grid.Row="7" TextWrapping="Wrap" VerticalAlignment="Top" Width="300" Height="32"    XMax="300" XMin="-200" Margin="5,30,0,0" />
        <Label Visibility="Collapsed" Content="s" HorizontalAlignment="Left" Grid.Row="7" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Margin="305,30,0,0" Grid.Column="2"/>

    </Grid>
</Page>
