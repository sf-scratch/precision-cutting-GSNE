<Page
    x:Class="精密切割系统.View.F7_ElectricSpark.ESIOCheckConf"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:精密切割系统.View.F7_ElectricSpark"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="ESIOCheckConf"
    d:DesignHeight="776"
    d:DesignWidth="1448"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded"
    mc:Ignorable="d">

    <Grid
        Width="1350"
        Height="600"
        ShowGridLines="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="30" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="30" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <Label
            x:Name="labIOCheck"
            Grid.Row="0"
            Margin="32,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="I/O检查(5.3)"
            FontSize="30"
            FontWeight="Bold" />
        <Label
            x:Name="label19"
            Grid.Row="1"
            Width="120"
            Margin="32,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="DI"
            FontSize="12"
            FontWeight="Bold" />
        <Grid Grid.Row="2">
            <ItemsControl ItemsSource="{Binding DataItems}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:ESIOCheckConfDataModel}">
                        <Border
                            x:Name="sepBd"
                            Margin="5,5,5,5"
                            BorderBrush="LightGray"
                            BorderThickness="1"
                            MouseLeftButtonDown="sepBd_MouseLeftButtonDown">
                            <StackPanel Width="140" Orientation="Vertical">
                                <Label
                                    Width="140"
                                    Height="30"
                                    VerticalAlignment="Center"
                                    HorizontalContentAlignment="Center"
                                    Content="{Binding No}"
                                    FontSize="12"
                                    FontWeight="Bold" />
                                <Label
                                    Width="140"
                                    Height="30"
                                    VerticalAlignment="Center"
                                    HorizontalContentAlignment="Center"
                                    Content="{Binding Desc}"
                                    FontSize="12"
                                    FontWeight="Bold" />
                                <Label
                                    Width="120"
                                    Height="35"
                                    Margin="0,0,0,8"
                                    VerticalAlignment="Center"
                                    HorizontalContentAlignment="Center"
                                    Content="{Binding Status}"
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Foreground="{Binding Brush}">
                                    <Label.Template>
                                        <ControlTemplate TargetType="Label">
                                            <Border
                                                x:Name="stpLabel"
                                                BorderBrush="#FF9E9898"
                                                BorderThickness="1"
                                                CornerRadius="1">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <!--  可以设置多个条件,多给属性当内容是Off时  -->
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="Content" Value="Off" />
                                                    </MultiTrigger.Conditions>
                                                    <MultiTrigger.Setters>
                                                        <Setter TargetName="stpLabel" Property="Background" Value="LightGray" />
                                                    </MultiTrigger.Setters>
                                                </MultiTrigger>
                                                <!--  单一属性改变 设置属性值  -->
                                                <Trigger Property="Content" Value="On">
                                                    <Setter TargetName="stpLabel" Property="BorderBrush" Value="Beige" />
                                                    <Setter TargetName="stpLabel" Property="Background" Value="Beige" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Label.Template>
                                </Label>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </Grid>

        <Label
            x:Name="label99"
            Grid.Row="3"
            Width="120"
            Margin="32,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="DO"
            FontSize="12"
            FontWeight="Bold" />
        <Grid Grid.Row="4">
            <ItemsControl ItemsSource="{Binding DataItems2}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:ESIOCheckConfDataModel}">
                        <!--  Background：背景色 BorderBrush：边框颜色  -->
                        <Border
                            x:Name="sepBd"
                            Margin="5,5,5,5"
                            Background="#FFAAD6FD"
                            BorderBrush="#FF9E9898"
                            BorderThickness="1"
                            MouseLeftButtonDown="sepBd_MouseLeftButtonDown_1">
                            <StackPanel Width="140" Orientation="Vertical">
                                <Label
                                    Width="140"
                                    Height="30"
                                    VerticalAlignment="Center"
                                    HorizontalContentAlignment="Center"
                                    Content="{Binding No}"
                                    FontSize="12"
                                    FontWeight="Bold" />
                                <Label
                                    Width="140"
                                    Height="30"
                                    VerticalAlignment="Center"
                                    HorizontalContentAlignment="Center"
                                    Content="{Binding Desc}"
                                    FontSize="12"
                                    FontWeight="Bold" />
                                <Label
                                    Width="120"
                                    Height="35"
                                    Margin="0,0,0,8"
                                    VerticalAlignment="Center"
                                    HorizontalContentAlignment="Center"
                                    Content="{Binding Status}"
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Foreground="{Binding Brush}"
                                    PreviewMouseDown="Label_PreviewMouseDown"
                                    TouchDown="Label_TouchDown">
                                    <Label.Template>
                                        <ControlTemplate TargetType="Label">
                                            <Border
                                                x:Name="stpLabel"
                                                Background="LightBlue"
                                                BorderBrush="#FF65B7FF"
                                                BorderThickness="1"
                                                CornerRadius="1">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <!--  可以设置多个条件,多给属性当内容是Off时  -->
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="Content" Value="Off" />
                                                    </MultiTrigger.Conditions>
                                                    <MultiTrigger.Setters>
                                                        <!--<Setter Property="Background" TargetName="stpLabel" Value="LightGray"/>-->
                                                    </MultiTrigger.Setters>
                                                </MultiTrigger>
                                                <!--  单一属性改变 设置属性值  -->
                                                <Trigger Property="Content" Value="On">
                                                    <Setter TargetName="stpLabel" Property="BorderBrush" Value="Beige" />
                                                    <Setter TargetName="stpLabel" Property="Background" Value="Beige" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Label.Template>
                                </Label>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </Grid>

    </Grid>
</Page>
