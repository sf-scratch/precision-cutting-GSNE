<Page x:Class="精密切割系统.View.F7_ElectricSpark.ESIOCheckConf"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
      xmlns:local="clr-namespace:精密切割系统.View.F7_ElectricSpark"
      mc:Ignorable="d" 
      d:DesignHeight="776" d:DesignWidth="1448"
      Title="ESIOCheckConf" Loaded="Page_Loaded" Unloaded="Page_Unloaded"> 
    
    <Grid Width="1350" Height="600" ShowGridLines="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Label Grid.Row="0" x:Name="labIOCheck" Content="I/O检查" FontWeight="Bold" FontSize="22" Width="120" Margin="32,0,0,0"  HorizontalAlignment="Left" VerticalAlignment="Center"/>
        <Label Grid.Row="1" x:Name="label19" Content="DI" FontWeight="Bold" FontSize="12" Width="120" Margin="32,0,0,0"  HorizontalAlignment="Left" VerticalAlignment="Center"/>
        <Grid Grid.Row="2" >
            <ItemsControl ItemsSource="{Binding DataItems}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:ESIOCheckConfDataModel}">
                        <Border BorderBrush="LightGray" BorderThickness="1" Margin="5,5,5,5" x:Name="sepBd" MouseLeftButtonDown="sepBd_MouseLeftButtonDown">
                            <StackPanel  Orientation="Vertical" Width="140">
                                <Label Width="140"  Height="30"  Content="{Binding No}" FontWeight="Bold" FontSize="12" HorizontalContentAlignment="Center" VerticalAlignment="Center"/>
                                <Label Width="140"  Height="30"  Content="{Binding Desc}" FontWeight="Bold" FontSize="12" HorizontalContentAlignment="Center" VerticalAlignment="Center"/>
                                <Label Width="120"  Height="35"  Foreground="{Binding Brush}" Content="{Binding Status}" FontWeight="Bold" FontSize="12" Margin="0,0,0,8" HorizontalContentAlignment="Center" VerticalAlignment="Center">
                                    <Label.Template>
                                        <ControlTemplate TargetType="Label">
                                            <Border BorderBrush="#FF9E9898" BorderThickness="1" CornerRadius="1" x:Name="stpLabel">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <!--可以设置多个条件,多给属性当内容是Off时-->
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="Content" Value="Off"/>
                                                    </MultiTrigger.Conditions>
                                                    <MultiTrigger.Setters>
                                                        <Setter Property="Background" TargetName="stpLabel" Value="LightGray"/>
                                                    </MultiTrigger.Setters>
                                                </MultiTrigger>
                                                <!--单一属性改变 设置属性值-->
                                                <Trigger Property="Content" Value="On">
                                                    <Setter TargetName="stpLabel" Property="BorderBrush" Value="Beige" />
                                                    <Setter TargetName="stpLabel" Property="Background" Value="Beige" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Label.Template>
                                </Label>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </Grid>
        
        <Label Grid.Row="3" x:Name="label99" Content="DO" FontWeight="Bold" FontSize="12" Width="120" Margin="32,0,0,0"  HorizontalAlignment="Left" VerticalAlignment="Center"/>
        <Grid Grid.Row="4" >
            <ItemsControl ItemsSource="{Binding DataItems2}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:ESIOCheckConfDataModel}">
                        <!-- Background：背景色 BorderBrush：边框颜色 -->
                        <Border BorderBrush="#FF9E9898" Background="#FFAAD6FD"  BorderThickness="1" Margin="5,5,5,5" x:Name="sepBd" MouseLeftButtonDown="sepBd_MouseLeftButtonDown_1">
                            <StackPanel  Orientation="Vertical" Width="140">
                                <Label Width="140"  Height="30"  Content="{Binding No}" FontWeight="Bold" FontSize="12" HorizontalContentAlignment="Center" VerticalAlignment="Center"/>
                                <Label Width="140"  Height="30"  Content="{Binding Desc}" FontWeight="Bold" FontSize="12" HorizontalContentAlignment="Center" VerticalAlignment="Center"/>
                                <Label Width="120"  Height="35" Foreground="{Binding Brush}" Content="{Binding Status}" FontWeight="Bold" FontSize="12" Margin="0,0,0,8" HorizontalContentAlignment="Center" VerticalAlignment="Center" TouchDown="Label_TouchDown" PreviewMouseDown="Label_PreviewMouseDown">
                                    <Label.Template>
                                        <ControlTemplate TargetType="Label">
                                            <Border Background="LightBlue" BorderBrush="#FF65B7FF" BorderThickness="1" CornerRadius="1" x:Name="stpLabel">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <!--可以设置多个条件,多给属性当内容是Off时-->
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="Content" Value="Off"/>
                                                    </MultiTrigger.Conditions>
                                                    <MultiTrigger.Setters>
                                                        <!--<Setter Property="Background" TargetName="stpLabel" Value="LightGray"/>-->
                                                    </MultiTrigger.Setters>
                                                </MultiTrigger>
                                                <!--单一属性改变 设置属性值-->
                                                <Trigger Property="Content" Value="On">
                                                    <Setter TargetName="stpLabel" Property="BorderBrush" Value="Beige" />
                                                    <Setter TargetName="stpLabel" Property="Background" Value="Beige" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Label.Template>
                                </Label>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </Grid>

    </Grid>
</Page>
