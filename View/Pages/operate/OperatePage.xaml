<Page
    x:Class="精密切割系统.View.Pages.operate.OperatePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
    xmlns:behav="clr-namespace:精密切割系统.Behaviors"
    xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:common="clr-namespace:精密切割系统.View.Pages.common"
    xmlns:controls="clr-namespace:精密切割系统.View.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:精密切割系统.View.Pages.operate"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:精密切割系统.ViewModel"
    Title="OperatePage"
    d:DataContext="{d:DesignInstance viewModel:CtViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="250"
    d:DesignWidth="1450"
    Loaded="Page_Loaded"
    mc:Ignorable="d">
    <Page.Resources>
        <Style TargetType="Controls:KeyboardBtn">
            <Setter Property="Width" Value="72" />
            <Setter Property="Height" Value="62" />
            <Setter Property="Margin" Value="5" />
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
    </Page.Resources>
    <Grid>
        <Grid
            x:Name="OperateGrid"
            Width="1450"
            Height="250"
            Margin="15,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
        </Grid>

        <controls:DirectOperate x:Name="commonDirection" Visibility="Collapsed" />
        <common:CustomKeyboard x:Name="costomKeyboardGrid" />
        <ItemsControl
            x:Name="OperateButtonListBox"
            Width="1450"
            Height="250"
            Margin="15,0,0,0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            d:ItemsSource="{d:SampleData ItemCount=13}"
            d:Visibility="Collapsed"
            Background="Transparent"
            BorderBrush="Transparent"
            BorderThickness="0"
            ItemsSource="{Binding RightButtonParams}"
            ScrollViewer.CanContentScroll="True"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            VirtualizingPanel.ScrollUnit="Pixel"
            Visibility="Visible">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <!--  每行3个元素  -->
                    <UniformGrid Columns="5" Rows="2" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Controls:BottomButton
                        Margin="8"
                        behav:BehaviorHelper.IsABehaviorActive="{Binding IsOpen}"
                        behav:BehaviorHelper.StartCommand="{Binding StartCommand}"
                        behav:BehaviorHelper.StopCommand="{Binding StopCommand}"
                        behav:BehaviorHelper.TouchAndClickCommand="{Binding TouchAndClickCommand}"
                        BackFlag="{Binding BackFlag}"
                        BackgroundDefColor="{Binding BackgroundDefColor}"
                        BackgroundDownColor="{Binding BackgroundDownColor}"
                        ButtonHeight="100"
                        ButtonWidth="268"
                        ContentText="{Binding ContentText}"
                        ContentTextFontSize="{Binding ContentTextFontSize}"
                        ImagePath="{Binding ImagePath}"
                        IsOpen="{Binding IsOpen}"
                        OpenOrCloseVisibility="{Binding OpenOrCloseVisibility}"
                        Visibility="{Binding ButtonVisibility}">
                        <behaviors:Interaction.Behaviors>
                            <behav:TouchAndClickBehavior TouchAndClickCommand="{Binding RightClickCommand}" />
                            <behav:DualInputBehavior StartCommand="{Binding StartCommand}" StopCommand="{Binding StopCommand}" />
                        </behaviors:Interaction.Behaviors>
                    </Controls:BottomButton>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Page>