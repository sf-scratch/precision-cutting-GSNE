<Page
    x:Class="精密切割系统.View.F6_EngineeringTechnology.ETPositionAlignmentConf"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:精密切割系统.View.F6_EngineeringTechnology"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="ETPositionAlignmentConf"
    d:DesignHeight="676"
    d:DesignWidth="1448"
    Loaded="Page_Loaded"
    mc:Ignorable="d">
    <Grid>
        <Grid.Resources>
            <Style TargetType="Label">
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Height" Value="35" />
                <Setter Property="Margin" Value="0,10,0,0" />
            </Style>
            <Style BasedOn="{StaticResource InputTextStyle}" TargetType="Controls:InputTextBox">
                <Setter Property="Width" Value="300" />
                <Setter Property="Height" Value="35" />
                <Setter Property="InputType" Value="Decimal" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="XPrecision" Value="3" />
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>
        <!--  位置校准 原6.5  -->
        <Label
            x:Name="labPositionAlignment"
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Height="auto"
            Margin="30,30,0,0"
            Content="位置校准(4.2)"
            FontSize="30"
            FontWeight="Bold" />
        <StackPanel
            x:Name="sp1"
            Grid.Row="1"
            Grid.Column="0"
            Margin="30,0,0,0"
            HorizontalAlignment="Left">
            <Label
                x:Name="labThetaCenterLocationGroup"
                Height="35"
                Margin="0,20,0,0"
                Content="θ轴中心点参数"
                FontSize="22"
                FontWeight="Bold" />

            <Label
                x:Name="labThetaCenterLocationX"
                Height="35"
                Margin="0,10,0,0"
                Content="θ轴切割中心点位置 X轴"
                FontWeight="Bold" />
            <Controls:InputTextBox
                x:Name="inputThetaCenterLocationX"
                IsEnabled="False"
                XMax="295"
                XMin="-45" />

            <Label
                x:Name="labThetaCenterLocationY"
                Height="35"
                Margin="0,10,0,0"
                Content="θ轴切割中心点位置 Y轴"
                FontWeight="Bold" />
            <Controls:InputTextBox
                x:Name="inputThetaCenterLocationY"
                IsEnabled="False"
                XMax="135"
                XMin="-15" />

            <Label
                x:Name="labThetaCameraLocationX"
                Height="35"
                Margin="0,10,0,0"
                Content="θ轴相机中心点位置 X轴"
                FontWeight="Bold" />
            <Controls:InputTextBox
                x:Name="inputThetaCameraLocationX"
                XMax="295"
                XMin="-45" />

            <Label
                x:Name="labThetaCameraLocationY"
                Height="35"
                Margin="0,10,0,0"
                Content="θ轴相机中心点位置 Y轴"
                FontWeight="Bold" />
            <Controls:InputTextBox
                x:Name="inputThetaCameraLocationY"
                XMax="135"
                XMin="-45" />
        </StackPanel>
        <StackPanel
            x:Name="sp2"
            Grid.Row="1"
            Grid.Column="1"
            Margin="30,0,0,0"
            HorizontalAlignment="Left">
            <Label
                x:Name="labCutGroup"
                Height="35"
                Margin="0,20,0,0"
                Content="切割参数"
                FontSize="22"
                FontWeight="Bold" />
            <Label
                x:Name="labCameraToCutXOffset"
                Height="35"
                Margin="0,10,0,0"
                Content="切割位置和相机位置的X轴偏移量"
                FontWeight="Bold" />
            <Controls:InputTextBox x:Name="inputCameraToCutXOffset" />

            <Label
                x:Name="labCameraToCutYOffset"
                Height="35"
                Margin="0,10,0,0"
                Content="切割位置和相机位置的Y轴偏移量"
                FontWeight="Bold" />
            <Controls:InputTextBox x:Name="inputCameraToCutYOffset" />

            <Label
                x:Name="labCutZ1MaxLocation"
                Height="35"
                Margin="0,10,0,0"
                Content="X轴切割Z1轴最大安全距离"
                FontWeight="Bold" />
            <Controls:InputTextBox
                x:Name="inputCutZ1MaxLocation"
                XMax="50"
                XMin="-5" />

            <!--<Label
                x:Name="labCameraOffsetX"
                Height="35"
                Margin="0,10,0,0"
                Content="相机和切割点的X轴的偏移量"
                FontSize="16"
                FontWeight="Bold" />
            <Controls:InputTextBox
                x:Name="inputCameraOffsetX"
                Width="300"
                Height="35"
                InputType="Decimal"
                TextWrapping="Wrap"
                XMax="295"
                XMin="-45"
                XPrecision="3" />

            <Label
                x:Name="labCameraOffsetY"
                Height="35"
                Margin="0,10,0,0"
                Content="相机和切割点的Y轴的偏移量"
                FontSize="16"
                FontWeight="Bold" />
            <Controls:InputTextBox
                x:Name="inputCameraOffsetY"
                Width="300"
                Height="35"
                InputType="Decimal"
                TextWrapping="Wrap"
                XMax="135"
                XMin="-15"
                XPrecision="3" />-->
        </StackPanel>
        <StackPanel
            Grid.Row="1"
            Grid.Column="2"
            Margin="30,0,0,0">
            <Label
                x:Name="labCameraGroup"
                Height="35"
                Margin="0,20,0,0"
                Content="相机参数"
                FontSize="22"
                FontWeight="Bold" />
            <!--<Label Height="35"  x:Name="labInitPosition" Content="聚焦初始位置" Margin="0,10,0,0" FontWeight="Bold" FontSize="16" />
            <Controls:InputTextBox x:Name="inputInitPosition" Width="300" TextWrapping="Wrap" Height="35" InputType="Decimal" XMin="-5" XMax="50"  XPrecision="3" />-->
            <!--<Label
                x:Name="labLightIntensityChannel"
                Height="35"
                Margin="0,10,0,0"
                Content="高倍光源通道"
                FontSize="16"
                FontWeight="Bold" />
            <Controls:InputTextBox
                x:Name="inputLightIntensityChannel"
                Width="300"
                Height="35"
                InputType="Numeral"
                TextWrapping="Wrap"
                XMax="4"
                XMin="1" />
            <Label
                x:Name="labLowLightIntensityChannel"
                Height="35"
                Margin="0,10,0,0"
                Content="低倍光源通道"
                FontSize="16"
                FontWeight="Bold" />
            <Controls:InputTextBox
                x:Name="inputLowLightIntensityChannel"
                Width="300"
                Height="35"
                InputType="Numeral"
                TextWrapping="Wrap"
                XMax="4"
                XMin="1" />
            <Label
                x:Name="labRingLightIntensityChannel"
                Height="35"
                Margin="0,10,0,0"
                Content="环光光源通道"
                FontSize="16"
                FontWeight="Bold" />
            <Controls:InputTextBox
                x:Name="inputRingLightIntensityChannel"
                Width="300"
                Height="35"
                InputType="Numeral"
                TextWrapping="Wrap"
                XMax="4"
                XMin="1" />-->
            <Label
                x:Name="labWorkDiscFocusPosition"
                Height="35"
                Margin="0,10,0,0"
                Content="相机聚焦位置"
                FontWeight="Bold" />
            <Controls:InputTextBox
                x:Name="inputWorkDiscFocusPosition"
                XMax="40"
                XMin="-10"
                XPrecision="4" />
            <!--<Label Height="35"  x:Name="labMultipleNum" Content="高速的倍率" Margin="0,10,0,0" FontWeight="Bold" FontSize="16" />
            <Controls:InputTextBox x:Name="inputMultipleNum" Width="300" TextWrapping="Wrap" Height="35" InputType="Decimal" XMin="0" XMax="10"  XPrecision="3" />-->
            <!--<Label
                x:Name="laHighMagToLowMagCameraXOffset"
                Height="35"
                Margin="0,10,0,0"
                Content="高倍相机和低倍相机X轴偏移量"
                FontSize="16"
                FontWeight="Bold" />
            <Controls:InputTextBox
                x:Name="inputHighMagToLowMagCameraXOffset"
                Width="300"
                Height="35"
                InputType="Decimal"
                TextWrapping="Wrap"
                XMax="100"
                XMin="0"
                XPrecision="3" />
            <Label
                x:Name="labHighMagToLowMagCameraYOffset"
                Height="35"
                Margin="0,10,0,0"
                Content="高倍相机和低倍相机Y轴偏移量"
                FontSize="16"
                FontWeight="Bold" />
            <Controls:InputTextBox
                x:Name="inputHighMagToLowMagCameraYOffset"
                Width="300"
                Height="35"
                InputType="Decimal"
                TextWrapping="Wrap"
                XMax="100"
                XMin="0"
                XPrecision="3" />-->
        </StackPanel>
    </Grid>
</Page>