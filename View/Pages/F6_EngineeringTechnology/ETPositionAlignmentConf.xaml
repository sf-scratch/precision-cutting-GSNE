<Page x:Class="精密切割系统.View.F6_EngineeringTechnology.ETPositionAlignmentConf"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:Controls="clr-namespace:精密切割系统.View.Controls"
      xmlns:local="clr-namespace:精密切割系统.View.F6_EngineeringTechnology"
      mc:Ignorable="d" 
      d:DesignHeight="676" d:DesignWidth="1448"
      Title="ETPositionAlignmentConf" Loaded="Page_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="auto"/>
        </Grid.ColumnDefinitions>
        <!--位置校准 原6.5 -->
        <Label x:Name="labPositionAlignment" Content="位置校准(4.2)" Margin="30,30,0,0" Grid.Row="0"  Grid.Column="0" Grid.ColumnSpan="2" FontSize="30" FontWeight="Bold"/>
        <StackPanel Grid.Row="1" Grid.Column="0" x:Name="sp1" HorizontalAlignment="Left" Margin="30,0,0,0">
            <Label  Height="35"  x:Name="labThetaCenterLocationGroup" Content="θ轴中心点参数" Margin="0,20,0,0" FontWeight="Bold" FontSize="22"/>

            <Label Height="35"  x:Name="labThetaCenterLocationX" Content="θ轴切割中心点位置 X轴" Margin="0,10,0,0" FontWeight="Bold" FontSize="16"/>
            <Controls:InputTextBox x:Name="inputThetaCenterLocationX" Width="300" TextWrapping="Wrap" Height="35" InputType="Decimal" XMin="-45" XMax="295" XPrecision="3"/>

            <Label Height="35"  x:Name="labThetaCenterLocationY" Content="θ轴切割中心点位置 Y轴" Margin="0,10,0,0" FontWeight="Bold" FontSize="16"/>
            <Controls:InputTextBox x:Name="inputThetaCenterLocationY" Width="300" TextWrapping="Wrap" Height="35" InputType="Decimal" XMin="-15" XMax="135"  XPrecision="3"/>

            <Label Height="35"  x:Name="labThetaCameraLocationX" Content="θ轴相机中心点位置 X轴" Margin="0,10,0,0" FontWeight="Bold" FontSize="16"/>
            <Controls:InputTextBox x:Name="inputThetaCameraLocationX" Width="300" TextWrapping="Wrap" Height="35" InputType="Decimal" XMin="-45" XMax="295" XPrecision="3"/>

            <Label Height="35"  x:Name="labThetaCameraLocationY" Content="θ轴相机中心点位置 Y轴" Margin="0,10,0,0" FontWeight="Bold" FontSize="16"/>
            <Controls:InputTextBox x:Name="inputThetaCameraLocationY" Width="300" TextWrapping="Wrap" Height="35" InputType="Decimal" XMin="-45" XMax="135"  XPrecision="3"/>
            
            
        </StackPanel>
        <StackPanel Grid.Row="1" Grid.Column="1" x:Name="sp2" HorizontalAlignment="Left" Margin="0,0,0,0" >
            <Label  Height="35"  x:Name="labCutGroup" Content="切割参数" Margin="0,20,0,0" FontWeight="Bold" FontSize="22"/>
            <Label  Height="35"  x:Name="labCameraToCutXOffset" Content="X轴切割位置和相机位置的偏移量" Margin="0,10,0,0" FontWeight="Bold" FontSize="16"/>
            <Controls:InputTextBox x:Name="inputCameraToCutXOffset" Width="300" TextWrapping="Wrap" Height="35" InputType="Decimal" XMin="-45" XMax="295" XPrecision="3" />

            <Label   Height="35"  x:Name="labCameraToCutYOffset" Content="X轴相机焦点和切割位置的偏移量" Margin="0,10,0,0" FontWeight="Bold" FontSize="16"/>
            <Controls:InputTextBox x:Name="inputCameraToCutYOffset" Width="300" TextWrapping="Wrap" Height="35" InputType="Decimal" XMin="-45" XMax="295" XPrecision="3"/>

            <Label  Height="35"  x:Name="labCutZ1MaxLocation" Content="X轴切割Z1轴最大安全距离" Margin="0,10,0,0" FontWeight="Bold" FontSize="16"/>
            <Controls:InputTextBox x:Name="inputCutZ1MaxLocation" Width="300" TextWrapping="Wrap" Height="35" InputType="Decimal" XMin="-5" XMax="50" XPrecision="3"/>

            <Label  Height="35"  x:Name="labCameraOffsetX" Content="相机和切割点的X轴的偏移量" Margin="0,10,0,0" FontWeight="Bold" FontSize="16"/>
            <Controls:InputTextBox x:Name="inputCameraOffsetX" Width="300" TextWrapping="Wrap" Height="35"  InputType="Decimal" XMin="-45" XMax="295" XPrecision="3"/>

            <Label  Height="35"  x:Name="labCameraOffsetY" Content="相机和切割点的Y轴的偏移量" Margin="0,10,0,0" FontWeight="Bold" FontSize="16"/>
            <Controls:InputTextBox x:Name="inputCameraOffsetY" Width="300" TextWrapping="Wrap" Height="35"  InputType="Decimal" XMin="-15" XMax="135" XPrecision="3"/>

        </StackPanel>
        <StackPanel Grid.Row="1" Grid.Column="2">
            <Label Height="35"  x:Name="labCameraGroup" Content="相机参数" Margin="0,20,0,0" FontWeight="Bold" FontSize="22"/>
            <!--<Label Height="35"  x:Name="labInitPosition" Content="聚焦初始位置" Margin="0,10,0,0" FontWeight="Bold" FontSize="16"/>
            <Controls:InputTextBox x:Name="inputInitPosition" Width="300" TextWrapping="Wrap" Height="35" InputType="Decimal" XMin="-5" XMax="50"  XPrecision="3"/>-->
            <Label Height="35"  x:Name="labLightIntensityChannel" Content="高倍光源通道" Margin="0,10,0,0" FontWeight="Bold" FontSize="16"/>
            <Controls:InputTextBox x:Name="inputLightIntensityChannel" Width="300" TextWrapping="Wrap" Height="35" InputType="Numeral" XMin="1" XMax="4"/>
            <Label Height="35"  x:Name="labLowLightIntensityChannel" Content="低倍光源通道" Margin="0,10,0,0" FontWeight="Bold" FontSize="16"/>
            <Controls:InputTextBox x:Name="inputLowLightIntensityChannel" Width="300" TextWrapping="Wrap" Height="35" InputType="Numeral" XMin="1" XMax="4"/>
            <Label Height="35"  x:Name="labRingLightIntensityChannel" Content="环光光源通道" Margin="0,10,0,0" FontWeight="Bold" FontSize="16"/>
            <Controls:InputTextBox x:Name="inputRingLightIntensityChannel" Width="300" TextWrapping="Wrap" Height="35" InputType="Numeral" XMin="1" XMax="4"/>
            <Label Height="35"  x:Name="labWorkDiscFocusPosition" Content="相机聚焦位置" Margin="0,10,0,0" FontWeight="Bold" FontSize="16"/>
            <Controls:InputTextBox x:Name="inputWorkDiscFocusPosition" Width="300" TextWrapping="Wrap" Height="35" InputType="Decimal" XMin="-10" XMax="40"  XPrecision="4"/>
            <!--<Label Height="35"  x:Name="labMultipleNum" Content="高速的倍率" Margin="0,10,0,0" FontWeight="Bold" FontSize="16"/>
            <Controls:InputTextBox x:Name="inputMultipleNum" Width="300" TextWrapping="Wrap" Height="35" InputType="Decimal" XMin="0" XMax="10"  XPrecision="3"/>-->
            <Label Height="35"  x:Name="laHighMagToLowMagCameraXOffset" Content="高倍相机和低倍相机X轴偏移量" Margin="0,10,0,0" FontWeight="Bold" FontSize="16"/>
            <Controls:InputTextBox x:Name="inputHighMagToLowMagCameraXOffset" Width="300" TextWrapping="Wrap" Height="35" InputType="Decimal" XMin="0" XMax="100"  XPrecision="3"/>
            <Label Height="35"  x:Name="labHighMagToLowMagCameraYOffset" Content="高倍相机和低倍相机Y轴偏移量" Margin="0,10,0,0" FontWeight="Bold" FontSize="16"/>
            <Controls:InputTextBox x:Name="inputHighMagToLowMagCameraYOffset" Width="300" TextWrapping="Wrap" Height="35" InputType="Decimal" XMin="0" XMax="100"  XPrecision="3"/>
        </StackPanel>

    </Grid>
</Page>
