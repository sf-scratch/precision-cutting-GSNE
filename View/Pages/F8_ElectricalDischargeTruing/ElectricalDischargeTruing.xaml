<Page x:Class="精密切割系统.View.Pages.F8_ElectricalDischargeTruing.ElectricalDischargeTruing"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"  
      xmlns:Controls="clr-namespace:精密切割系统.View.Controls" 
      xmlns:local="clr-namespace:精密切割系统.ViewModel"
      mc:Ignorable="d" 
      d:DesignHeight="655" d:DesignWidth="1570"
      Title="ElectricalDischargeTruing" Loaded="Page_Loaded" Unloaded="Page_Unloaded">
    <Page.DataContext>
        <local:ElectricalDischargeTruingViewModel></local:ElectricalDischargeTruingViewModel>
    </Page.DataContext>
    <Grid x:Name="bigGird">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"></RowDefinition>
            <RowDefinition Height="60"></RowDefinition>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition Height="60"></RowDefinition>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition Height="50"></RowDefinition>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Label Content="电火花修刀6.0" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="30" FontWeight="Bold" Padding="0,0,0,0" Margin="10,0,0,0"/>
        <Label Content="校准初始位置" HorizontalAlignment="Left" Grid.Row="1" VerticalAlignment="Center" Margin="20,0,0,0" FontSize="20" FontWeight="Bold"/>
        <Label Content="X轴初始位置" HorizontalAlignment="Left" Grid.Row="2" FontSize="16" VerticalAlignment="Center" Margin="20,0,0,0" FontWeight="Bold"/>
        <Controls:InputTextBox Text="{Binding Path=XInitLocation,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Grid.ColumnSpan="2" HorizontalAlignment="Left" Grid.Row="2" TextWrapping="Wrap" VerticalAlignment="Center" Width="200" Height="32" Margin="160,0,0,0" Background="#CAEBFE" MaxLines="10" XMin="-45" XMax="295" InputType="Decimal" />
        <Label Content="mm" HorizontalAlignment="Left" Grid.Row="2" FontSize="16" VerticalAlignment="Center" Margin="365,0,0,0" FontWeight="Bold"/>


        <Label Content="Y轴刀片前端位置" HorizontalAlignment="Left" Grid.Row="3" FontSize="16" VerticalAlignment="Center" Margin="20,0,0,0" FontWeight="Bold"/>
        <Controls:InputTextBox Text="{ Binding Path=YBladeFrontLocation,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged }" Grid.ColumnSpan="3" HorizontalAlignment="Left" Grid.Row="3" TextWrapping="Wrap" VerticalAlignment="Center" Width="200" Height="32" Margin="160,0,0,0" Background="#CAEBFE" XMin="-15" XMax="135" InputType="Decimal" XPrecision="4" />
        <Label Content="mm" HorizontalAlignment="Left" Grid.Row="3" FontSize="16" VerticalAlignment="Center" Margin="365,0,0,0" FontWeight="Bold"/>


        <Label Content="Y轴刀片后端位置" HorizontalAlignment="Left" Grid.Row="4" FontSize="16" VerticalAlignment="Center" Margin="20,0,0,0" FontWeight="Bold"/>
        <Controls:InputTextBox Grid.ColumnSpan="4" HorizontalAlignment="Left" Grid.Row="4" TextWrapping="Wrap" 
                               Text="{ Binding Path=YBladeBackLocation,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Width="200" Height="32" Margin="160,0,0,0" Background="#CAEBFE" XMin="-5" XMax="300" InputType="Decimal" XPrecision="4" />
        <Label Content="mm" HorizontalAlignment="Left" Grid.Row="4" FontSize="16" VerticalAlignment="Center" Margin="365,0,0,0" FontWeight="Bold"/>


        <Label Content="Z轴设定位置" HorizontalAlignment="Left" Grid.Row="5" FontSize="16" VerticalAlignment="Center" Margin="20,0,0,0" FontWeight="Bold"/>
        <Controls:InputTextBox Grid.ColumnSpan="5" HorizontalAlignment="Left" Grid.Row="5" TextWrapping="Wrap" Text="{Binding Path=ZSetPosition,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Width="200" Height="32" Margin="160,0,0,0" Background="#CAEBFE" XMin="-200" XMax="300" InputType="Decimal"   />
        <Label Content="mm" HorizontalAlignment="Left" Grid.Row="5" FontSize="16" VerticalAlignment="Center" Margin="365,0,0,0" FontWeight="Bold"/>

        <Label Content="刀片角度" HorizontalAlignment="Left" Grid.Row="6" FontSize="16" VerticalAlignment="Center" Margin="20,0,0,0" FontWeight="Bold"/>
        <Controls:InputTextBox Grid.ColumnSpan="6" HorizontalAlignment="Left" Grid.Row="6" TextWrapping="Wrap" Text="{Binding Path=BladeAngle,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Width="200" Height="32" Margin="160,0,0,0" Background="#CAEBFE" XMin="-360" XMax="360" InputType="Decimal"   />
        <Label Content="deg" HorizontalAlignment="Left" Grid.Row="6" FontSize="16" VerticalAlignment="Center" Margin="365,0,0,0" FontWeight="Bold"/>

        <Label Content="电火花修刀基准位置" HorizontalAlignment="Left" Grid.Row="7" VerticalAlignment="Center" Margin="20,0,0,0" FontSize="20" FontWeight="Bold"/>

        <Label Content="X0轴基准位置" HorizontalAlignment="Left" Grid.Row="8" FontSize="16" VerticalAlignment="Center" Margin="20,0,0,0" FontWeight="Bold"/>
        <Controls:InputTextBox Grid.ColumnSpan="8" HorizontalAlignment="Left" Grid.Row="8" TextWrapping="Wrap" Text="{Binding Path=X0BasePosition,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Width="200" Height="32" Margin="160,0,0,0" Background="#CAEBFE" XMin="-200" XMax="300" InputType="Decimal"   />
        <Label Content="mm" HorizontalAlignment="Left" Grid.Row="8" FontSize="16" VerticalAlignment="Center" Margin="365,0,0,0" FontWeight="Bold"/>


        <Label Content=" Y0轴基准位置" HorizontalAlignment="Left" Grid.Row="9" FontSize="16" VerticalAlignment="Center" Margin="15,0,0,0" FontWeight="Bold"/>
        <Controls:InputTextBox Grid.ColumnSpan="9" HorizontalAlignment="Left" Grid.Row="9" TextWrapping="Wrap" Text="{Binding Path=Y0BasePosition,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Width="200" Height="32" Margin="160,0,0,0" Background="#CAEBFE" XMin="-200" XMax="300" InputType="Decimal"   />
        <Label Content="mm" HorizontalAlignment="Left" Grid.Row="9" FontSize="16" VerticalAlignment="Center" Margin="365,0,0,0" FontWeight="Bold"/>

        <Label Content="Z0轴基准位置" HorizontalAlignment="Left" Grid.Row="10" FontSize="16" VerticalAlignment="Center" Margin="20,0,0,0" FontWeight="Bold"/>
        <Controls:InputTextBox Grid.ColumnSpan="10" HorizontalAlignment="Left" Grid.Row="10" TextWrapping="Wrap" Text="{Binding Path=Z0BasePosition,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Width="200" Height="32" Margin="160,0,0,0" Background="#CAEBFE" XMin="-200" XMax="300" InputType="Decimal"  XPrecision="4"/>
        <Label Content="mm" HorizontalAlignment="Left" Grid.Row="10" FontSize="16" VerticalAlignment="Center" Margin="365,0,0,0" FontWeight="Bold"/>

        <Label Content="参数设置" HorizontalAlignment="Left" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0" FontSize="20" FontWeight="Bold"/>
        <Label Content="Z轴切割量" HorizontalAlignment="Left" Grid.Row="2" Grid.Column="1" FontSize="16" VerticalAlignment="Center" Margin="20,0,0,0" FontWeight="Bold"/>
        <Controls:InputTextBox Grid.ColumnSpan="2" HorizontalAlignment="Left" Grid.Row="2" Grid.Column="1" TextWrapping="Wrap" Text="{Binding Path=ZCuttingAmount,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Width="200" Height="32" Margin="160,0,0,0" Background="#CAEBFE" XMin="-1000" XMax="1000" InputType="Decimal" XPrecision="4"   />
        <Label Content="mm" HorizontalAlignment="Left" Grid.Row="2" FontSize="16" VerticalAlignment="Center" Margin="360,0,0,0" FontWeight="Bold" Grid.Column="1"/>

        <Label Content="重复次数" HorizontalAlignment="Left" Grid.Row="3" Grid.Column="1" FontSize="16" VerticalAlignment="Center" Margin="20,0,0,0" FontWeight="Bold"/>
        <Controls:InputTextBox Grid.ColumnSpan="3" HorizontalAlignment="Left" Grid.Row="3" Grid.Column="1" TextWrapping="Wrap" Text="{Binding Path=RepeatCount,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Width="200" Height="32" Margin="160,0,0,0" Background="#CAEBFE" XMin="0" XMax="1000" InputType="Numeral" />
        <Label Content="num/times" HorizontalAlignment="Left" Grid.Row="3" FontSize="16" VerticalAlignment="Center" Margin="360,0,0,0" FontWeight="Bold" Grid.Column="1"/>

        <Label Content="电极极性设置" HorizontalAlignment="Left" Grid.Row="4" Grid.Column="1" FontSize="16" VerticalAlignment="Center" Margin="20,0,0,0" FontWeight="Bold"/>
        <Controls:InputTextBox Grid.ColumnSpan="4" HorizontalAlignment="Left" Grid.Row="4" Grid.Column="1" TextWrapping="Wrap" Text="{Binding Path=ElectrodePolaritySetting,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Width="200" Height="32" Margin="160,0,0,0" Background="#CAEBFE" XMin="-200" XMax="1000" InputType="Decimal" XPrecision="4"   />
        <Label Content="mm" HorizontalAlignment="Left" Grid.Row="4" FontSize="16" VerticalAlignment="Center" Margin="360,0,0,0" FontWeight="Bold" Grid.Column="1"/>

        <Label Content="刀片修正速度" HorizontalAlignment="Left" Grid.Row="5" Grid.Column="1" FontSize="16" VerticalAlignment="Center" Margin="20,0,0,0" FontWeight="Bold"/>
        <Controls:InputTextBox Grid.ColumnSpan="5" HorizontalAlignment="Left" Grid.Row="5" Grid.Column="1" TextWrapping="Wrap" Text="{Binding Path=BladeCorrectionSpeed,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Width="200" Height="32" Margin="160,0,0,0" Background="#CAEBFE" XMin="0" XMax="65000" InputType="Decimal" XPrecision="4"   />
        <Label Content="mm/s" HorizontalAlignment="Left" Grid.Row="5" FontSize="16" VerticalAlignment="Center" Margin="360,0,0,0" FontWeight="Bold" Grid.Column="1"/>

        <Label Content="主轴速度" HorizontalAlignment="Left" Grid.Row="6" Grid.Column="1" FontSize="16" VerticalAlignment="Center" Margin="20,0,0,0" FontWeight="Bold"/>
        <Controls:InputTextBox Grid.ColumnSpan="6" HorizontalAlignment="Left" Grid.Row="6" Grid.Column="1" TextWrapping="Wrap" Text="{Binding Path=SpindleSpeed,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Width="200" Height="32" Margin="160,0,0,0" Background="#CAEBFE" XMin="0" XMax="65000" InputType="Decimal"   />
        <Label Content="rpm " HorizontalAlignment="Left" Grid.Row="6" FontSize="16" VerticalAlignment="Center" Margin="360,0,0,0" FontWeight="Bold" Grid.Column="1"/>

        <Label Content="刀片厚度" HorizontalAlignment="Left" Grid.Row="7" Grid.Column="1" FontSize="16" VerticalAlignment="Center" Margin="20,0,0,0" FontWeight="Bold"/>
        <Controls:InputTextBox Grid.ColumnSpan="7" HorizontalAlignment="Left" Grid.Row="7" Grid.Column="1" TextWrapping="Wrap" Text="{Binding Path=BladeThickness,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Width="200" Height="32" Margin="160,0,0,0" Background="#CAEBFE" XMin="0" XMax="1000" InputType="Decimal"   />
        <Label Content="mm" HorizontalAlignment="Left" Grid.Row="7" FontSize="16" VerticalAlignment="Center" Margin="360,0,0,0" FontWeight="Bold" Grid.Column="1"/>

        <Label Content="电极厚度" HorizontalAlignment="Left" Grid.Row="8" Grid.Column="1" FontSize="16" VerticalAlignment="Center" Margin="20,0,0,0" FontWeight="Bold"/>
        <Controls:InputTextBox Grid.ColumnSpan="8" HorizontalAlignment="Left" Grid.Row="8" Grid.Column="1" TextWrapping="Wrap" Text="{Binding Path=ElectrodeThickness,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Width="200" Height="32" Margin="160,0,0,0" Background="#CAEBFE" XMin="0" XMax="1000" InputType="Decimal"   />
        <Label Content="mm" HorizontalAlignment="Left" Grid.Row="8" FontSize="16" VerticalAlignment="Center" Margin="360,0,0,0" FontWeight="Bold" Grid.Column="1"/>

        <Label Content="Y轴偏移量" HorizontalAlignment="Left" Grid.Row="2" Grid.Column="2" FontSize="16" VerticalAlignment="Center" Margin="20,0,0,0" FontWeight="Bold"/>
        <Controls:InputTextBox Grid.ColumnSpan="2" HorizontalAlignment="Left" Grid.Row="2" Grid.Column="2" TextWrapping="Wrap" Text="{Binding Path=YOffsetAmount,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Width="200" Height="32" Margin="160,0,0,0" Background="#CAEBFE" XMin="-200" XMax="300" InputType="Decimal"   />
        <Label Content="mm" HorizontalAlignment="Left" Grid.Row="2" FontSize="16" VerticalAlignment="Center" Margin="360,0,0,0" FontWeight="Bold" Grid.Column="2"/>

        <Label Content="Y轴浮动量" HorizontalAlignment="Left" Grid.Row="3" Grid.Column="2" FontSize="16" VerticalAlignment="Center" Margin="20,0,0,0" FontWeight="Bold"/>
        <Controls:InputTextBox Grid.ColumnSpan="3" HorizontalAlignment="Left" Grid.Row="3" Grid.Column="2" TextWrapping="Wrap" Text="{Binding Path=YFloatingAmount,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Width="200" Height="32" Margin="160,0,0,0" Background="#CAEBFE" XMin="-200" XMax="300" InputType="Decimal"   />
        <Label Content="mm" HorizontalAlignment="Left" Grid.Row="3" FontSize="16" VerticalAlignment="Center" Margin="360,0,0,0" FontWeight="Bold" Grid.Column="2"/>

        <Label Content="Z轴极限位置" HorizontalAlignment="Left" Grid.Row="4" Grid.Column="2" FontSize="16" VerticalAlignment="Center" Margin="20,0,0,0" FontWeight="Bold"/>
        <Controls:InputTextBox Grid.ColumnSpan="4" HorizontalAlignment="Left" Grid.Row="4" Grid.Column="2" TextWrapping="Wrap" Text="{Binding Path=ZLimitPosition,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Width="200" Height="32" Margin="160,0,0,0" Background="#CAEBFE" XMin="-200" XMax="300" InputType="Decimal"   />
        <Label Content="mm" HorizontalAlignment="Left" Grid.Row="4" FontSize="16" VerticalAlignment="Center" Margin="360,0,0,0" FontWeight="Bold" Grid.Column="2"/>

        <Label Content="电极角度" HorizontalAlignment="Left" Grid.Row="5" Grid.Column="2" FontSize="16" VerticalAlignment="Center" Margin="20,0,0,0" FontWeight="Bold"/>
        <Controls:InputTextBox Grid.ColumnSpan="5" HorizontalAlignment="Left" Grid.Row="5" Grid.Column="2" TextWrapping="Wrap" Text="{Binding Path=ElectrodeAngle,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Width="200" Height="32" Margin="160,0,0,0" Background="#CAEBFE" XMin="-360" XMax="360" InputType="Decimal"   />
        <Label Content="deg" HorizontalAlignment="Left" Grid.Row="5" FontSize="16" VerticalAlignment="Center" Margin="360,0,0,0" FontWeight="Bold" Grid.Column="2"/>

        <Grid Grid.Row="9" Grid.Column="1" x:Name="repairGrid">
            <Label Content="修刀进度" HorizontalAlignment="Left" Grid.Row="9" Grid.Column="1" FontSize="16" VerticalAlignment="Center" Margin="20,0,0,0" FontWeight="Bold"/>
            <Controls:InputTextBox x:Name="currentRepairNumInput" Grid.ColumnSpan="5" IsEnabled="False" HorizontalAlignment="Left" Grid.Row="9" Grid.Column="1" TextWrapping="Wrap" Text="{Binding Path=CurrentRepairNum,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Width="100" Height="32" Margin="160,0,0,0" Background="#CAEBFE" XMin="0" XMax="1000" InputType="Numeral" />
            <Label Content="/" HorizontalAlignment="Left" Grid.Row="9" FontSize="16" VerticalAlignment="Center" Margin="263,0,0,0" FontWeight="Bold" Grid.Column="2"/>
            <Controls:InputTextBox x:Name="repeatCountInput" Grid.ColumnSpan="5" IsEnabled="False" HorizontalAlignment="Left" Grid.Row="9" Grid.Column="1" TextWrapping="Wrap" Text="{Binding Path=RepeatCount,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Width="100" Height="32" Margin="283,0,0,0" Background="#CAEBFE" XMin="0" XMax="1000" InputType="Numeral" />
            <Label Content="次" HorizontalAlignment="Left" Grid.Row="9" FontSize="16" VerticalAlignment="Center" Margin="385,0,0,0" FontWeight="Bold" Grid.Column="2"/>
        </Grid>
        <Grid Grid.Row="10" Grid.Column="1" x:Name="allRepairGrid">
            <Label Content="自换刀后修刀数" HorizontalAlignment="Left" Grid.Row="9" Grid.Column="1" FontSize="16" VerticalAlignment="Center" Margin="20,0,0,0" FontWeight="Bold"/>
            <Controls:InputTextBox x:Name="allDressersNumInput" IsEnabled="False" Grid.ColumnSpan="5" HorizontalAlignment="Left" Grid.Row="9" Grid.Column="1" 
                                   TextWrapping="Wrap" Text="{Binding Path=AllDressersNum,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Width="200" Height="32" Margin="160,0,0,0" Background="#CAEBFE" XMin="0" XMax="1000" InputType="Numeral" />
            <Label Content="次" HorizontalAlignment="Left" Grid.Row="9" FontSize="16" VerticalAlignment="Center" Margin="360,0,0,0" FontWeight="Bold" Grid.Column="2"/>
        </Grid>
        <Grid Grid.Row="11" Grid.Column="1" x:Name="clearRepairGrid">
            <Label Content="自清零后修刀数" HorizontalAlignment="Left" Grid.Row="9" Grid.Column="1" FontSize="16" VerticalAlignment="Center" Margin="20,0,0,0" FontWeight="Bold"/>
            <Controls:InputTextBox x:Name="clearDressersNumInput" IsEnabled="False" Grid.ColumnSpan="5" HorizontalAlignment="Left" Grid.Row="9" Grid.Column="1" 
                                   TextWrapping="Wrap" Text="{Binding Path=ClearDressersNum,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Width="200" Height="32" Margin="160,0,0,0" Background="#CAEBFE" XMin="0" XMax="1000" InputType="Numeral" />
            <Label Content="次" HorizontalAlignment="Left" Grid.Row="9" FontSize="16" VerticalAlignment="Center" Margin="360,0,0,0" FontWeight="Bold" Grid.Column="2"/>
        </Grid>
        

    </Grid>
</Page>
