<Window
    x:Class="精密切割系统.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:精密切割系统"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    Title="MainWindow"
    Width="1920"
    Height="1080"
    Background="#FFDFFCFF"
    Loaded="Window_Loaded"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    WindowStyle="None"
    mc:Ignorable="d">
    <Window.Resources>
        <Style x:Key="MyButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="true">
                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="Border" Property="BorderBrush" Value="LightBlue" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="Border" Property="BorderBrush" Value="DarkBlue" />
                                <Setter TargetName="Border" Property="BorderThickness" Value="3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <materialDesign:DialogHost x:Name="MainWindowDialogHost">
        <materialDesign:DialogHost.Resources>
            <ResourceDictionary Source="pack://application:,,,/精密切割系统;component/Themes/MaterialDesignResources.xaml" />
        </materialDesign:DialogHost.Resources>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="140" />
                <RowDefinition Height="*" />
                <RowDefinition Height="15" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Frame
                    x:Name="headerFrame"
                    NavigationUIVisibility="Hidden"
                    Source="View/Pages/Header/HeaderPage.xaml" />
                <!--
            <Grid>
                <TextBox Width="120" Height="30" GotFocus="TextBox_GotFocus" HorizontalAlignment="Left"></TextBox>
                <TextBox Width="120" Height="30" GotFocus="TextBox_GotFocus" VerticalContentAlignment="Stretch"></TextBox>
            </Grid>
                -->
            </Grid>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition Height="250" />
                    </Grid.RowDefinitions>
                    <Border
                        Grid.Row="0"
                        Margin="30,20,10,10"
                        Background="#DFFCFF"
                        CornerRadius="10">
                        <Border.Effect>
                            <DropShadowEffect
                                BlurRadius="20"
                                Direction="315"
                                ShadowDepth="5"
                                Color="#4DC9EBF7" />
                        </Border.Effect>
                        <Grid Grid.Row="0">
                            <Frame
                                x:Name="mainFrame"
                                Grid.Row="1"
                                Grid.Column="0"
                                NavigationUIVisibility="Hidden"
                                Source="View/MainMenu.xaml" />
                            <ContentControl x:Name="mainRegion" prism:RegionManager.RegionName="MainRegion" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="130" />
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <Frame
                                x:Name="operateFrame"
                                NavigationUIVisibility="Hidden"
                                Source="View/Pages/operate/OperatePage.xaml" />
                        </Grid>
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Border
                                    x:Name="shortcutTopBtn"
                                    Width="95"
                                    Height="110"
                                    Background="#FFFFFF"
                                    CornerRadius="10,10,10,10">
                                    <Image
                                        x:Name="shortcutTopIcon"
                                        Width="34"
                                        Height="34"
                                        Source="/Assets/picture/shortcut_top_btn_icon.png" />
                                    <Border.Effect>
                                        <DropShadowEffect
                                            BlurRadius="20"
                                            Direction="315"
                                            ShadowDepth="5"
                                            Color="#4DC9EBF7" />
                                    </Border.Effect>
                                    <!--  设置按钮内容的偏移效果  -->
                                    <Border.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform x:Name="ScaleTransform" ScaleX="1" ScaleY="1" />
                                            <TranslateTransform x:Name="ContentTransform" X="0" Y="0" />
                                        </TransformGroup>
                                    </Border.RenderTransform>
                                </Border>
                            </Grid>
                            <Grid Grid.Row="1">
                                <Border
                                    x:Name="shortcutDirectBtn"
                                    Width="95"
                                    Height="110"
                                    Background="#FFFFFF"
                                    CornerRadius="10,10,10,10">
                                    <Image
                                        x:Name="shortcutDirectIcon"
                                        Width="25"
                                        Height="22"
                                        Source="/Assets/picture/shortcut_direct.png" />
                                    <Border.Effect>
                                        <DropShadowEffect
                                            BlurRadius="20"
                                            Direction="315"
                                            ShadowDepth="5"
                                            Color="#4DC9EBF7" />
                                    </Border.Effect>
                                    <!--  设置按钮内容的偏移效果  -->
                                    <Border.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform x:Name="shortcutScaleTransform" ScaleX="1" ScaleY="1" />
                                            <TranslateTransform x:Name="shortcutDirectTransform" X="0" Y="0" />
                                        </TransformGroup>
                                    </Border.RenderTransform>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
                <Border
                    Grid.Column="1"
                    Margin="10,20,20,10"
                    Background="#DFFCFF"
                    CornerRadius="10">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="20"
                            Direction="315"
                            ShadowDepth="5"
                            Color="#4DC9EBF7" />
                    </Border.Effect>
                    <Grid Grid.Column="1">
                        <Frame
                            x:Name="rightFrame"
                            NavigationUIVisibility="Hidden"
                            Source="View/Pages/right/RightPage.xaml" />
                    </Grid>
                </Border>
            </Grid>
            <Grid Grid.Row="2" />
        </Grid>
    </materialDesign:DialogHost>
</Window>